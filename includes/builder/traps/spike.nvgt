sound_pool spikepool;
spike@[]spikes(0);

class spike
{
int defsound, hitsound, hurtsound, spikesound;
bool destroyable;
bool is_ranged;
double minx, maxx, miny, maxy;
double minz, maxz;
double spikehealth;
double spikemaxhealth;
int damage;
int spiketime;
string spiketype;
timer spiketimer;
spike(double mx,double mx2,double my,double my2,double hp,double maxhp,int dmg,int sp,string st,bool dtb,double mnz=0,double mxz=0,bool rng=true)
{
minx=mx;
maxx=mx2;
miny=my;
maxy=my2;
minz=mnz;
maxz=mxz;
spikehealth=hp;
spikemaxhealth=maxhp;
damage=dmg;
spiketime=sp;
spiketype=st;
destroyable=dtb;
is_ranged=rng;
spikesound=spikepool.play_extended_3d(get_map_sound("builder/traps/spikes/"+spiketype+"/*loop*"),me.x,me.y,me.z,minx,miny,minz,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
spikepool.update_sound_3d(spikesound,minx,miny,minz);
spikepool.update_sound_range_3d(spikesound, 0, maxx-minx, 0, maxy-miny, 0, maxz-minz);
}
}
bool player_in_spike(uint i)
{
if(!(spikes[i].minx<=me.x and spikes[i].maxx>=me.x and spikes[i].miny<=me.y and spikes[i].maxy>=me.y)) return false;
if(mapmode == "3d" && (me.z < spikes[i].minz || me.z > spikes[i].maxz)) return false;
return true;
}
void spikeloop()
{
for(uint i=0; i<spikes.length(); i++)
{
if(@spikes[i] == null) continue;
if(spikes[i].spiketimer.elapsed>=spikes[i].spiketime)
{
spikes[i].spikesound=spikepool.play_extended_3d(get_map_sound("builder/traps/spikes/"+spikes[i].spiketype+"/*loop*"),me.x,me.y,me.z,spikes[i].minx,spikes[i].miny,spikes[i].minz,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
spikepool.update_sound_3d(spikes[i].spikesound,spikes[i].minx,spikes[i].miny,spikes[i].minz);
spikepool.update_sound_range_3d(spikes[i].spikesound, 0, spikes[i].maxx-spikes[i].minx, 0, spikes[i].maxy-spikes[i].miny, 0, spikes[i].maxz-spikes[i].minz);
spikes[i].spiketimer.restart();
if(player_in_spike(i) and shieldon==1 and shield_blocks() and paused==0 and !glider_engine_on)
{
if(shieldpassthrough) spikes[i].hitsound=spikepool.play_stationary_extended(get_map_sound("builder/traps/spikes/"+spikes[i].spiketype+"/*hit*"),false,0,0,0,100,false);
shieldslot=p.play_stationary_extended(get_pack_sound("main/equipments/shields/"+shieldtype+"/general/*hit*"),false,0,0,0,100,false);
int sdm = max(1, (shieldcushion ? int(spikes[i].damage * 0.5) : spikes[i].damage) - (shielddefence * 3));
shieldstrength -= sdm;
kombatlog.insert_last(spikes[i].spiketype + "'s attack took " + shieldtype + " " + sdm + " damage.");
}
else if(player_in_spike(i) and paused==0 and !glider_engine_on)
{
spikes[i].hitsound=spikepool.play_stationary_extended(get_map_sound("builder/traps/spikes/"+spikes[i].spiketype+"/*hit*"),false,0,0,0,100,false);
int dmg = max(1, (spikes[i].damage) - (defence * 3));
health -= dmg;
kombatlog.insert_last(spikes[i].spiketype + "'s attack took you " + dmg + " damage.");
{
string painfile;
int damage_percent = round((float(dmg) / float(maxhealth)) * 100, 0);
if (damage_percent <= 1)
{
painfile = get_pack_sound("main/characters/" + chartype+"/general/*hurt*");
}
else if (damage_percent >= 10)
{
painfile = get_pack_sound("main/characters/" + chartype+"/general/*crit*");
}
else
{
painfile = get_pack_sound("main/characters/" + chartype+"/general/*hurt*");
}
painslot = p.play_stationary_extended(painfile, false, 0, 0, 0, 100, false);
}
}
if(spikes[i].spikehealth<=0)
{
spikepool.destroy_sound(spikes[i].hurtsound);
spikepool.destroy_sound(spikes[i].spikesound);
spikes[i].defsound=spikepool.play_extended_3d(get_map_sound("builder/traps/spikes/"+spikes[i].spiketype+"/*death*"),me.x,me.y,me.z,spikes[i].minx,spikes[i].miny,spikes[i].minz,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
spikepool.update_sound_3d(spikes[i].defsound,spikes[i].minx,spikes[i].miny,spikes[i].minz);
spikepool.update_sound_range_3d(spikes[i].defsound,0,spikes[i].maxx-spikes[i].minx,0,spikes[i].maxy-spikes[i].miny, 0, spikes[i].maxz-spikes[i].minz);
@spikes[i] = null;
return;
}
}
}
}
void spawn_spike(double x1,double x2,double y1,double y2,double hp,double maxhp,int dmg,int sp,string spiketype,bool destroyable,double minz=0,double maxz=0,bool is_ranged=true)
{
spike sp1(x1,x2,y1,y2,hp,maxhp,dmg,sp,spiketype,destroyable,minz,maxz,is_ranged);
spikes.insert_last(sp1);
}
void destroy_all_spikes()
{
for(uint i=0; i<spikes.length(); i++)
{
if(@spikes[i] == null) continue;
spikepool.destroy_sound(spikes[i].spikesound);
}
spikes.resize(0);
}

void build_spike()
{
string[] spikes_list = get_map_sound_folders("builder/traps/spikes/*");
if(spikes_list.length() == 0)
{
dlg("Error. There are no spikes available to view. Press enter to continue.");
resume_pools();
return;
}
string disallowed_nums = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ `!@#$%^&*()[]{};:'\"\\|,<>?_/.+=~";
bool y_uses_back_front = mapmode != "2d";
string saved_x = sel_left_set ? sel_left : "";
string saved_y = y_uses_back_front ? (sel_back_set ? sel_back : "") : (sel_bottom_set ? sel_bottom : "");
string saved_z = sel_bottom_set ? sel_bottom : "";
string saved_mnx = sel_left_set ? sel_left : "";
string saved_mxx = sel_right_set ? sel_right : "";
string saved_mny = y_uses_back_front ? (sel_back_set ? sel_back : "") : (sel_bottom_set ? sel_bottom : "");
string saved_mxy = y_uses_back_front ? (sel_front_set ? sel_front : "") : (sel_top_set ? sel_top : "");
string saved_mnz = sel_bottom_set ? sel_bottom : "";
string saved_mxz = sel_top_set ? sel_top : "";
string saved_hp = "1";
string saved_dm = "";
string saved_sp = "";
int saved_list_pos = 0;
bool saved_dest = false;
int saved_mode_pos = 0;
int last_mode_pos = -2;
bool do_build = true;
int mode_list=-1, mx=-1, my=-1, mz=-1, mnx=-1, mxx=-1, mny=-1, mxy=-1, mnz=-1, mxz=-1, hp=-1, dm=-1, sp=-1, spike_list=-1, dest_cb=-1, ok=-1, cn=-1;
while(true)
{
if(do_build)
{
do_build = false;
if(last_mode_pos != -2)
{
saved_hp = form.get_text(hp);
saved_dm = form.get_text(dm);
saved_sp = form.get_text(sp);
saved_list_pos = form.get_list_position(spike_list);
saved_dest = form.is_checked(dest_cb);
if(last_mode_pos == 1)
{
saved_mnx = form.get_text(mnx);
saved_mxx = form.get_text(mxx);
saved_mny = form.get_text(mny);
saved_mxy = form.get_text(mxy);
if(mnz != -1) saved_mnz = form.get_text(mnz);
if(mxz != -1) saved_mxz = form.get_text(mxz);
}
else
{
saved_x = form.get_text(mx);
saved_y = form.get_text(my);
if(mz != -1) saved_z = form.get_text(mz);
}
}
form.reset();
form.create_window("spike", false, true, last_mode_pos != -2);
mode_list = form.create_list("build mode");
form.add_list_item(mode_list, "single - one tile at a single position", "single");
form.add_list_item(mode_list, "ranged - a rectangular area between a minimum and maximum axes", "ranged");
form.set_list_position(mode_list, saved_mode_pos, false);
mx = -1; my = -1; mz = -1; mnx = -1; mxx = -1; mny = -1; mxy = -1; mnz = -1; mxz = -1;
if(saved_mode_pos == 1)
{
mnx = form.create_input_box("minimum x", saved_mnx);
mxx = form.create_input_box("maximum x", saved_mxx);
mny = form.create_input_box("minimum y", saved_mny);
mxy = form.create_input_box("maximum y", saved_mxy);
if(mapmode == "3d")
{
mnz = form.create_input_box("minimum z", saved_mnz);
mxz = form.create_input_box("maximum z", saved_mxz);
}
}
else
{
mx = form.create_input_box("x", saved_x);
my = form.create_input_box("y", saved_y);
if(mapmode == "3d") mz = form.create_input_box("z", saved_z);
}
hp = form.create_input_box("health", saved_hp);
dm = form.create_input_box("maximum attack", saved_dm);
sp = form.create_input_box("speed", saved_sp);
if(saved_mode_pos == 1)
{
form.set_disallowed_chars(mnx, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(mxx, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(mny, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(mxy, disallowed_nums, false, "This character is not allowed.");
if(mnz != -1) form.set_disallowed_chars(mnz, disallowed_nums, false, "This character is not allowed.");
if(mxz != -1) form.set_disallowed_chars(mxz, disallowed_nums, false, "This character is not allowed.");
}
else
{
form.set_disallowed_chars(mx, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(my, disallowed_nums, false, "This character is not allowed.");
if(mz != -1) form.set_disallowed_chars(mz, disallowed_nums, false, "This character is not allowed.");
}
form.set_disallowed_chars(hp, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(dm, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(sp, disallowed_nums, false, "This character is not allowed.");
spike_list = form.create_list("spike sound");
form.add_list_item(spike_list, "none", "none");
for(uint i = 0; i < spikes_list.length(); i++)
form.add_list_item(spike_list, spikes_list[i], spikes_list[i]);
form.set_list_position(spike_list, saved_list_pos, false);
dest_cb = form.create_checkbox("destroyable", saved_dest);
ok = form.create_button("&okay", true);
cn = form.create_button("&cancel");
if(last_mode_pos == -2) form.focus(mode_list);
else form.focus_silently(mode_list);
last_mode_pos = saved_mode_pos;
}
wait(5);
form.monitor();
int cur_mode_pos = form.get_list_position(mode_list);
if(cur_mode_pos != -1 && cur_mode_pos != last_mode_pos)
{
saved_mode_pos = cur_mode_pos;
do_build = true;
continue;
}
int cur_focus = form.get_current_focus();
if(key_down(KEY_SPACE) && keytimer.elapsed >= keytime)
{
t.destroy_sound(prevslot);
if(cur_focus == spike_list)
{
int p = form.get_list_position(spike_list);
if(p > 0) prevslot = t.play_stationary(get_map_sound("builder/traps/spikes/"+spikes_list[p-1]+"/*hit*"), false);
}
keytimer.restart();
}
if(cur_focus == spike_list && control_is_down() && key_repeating(KEY_L))
{
int p = form.get_list_position(spike_list);
if(p > 0)
{
t.destroy_sound(prevslot);
prevslot = t.play_stationary(get_map_sound("builder/traps/spikes/"+spikes_list[p-1]+"/*loop*"), false);
}
}
if(cur_focus == spike_list && control_is_down() && key_repeating(KEY_H))
{
int p = form.get_list_position(spike_list);
if(p > 0)
{
t.destroy_sound(prevslot);
prevslot = t.play_stationary(get_map_sound("builder/traps/spikes/"+spikes_list[p-1]+"/*death*"), false);
}
}
if(key_pressed(KEY_ESCAPE))
{
t.destroy_sound(prevslot);
resume_pools();
speak("canceled");
return;
}
if(form.is_pressed(cn))
{
t.destroy_sound(prevslot);
resume_pools();
speak("canceled");
return;
}
if(form.is_pressed(ok))
{
bool ranged = (saved_mode_pos == 1);
if(ranged)
{
if(form.get_text(mnx) == "") { speak("Minimum x is required."); form.focus(mnx); continue; }
if(form.get_text(mxx) == "") { speak("Maximum x is required."); form.focus(mxx); continue; }
if(form.get_text(mny) == "") { speak("Minimum y is required."); form.focus(mny); continue; }
if(form.get_text(mxy) == "") { speak("Maximum y is required."); form.focus(mxy); continue; }
if(mnz != -1 && form.get_text(mnz) == "") { speak("Minimum z is required."); form.focus(mnz); continue; }
if(mxz != -1 && form.get_text(mxz) == "") { speak("Maximum z is required."); form.focus(mxz); continue; }
}
else
{
if(form.get_text(mx) == "") { speak("X is required."); form.focus(mx); continue; }
if(form.get_text(my) == "") { speak("Y is required."); form.focus(my); continue; }
if(mz != -1 && form.get_text(mz) == "") { speak("Z is required."); form.focus(mz); continue; }
}
if(form.get_text(hp) == "")
{
speak("Health is required.");
form.focus(hp);
continue;
}
if(form.get_text(dm) == "")
{
speak("Maximum attack is required.");
form.focus(dm);
continue;
}
if(form.get_text(sp) == "")
{
speak("Speed is required.");
form.focus(sp);
continue;
}
double bhp = string_to_number(form.get_text(hp));
int bdmg = string_to_number(form.get_text(dm));
int bsp = string_to_number(form.get_text(sp));
int p = form.get_list_position(spike_list);
string btype = (p > 0) ? spikes_list[p-1] : "none";
bool bdest = form.is_checked(dest_cb);
t.destroy_sound(prevslot);
resume_pools();
if(ranged)
{
double bmnx = string_to_number(form.get_text(mnx));
double bmxx = string_to_number(form.get_text(mxx));
double bmny = string_to_number(form.get_text(mny));
double bmxy = string_to_number(form.get_text(mxy));
double bmnz = (mnz != -1) ? string_to_number(form.get_text(mnz)) : 0;
double bmxz = (mxz != -1) ? string_to_number(form.get_text(mxz)) : 0;
write_ranged_spike(bmnx, bmxx, bmny, bmxy, bhp, bdmg, bsp, btype, bdest, bmnz, bmxz);
spawn_spike(bmnx, bmxx, bmny, bmxy, bhp, bhp, bdmg, bsp, btype, bdest, bmnz, bmxz, true);
}
else
{
double bx = string_to_number(form.get_text(mx));
double by = string_to_number(form.get_text(my));
double bz = (mz != -1) ? string_to_number(form.get_text(mz)) : 0;
write_spike(bx, by, bhp, bdmg, bsp, btype, bdest, bz);
spawn_spike(bx, bx, by, by, bhp, bhp, bdmg, bsp, btype, bdest, bz, bz, false);
}
load_map(mapname, mapowner);
mpool.play_stationary(get_pack_sound("main/characters/"+chartype+"/map/*update*"), false);
speak("Map updated.");
return;
}
}
}

void read_spike(string[] sd)
{
double x=stn(sd[1]);
double y=stn(sd[2]);
double z=0;
int o=3;
if(mapmode=="3d") { z=stn(sd[3]); o=4; }
double hp=stn(sd[o]);
int dmg=stn(sd[o+1]);
int sp=stn(sd[o+2]);
string spiketype=sd[o+3];
bool dbl=string_to_bool(sd[o+4]);
spawn_spike(x, x, y, y, hp, hp, dmg, sp, spiketype, dbl, z, z, false);
}

void write_spike(double x, double y, double hp, int damage, int speed, string spiketype, bool destroyable, double z=0)
{
mapper.open("data/builder/maps/decompiled/"+mapname+"/"+"data/main.sif","ab");
mapdata=mapper.read();
string coords=x+" "+y;
if(mapmode=="3d") coords+=" "+z;
mapper.write("\r\n"+"spike "+coords+" "+hp+" "+damage+" "+speed+" "+spiketype+" "+destroyable);
mapper.close();
bump_map_modified();
}

void read_ranged_spike(string[] sd)
{
double mx=stn(sd[1]);
double mx2=stn(sd[2]);
double my=stn(sd[3]);
double my2=stn(sd[4]);
double mnz=0, mxz=0;
int o=5;
if(mapmode=="3d") { mnz=stn(sd[5]); mxz=stn(sd[6]); o=7; }
double hp=stn(sd[o]);
int dmg=stn(sd[o+1]);
int sp=stn(sd[o+2]);
string spiketype=sd[o+3];
bool dbl=string_to_bool(sd[o+4]);
spawn_spike(mx, mx2, my, my2, hp, hp, dmg, sp, spiketype, dbl, mnz, mxz, true);
}

void write_ranged_spike(double x1, double x2, double y1, double y2, double hp, int damage, int speed, string spiketype, bool destroyable, double minz=0, double maxz=0)
{
mapper.open("data/builder/maps/decompiled/"+mapname+"/"+"data/main.sif","ab");
mapdata=mapper.read();
string coords=x1+" "+x2+" "+y1+" "+y2;
if(mapmode=="3d") coords+=" "+minz+" "+maxz;
mapper.write("\r\n"+"ranged_spike "+coords+" "+hp+" "+damage+" "+speed+" "+spiketype+" "+destroyable);
mapper.close();
bump_map_modified();
}
