class timebomb
{
int hitsound,loopsound,landsound,spawnsound;
int timbombx;
int timbomby;
int damage;
int timbombtime;
string timbombtype;
timer beeptimer, timbombtimer;
timebomb(int bx,int by,int dmg,int btime,string bt)
{
timbombx=bx;
timbomby=by;
damage=dmg;
timbombtime=btime;
timbombtype=bt;
spawnsound=bombpool.play_extended_2d(get_map_sound("objects/time bombs/"+timbombtype+"/*drop*"),me.x, me.y,timbombx, timbomby,0,0,0,0,false,0,0,painvolume,painpitch,false);
loopsound=bombpool.play_extended_2d(get_map_sound("objects/time bombs/"+timbombtype+"/*tick*"),me.x, me.y,timbombx, timbomby,0,0,0,0,false,0,0,painvolume,painpitch,false);
bombpool.update_sound_2d(loopsound, timbombx, timbomby);
}
}
void timebombloop()
{
for(uint i=0; i<timebombs.length(); i++)
{
float progress = 0.0;
if(timebombs[i].timbombtime > 0)
{
progress = 1.0 - float(timebombs[i].timbombtimer.elapsed) / float(timebombs[i].timbombtime);
if(progress < 0) progress = 0;
}
int maxBeep = 1000;
int minBeep = 50;
int interval = int(minBeep + (maxBeep - minBeep) * progress);
if(timebombs[i].beeptimer.elapsed >= interval)
{
timebombs[i].loopsound = bombpool.play_extended_2d(get_map_sound("objects/time bombs/"+timebombs[i].timbombtype+"/*tick*"),me.x, me.y,timebombs[i].timbombx, timebombs[i].timbomby,0,0,0,0,false,0,0,painvolume,painpitch,false);
bombpool.update_sound_2d(timebombs[i].loopsound, timebombs[i].timbombx, timebombs[i].timbomby);
timebombs[i].beeptimer.restart();
}
if(timebombs[i].timbombtimer.elapsed>=timebombs[i].timbombtime)
{
timebombs[i].timbombtimer.restart();
for(uint i1=0; i1<animals.length(); i1++)
{
if(animals[i1].amx==timebombs[i].timbombx and animals[i1].amy==timebombs[i].timbomby)
{
bombpool.destroy_sound(timebombs[i].loopsound);
timebombs[i].landsound=bombpool.play_extended_2d(get_map_sound("objects/time bombs/"+timebombs[i].timbombtype+"/*land*"),me.x,me.y,timebombs[i].timbombx,timebombs[i].timbomby,0,0,0,0,false,0,0,painvolume,painpitch,false);
timebombs[i].hitsound=bombpool.play_extended_2d(get_map_sound("objects/time bombs/"+timebombs[i].timbombtype+"/*hit*"),me.x,me.y,timebombs[i].timbombx,timebombs[i].timbomby,0,0,0,0,false,0,0,painvolume,painpitch,false);
animals[i1].hurtsound=animalpool.play_extended_2d(get_map_sound("npc/animals/"+animals[i1].animaltype+"/*hurt*"),me.x,me.y,animals[i1].amx,animals[i1].amy,0,0,0,0,false,0,0,painvolume,painpitch,false);
animals[i1].animalhealth-=timebombs[i].damage;
timebombs.remove_at(i);
return;
}
}
