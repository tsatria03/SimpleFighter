{
bombpool.destroy_sound(timebombs[i].loopsound);
timebombs[i].landsound=bombpool.play_extended_3d(get_map_sound("builder/traps/time bombs/"+timebombs[i].timbombtype+"/*land*"),me.x,me.y,me.z,timebombs[i].timbombx,timebombs[i].timbomby,timebombs[i].timbombz,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
timebombs[i].hitsound=bombpool.play_extended_3d(get_map_sound("builder/traps/time bombs/"+timebombs[i].timbombtype+"/*hit*"),me.x,me.y,me.z,timebombs[i].timbombx,timebombs[i].timbomby,timebombs[i].timbombz,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
int dmg = max(1, (timebombs[i].damage) - (defence * 3));
health -= dmg;
kombatlog.insert_last(timebombs[i].timbombtype + "'s attack took you " + dmg + " damage.");
{
string painfile;
int damage_percent = round((float(dmg) / float(maxhealth)) * 100, 0);
if (damage_percent <= 1)
{
painfile = get_pack_sound("main/characters/" + chartype+"/general/*hurt*");
}
else if (damage_percent >= 10)
{
painfile = get_pack_sound("main/characters/" + chartype+"/general/*crit*");
}
else
{
painfile = get_pack_sound("main/characters/" + chartype+"/general/*hurt*");
}
painslot = p.play_stationary_extended(painfile, false, 0, 0, 0, 100, false);
}
@timebombs[i] = null;
return;
}
}
}
}
void spawn_timebomb(int x,int y,int dmg,int timbombtime,string timbombtype,int z=0)
{
timebomb tb1(x,y,dmg,timbombtime,timbombtype,z);
timebombs.insert_last(tb1);
}
void destroy_all_timebombs()
{
for(uint i=0;i<timebombs.length();i++)
{
if(@timebombs[i] == null) continue;
bombpool.destroy_sound(timebombs[i].loopsound);
}
timebombs.resize(0);
}

void build_timebomb()
{
string[] tbombs = get_map_sound_folders("builder/traps/time bombs/*");
if(tbombs.length() == 0)
{
dlg("Error. There are no time bombs available to view. Press enter to continue.");
resume_pools();
return;
}
string disallowed_nums = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ `!@#$%^&*()[]{};:'\"\\|,<>?_/.+=~";
form.reset();
form.create_window("time bomb", false);
bool y_uses_back_front = mapmode != "2d";
int mx = form.create_input_box("x", sel_left_set ? sel_left : "");
int my = form.create_input_box("y", y_uses_back_front ? (sel_back_set ? sel_back : "") : (sel_bottom_set ? sel_bottom : ""));
int mz = -1;
if(mapmode == "3d") mz = form.create_input_box("z", sel_bottom_set ? sel_bottom : "");
int dm = form.create_input_box("maximum attack");
int sp = form.create_input_box("speed");
form.set_disallowed_chars(mx, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(my, disallowed_nums, false, "This character is not allowed.");
if(mz != -1) form.set_disallowed_chars(mz, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(dm, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(sp, disallowed_nums, false, "This character is not allowed.");
int tbomb_list = form.create_list("time bomb sound");
form.add_list_item(tbomb_list, "none", "none");
for(uint i = 0; i < tbombs.length(); i++)
form.add_list_item(tbomb_list, tbombs[i], tbombs[i]);
form.set_list_position(tbomb_list, 0, false);
int ok = form.create_button("&okay", true);
int cn = form.create_button("&cancel");
form.focus(mx);
while(true)
{
wait(5);
form.monitor();
int cur_focus = form.get_current_focus();
if(key_down(KEY_SPACE) && keytimer.elapsed >= keytime)
{
t.destroy_sound(prevslot);
if(cur_focus == tbomb_list)
{
int p = form.get_list_position(tbomb_list);
if(p > 0) prevslot = t.play_stationary(get_map_sound("builder/traps/time bombs/"+tbombs[p-1]+"/*land*"), false);
}
keytimer.restart();
}
if(cur_focus == tbomb_list && control_is_down() && key_repeating(KEY_L))
{
int p = form.get_list_position(tbomb_list);
if(p > 0)
{
t.destroy_sound(prevslot);
prevslot = t.play_stationary(get_map_sound("builder/traps/time bombs/"+tbombs[p-1]+"/*tick*"), false);
}
}
if(key_pressed(KEY_ESCAPE))
{
t.destroy_sound(prevslot);
resume_pools();
speak("canceled");
return;
}
if(form.is_pressed(cn))
{
t.destroy_sound(prevslot);
resume_pools();
speak("canceled");
return;
}
if(form.is_pressed(ok))
{
if(form.get_text(mx) == "")
{
speak("X is required.");
form.focus(mx);
continue;
}
if(form.get_text(my) == "")
{
speak("Y is required.");
form.focus(my);
continue;
}
if(mz != -1 && form.get_text(mz) == "")
{
speak("Z is required.");
form.focus(mz);
continue;
}
if(form.get_text(dm) == "")
{
speak("Maximum attack is required.");
form.focus(dm);
continue;
}
if(form.get_text(sp) == "")
{
speak("Speed is required.");
form.focus(sp);
continue;
}
int bx = string_to_number(form.get_text(mx));
int by = string_to_number(form.get_text(my));
int bz = (mz != -1) ? string_to_number(form.get_text(mz)) : 0;
int bdm = string_to_number(form.get_text(dm));
int bsp = string_to_number(form.get_text(sp));
int p = form.get_list_position(tbomb_list);
string btype = (p > 0) ? tbombs[p-1] : "none";
t.destroy_sound(prevslot);
resume_pools();
write_timebomb(bx, by, bdm, bsp, btype, bz);
spawn_timebomb(bx, by, bdm, bsp, btype, bz);
load_map(mapname, mapowner);
mpool.play_stationary(get_pack_sound("main/characters/"+chartype+"/map/*update*"), false);
speak("Map updated.");
return;
}
}
}

void read_timebomb(string[] sd)
{
int x=stn(sd[1]);
int y=stn(sd[2]);
if(sd.length() == 7)
{
int z=stn(sd[3]);
int dmg=stn(sd[4]);
int sp=stn(sd[5]);
string timbotype=sd[6];
spawn_timebomb(x, y, dmg, sp, timbotype, z);
}
else
{
int dmg=stn(sd[3]);
int sp=stn(sd[4]);
string timbotype=sd[5];
spawn_timebomb(x, y, dmg, sp, timbotype, 0);
}
}

void write_timebomb(int x, int y, int damage, int speed, string timbombtype, int z=0)
{
mapper.open("data/builder/maps/decompiled/"+mapname+"/"+"data/main.sif","ab");
mapdata=mapper.read();
if(mapmode == "3d")
mapper.write("\r\n"+"time_bomb "+x+" "+y+" "+z+" "+damage+" "+speed+" "+timbombtype);
else
mapper.write("\r\n"+"time_bomb "+x+" "+y+" "+damage+" "+speed+" "+timbombtype);
mapper.close();
bump_map_modified();
}
