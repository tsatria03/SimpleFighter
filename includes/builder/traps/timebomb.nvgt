loopsound=bombpool.play_extended_3d(get_map_sound("builder/traps/time bombs/"+timbombtype+"/*tick*"),me.x, me.y, me.z,timbombx, timbomby,timbombz,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
