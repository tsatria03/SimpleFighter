bosses[i16].hurtsound=bosspool.play_extended_2d(get_map_sound("npc/bosses/"+bosses[i16].bosstype+"/*hurt*"),me.x,me.y,bosses[i16].bossx,bosses[i16].bossy,0,0,0,0,false,0,0,painvolume,painpitch,false);
bosses[i16].bosshealth-=timebombs[i].damage;
timebombs.remove_at(i);
return;
}
}
if(me.x<timebombs[i].timbombx or me.y<timebombs[i].timbomby and paused==0)
{
bombpool.destroy_sound(timebombs[i].loopsound);
timebombs[i].landsound=bombpool.play_extended_2d(get_map_sound("objects/time bombs/"+timebombs[i].timbombtype+"/*land*"),me.x,me.y,timebombs[i].timbombx,timebombs[i].timbomby,0,0,0,0,false,0,0,weaponvolume,weaponpitch,false);
timebombs.remove_at(i);
return;
}
if(me.x>timebombs[i].timbombx or me.y>timebombs[i].timbomby and paused==0)
{
bombpool.destroy_sound(timebombs[i].loopsound);
timebombs[i].landsound=bombpool.play_extended_2d(get_map_sound("objects/time bombs/"+timebombs[i].timbombtype+"/*land*"),me.x,me.y,timebombs[i].timbombx,timebombs[i].timbomby,0,0,0,0,false,0,0,weaponvolume,weaponpitch,false);
timebombs.remove_at(i);
return;
}
if(me.x==timebombs[i].timbombx and me.y==timebombs[i].timbomby and shieldon==1 and paused==0)
{
bombpool.destroy_sound(timebombs[i].loopsound);
if(shieldhitsound==1) shieldslot=p.play_stationary_extended(get_pack_sound("equipments/shields/"+shieldtype+"/*hit*"),false,0,0,shieldvolume,shieldpitch,false);
int sdm = max(1, (timebombs[i].damage) - (shielddefence * 3));
shieldstrength -= sdm;
kombatlog.insert_last(timebombs[i].timbombtype + "'s attack took " + shieldtype + " " + sdm + " damage.");
timebombs.remove_at(i);
return;
}
else if(me.x==timebombs[i].timbombx and me.y==timebombs[i].timbomby and shieldon==0 and paused==0)
{
bombpool.destroy_sound(timebombs[i].loopsound);
timebombs[i].landsound=bombpool.play_extended_2d(get_map_sound("objects/time bombs/"+timebombs[i].timbombtype+"/*land*"),me.x,me.y,timebombs[i].timbombx,timebombs[i].timbomby,0,0,0,0,false,0,0,weaponvolume,weaponpitch,false);
timebombs[i].hitsound=bombpool.play_extended_2d(get_map_sound("objects/time bombs/"+timebombs[i].timbombtype+"/*hit*"),me.x,me.y,timebombs[i].timbombx,timebombs[i].timbomby,0,0,0,0,false,0,0,painvolume,painpitch,false);
int dmg = max(1, (timebombs[i].damage) - (defence * 3));
health -= dmg;
kombatlog.insert_last(timebombs[i].timbombtype + "'s attack took you " + dmg + " damage.");
if (charhurtsound == 1)
{
string painfile;
int damage_percent = round((float(dmg) / float(maxhealth)) * 100, 0);
if (damage_percent <= 1)
{
painfile = get_pack_sound("characters/" + chartype+"/general/*hurt*");
}
else if (damage_percent >= 10)
{
painfile = get_pack_sound("characters/" + chartype+"/general/*crit*");
}
else
{
painfile = get_pack_sound("characters/" + chartype+"/general/*hurt*");
}
painslot = p.play_stationary_extended(painfile, false, 0, 0, painvolume, painpitch, false);
}
timebombs.remove_at(i);
return;
}
}
}
}
void spawn_timebomb(int x,int y,int dmg,int timbombtime,string timbombtype)
{
timebomb tb1(x,y,dmg,timbombtime,timbombtype);
timebombs.insert_last(tb1);
}
void destroy_all_timebombs()
{
for(uint i=0;i<timebombs.length();i++)
{
bombpool.destroy_sound(timebombs[i].loopsound);
}
timebombs.resize(0);
}

void build_timebomb()
{
string[] tbombs = get_map_sound_folders("objects/time bombs/*");
if(tbombs.length() == 0)
{
dlg("Error. There are no time bombs available to view. Press enter to continue.");
resume_pools();
return;
}
string disallowed_nums = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ `!@#$%^&*()[]{};:'\"\\|,<>?_/.+=~";
form.reset();
form.create_window("time bomb", false);
int mx = form.create_input_box("x", sel_left_set ? sel_left : "");
int my = form.create_input_box("y", sel_bottom_set ? sel_bottom : "");
int dm = form.create_input_box("maximum attack");
int sp = form.create_input_box("speed");
form.set_disallowed_chars(mx, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(my, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(dm, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(sp, disallowed_nums, false, "This character is not allowed.");
int tbomb_list = form.create_list("time bomb sound");
form.add_list_item(tbomb_list, "none", "none");
for(uint i = 0; i < tbombs.length(); i++)
form.add_list_item(tbomb_list, tbombs[i], tbombs[i]);
form.set_list_position(tbomb_list, 0, false);
int ok = form.create_button("&okay", true);
int cn = form.create_button("&cancel");
form.focus(mx);
spool.play_stationary(get_pack_sound("menus/"+menutype+"/*open*"), false);
while(true)
{
wait(5);
form.monitor();
int cur_focus = form.get_current_focus();
if(key_pressed(KEY_SPACE) && spacehold == 0)
{
t.destroy_sound(prevslot);
if(cur_focus == tbomb_list)
{
int p = form.get_list_position(tbomb_list);
if(p > 0) prevslot = t.play_stationary(get_map_sound("objects/time bombs/"+tbombs[p-1]+"/*land*"), false);
}
keytimer.restart();
}
if(key_down(KEY_SPACE) && spacehold == 1 && keytimer.elapsed >= keytime)
{
t.destroy_sound(prevslot);
if(cur_focus == tbomb_list)
{
int p = form.get_list_position(tbomb_list);
if(p > 0) prevslot = t.play_stationary(get_map_sound("objects/time bombs/"+tbombs[p-1]+"/*land*"), false);
}
keytimer.restart();
}
if(cur_focus == tbomb_list && control_is_down() && key_repeating(KEY_L))
{
int p = form.get_list_position(tbomb_list);
if(p > 0)
{
t.destroy_sound(prevslot);
prevslot = t.play_stationary(get_map_sound("objects/time bombs/"+tbombs[p-1]+"/*fall*"), false);
}
}
if(key_pressed(KEY_ESCAPE))
{
t.destroy_sound(prevslot);
resume_pools();
speak("canceled");
return;
}
if(form.is_pressed(cn))
{
t.destroy_sound(prevslot);
resume_pools();
speak("canceled");
return;
}
if(form.is_pressed(ok))
{
if(form.get_text(mx) == "")
{
speak("X is required.");
form.focus(mx);
spool.play_stationary(get_pack_sound("menus/"+menutype+"/*open*"), false);
continue;
}
if(form.get_text(my) == "")
{
speak("Y is required.");
form.focus(my);
spool.play_stationary(get_pack_sound("menus/"+menutype+"/*open*"), false);
continue;
}
if(form.get_text(dm) == "")
{
speak("Maximum attack is required.");
form.focus(dm);
spool.play_stationary(get_pack_sound("menus/"+menutype+"/*open*"), false);
continue;
}
if(form.get_text(sp) == "")
{
speak("Speed is required.");
form.focus(sp);
spool.play_stationary(get_pack_sound("menus/"+menutype+"/*open*"), false);
continue;
}
int bx = string_to_number(form.get_text(mx));
int by = string_to_number(form.get_text(my));
int bdm = string_to_number(form.get_text(dm));
int bsp = string_to_number(form.get_text(sp));
int p = form.get_list_position(tbomb_list);
string btype = (p > 0) ? tbombs[p-1] : "none";
t.destroy_sound(prevslot);
resume_pools();
write_timebomb(bx, by, bdm, bsp, btype);
spawn_timebomb(bx, by, bdm, bsp, btype);
load_map(mapname, mapowner);
mpool.play_stationary(get_pack_sound("characters/"+chartype+"/map/*update*"), false);
speak("Map updated.");
return;
}
}
}

void read_timebomb(string[] sd)
{
int x=stn(sd[1]);
int y=stn(sd[2]);
int dmg=stn(sd[3]);
int sp=stn(sd[4]);
string timbotype=sd[5];
spawn_timebomb(x, y, dmg, sp, timbotype);
}

void write_timebomb(int x, int y, int damage, int speed, string timbombtype)
{
mapper.open("data/maps/decompiled/"+mapname+"/"+"info.sif","ab");
mapdata=mapper.read();
mapper.write("\r\n"+"timebomb "+x+" "+y+" "+damage+" "+speed+" "+timbombtype);
mapper.close();
}
