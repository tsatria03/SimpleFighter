void timebombloop()
{
for(uint i=0; i<timebombs.length(); i++)
{
if(@timebombs[i] == null) continue;
float progress = 0.0;
if(timebombs[i].timbombtime > 0)
{
progress = 1.0 - float(timebombs[i].timbombtimer.elapsed) / float(timebombs[i].timbombtime);
if(progress < 0) progress = 0;
}
int maxBeep = 1000;
int minBeep = 50;
int interval = int(minBeep + (maxBeep - minBeep) * progress);
if(timebombs[i].beeptimer.elapsed >= interval)
{
timebombs[i].loopsound = bombpool.play_extended_3d(get_map_sound("builder/traps/time bombs/"+timebombs[i].timbombtype+"/*tick*"),me.x, me.y, me.z,timebombs[i].timbombx, timebombs[i].timbomby,0,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
bombpool.update_sound_3d(timebombs[i].loopsound, timebombs[i].timbombx, timebombs[i].timbomby, timebombs[i].timbombz);
timebombs[i].beeptimer.restart();
}
if(timebombs[i].timbombtimer.elapsed>=timebombs[i].timbombtime)
{
timebombs[i].timbombtimer.restart();
for(uint j=0; j<npcs.length(); j++)
{
if(@npcs[j] == null) continue;
if(npcs[j].x==timebombs[i].timbombx and npcs[j].y==timebombs[i].timbomby and (mapmode != "3d" or npcs[j].z==timebombs[i].timbombz))
{
bombpool.destroy_sound(timebombs[i].loopsound);
timebombs[i].landsound=bombpool.play_extended_3d(get_map_sound("builder/traps/time bombs/"+timebombs[i].timbombtype+"/*land*"),me.x,me.y,me.z,timebombs[i].timbombx,timebombs[i].timbomby,timebombs[i].timbombz,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
timebombs[i].hitsound=bombpool.play_extended_3d(get_map_sound("builder/traps/time bombs/"+timebombs[i].timbombtype+"/*hit*"),me.x,me.y,me.z,timebombs[i].timbombx,timebombs[i].timbomby,timebombs[i].timbombz,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
sound_pool@ npool = npc_pool(npcs[j].category);
npcs[j].hurtsound=npool.play_extended_3d(get_map_sound("builder/kombat/npc/"+npcs[j].category+"/"+npcs[j].subtype+"/general/*hurt*"),me.x,me.y,me.z,npcs[j].x,npcs[j].y,npcs[j].z,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
npcs[j].health-=timebombs[i].damage;
@timebombs[i] = null;
return;
}
}
