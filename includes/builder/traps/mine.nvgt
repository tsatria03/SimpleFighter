mine@[]mines(0);
class mine
{
bool triggered;
int explodesound, lightsound, minesound, spawnsound, wepsound;
int minex;
int miney;
int damage;
string minetype;
mine(int mx,int my,int dmg,string mt,bool tg)
{
minex=mx;
miney=my;
damage=dmg;
minetype=mt;
triggered=tg;
if(triggered==true) lightsound=minepool.play_extended_2d(get_map_sound("objects/mines/"+minetype+"/*light*"),me.x,me.y,minex,miney,0,0,0,0,false,0,0,0,100,false);
if(triggered==true) minesound=minepool.play_extended_2d(get_map_sound("objects/mines/"+minetype+"/*loop*"),me.x,me.y,minex,miney,0,0,0,0,true,0,0,0,100,false);
if(triggered==false) spawnsound=minepool.play_extended_2d(get_map_sound("objects/mines/"+minetype+"/*spawn*"),me.x,me.y,minex,miney,0,0,0,0,false,0,0,0,100,false);
}
}
void mineloop()
{
for(uint i=0; i<mines.length(); i++)
{
if((absolute(me.x-mines[i].minex)==1 or absolute(me.y-mines[i].miney)==1) and (me.x!=mines[i].minex or me.y!=mines[i].miney) and mines[i].triggered==false and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_repeating(KEY_RETURN))
{
mines[i].lightsound=minepool.play_extended_2d(get_map_sound("objects/mines/"+mines[i].minetype+"/*light*"),me.x,me.y,mines[i].minex,mines[i].miney,0,0,0,0,false,0,0,0,100,false);
mines[i].minesound=minepool.play_extended_2d(get_map_sound("objects/mines/"+mines[i].minetype+"/*loop*"),me.x,me.y,mines[i].minex,mines[i].miney,0,0,0,0,true,0,0,0,100,false);
minepool.update_sound_2d(mines[i].lightsound,mines[i].minex,mines[i].miney);
minepool.update_sound_2d(mines[i].minesound,mines[i].minex,mines[i].miney);
mines[i].triggered=true;
speak("Mine activated.");
}
if(me.x==mines[i].minex and me.y==mines[i].miney and mines[i].triggered==false and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_repeating(KEY_RETURN))
{
speak("Do you want to blow yourself up? If not, then I suggest stepping to the left or right side of the mine to activate it safely. Unless you'd rather become a pile of flesh on the floor, that is.");
}
if(me.x==mines[i].minex and me.y==mines[i].miney and mines[i].triggered==true and shieldon==1 and shieldstrength<=maxshieldstrength and paused==0)
{
minepool.destroy_sound(mines[i].minesound);
if(shieldhitsound==1) shieldslot=minepool.play_stationary_extended(get_pack_sound("equipments/shields/"+shieldtype+"/*hit*"),false,0,0,0,100,false);
int sdm = max(1, (mines[i].damage) - (shielddefence * 3));
shieldstrength -= sdm;
kombatlog.insert_last(mines[i].minetype + "'s attack took " + shieldtype + " " + sdm + " damage.");
mines[i].triggered=false;
mines.remove_at(i);
return;
}
else if(me.x==mines[i].minex and me.y==mines[i].miney and mines[i].triggered==true and shieldon==0 and paused==0)
{
minepool.destroy_sound(mines[i].minesound);
mines[i].explodesound=minepool.play_stationary_extended(get_map_sound("objects/mines/"+mines[i].minetype+"/*explode*"),false,0,0,0,100,false);
mines[i].wepsound=minepool.play_stationary_extended(get_map_sound("objects/mines/"+mines[i].minetype+"/*hit*"),false,0,0,0,100,false);
int dmg = max(1, (mines[i].damage) - (defence * 3));
health -= dmg;
kombatlog.insert_last(mines[i].minetype + "'s attack took you " + dmg + " damage.");
if (charhurtsound == 1)
{
string painfile;
int damage_percent = round((float(dmg) / float(maxhealth)) * 100, 0);
if (damage_percent <= 1)
{
painfile = get_pack_sound("characters/" + chartype+"/general/*hurt*");
}
else if (damage_percent >= 10)
{
painfile = get_pack_sound("characters/" + chartype+"/general/*crit*");
}
else
{
painfile = get_pack_sound("characters/" + chartype+"/general/*hurt*");
}
painslot = p.play_stationary_extended(painfile, false, 0, 0, 0, 100, false);
}
mines[i].triggered=false;
mines.remove_at(i);
return;
}
for(uint j=0; j<npcs.length(); j++)
{
if(npcs[j].x==mines[i].minex and npcs[j].y==mines[i].miney and mines[i].triggered==true)
{
minepool.destroy_sound(mines[i].minesound);
mines[i].explodesound=minepool.play_extended_2d(get_map_sound("objects/mines/"+mines[i].minetype+"/*explode*"),me.x,me.y,mines[i].minex,mines[i].miney,0,0,0,0,false,0,0,0,100,false);
mines[i].wepsound=minepool.play_extended_2d(get_map_sound("objects/mines/"+mines[i].minetype+"/*hit*"),me.x,me.y,mines[i].minex,mines[i].miney,0,0,0,0,false,0,0,0,100,false);
sound_pool@ npool = npc_pool(npcs[j].category);
npcs[j].hurtsound=npool.play_extended_2d(get_map_sound("npc/"+npcs[j].category+"/"+npcs[j].subtype+"/*hurt*"),me.x,me.y,npcs[j].x,npcs[j].y,0,0,0,0,false,0,0,0,100,false);
npcs[j].health-=mines[i].damage;
mines.remove_at(i);
return;
}
}
for(uint i2=0; i2<calanders.length(); i2++)
{
if(calanders[i2].calanderx==mines[i].minex and calanders[i2].calandery==mines[i].miney and calanders[i2].destroyable==true and mines[i].triggered==true)
{
