void spawn_mine(int x,int y,int damage,string minetype,bool triggered)
{
mine mine1(x,y,damage,minetype,triggered);
mines.insert_last(mine1);
}
void destroy_all_mines()
{
for(uint i=0; i<mines.length(); i++)
{
minepool.destroy_sound(mines[i].minesound);
}
mines.resize(0);
}

void build_mine()
{
string[] mines_list = get_map_sound_folders("objects/mines/*");
if(mines_list.length() == 0)
{
dlg("Error. There are no mines available to view. Press enter to continue.");
resume_pools();
return;
}
string disallowed_nums = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ `!@#$%^&*()[]{};:'\"\\|,<>?_/.+=~";
form.reset();
form.create_window("mine", false);
int mx = form.create_input_box("x", sel_left_set ? sel_left : "");
int my = form.create_input_box("y", sel_bottom_set ? sel_bottom : "");
int dm = form.create_input_box("maximum attack");
form.set_disallowed_chars(mx, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(my, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(dm, disallowed_nums, false, "This character is not allowed.");
int mine_list = form.create_list("mine sound");
form.add_list_item(mine_list, "none", "none");
for(uint i = 0; i < mines_list.length(); i++)
form.add_list_item(mine_list, mines_list[i], mines_list[i]);
form.set_list_position(mine_list, 0, false);
int auto_cb = form.create_checkbox("auto activate", false);
int ok = form.create_button("&okay", true);
int cn = form.create_button("&cancel");
form.focus(mx);
while(true)
{
wait(5);
form.monitor();
int cur_focus = form.get_current_focus();
if(key_down(KEY_SPACE) && keytimer.elapsed >= keytime)
{
t.destroy_sound(prevslot);
if(cur_focus == mine_list)
{
int p = form.get_list_position(mine_list);
if(p > 0) prevslot = t.play_stationary(get_map_sound("objects/mines/"+mines_list[p-1]+"/*spawn*"), false);
}
keytimer.restart();
}
if(cur_focus == mine_list && control_is_down() && key_repeating(KEY_L))
{
int p = form.get_list_position(mine_list);
if(p > 0)
{
t.destroy_sound(prevslot);
prevslot = t.play_stationary(get_map_sound("objects/mines/"+mines_list[p-1]+"/*loop*"), false);
}
}
if(cur_focus == mine_list && control_is_down() && key_repeating(KEY_H))
{
int p = form.get_list_position(mine_list);
if(p > 0)
{
t.destroy_sound(prevslot);
prevslot = t.play_stationary(get_map_sound("objects/mines/"+mines_list[p-1]+"/*explode*"), false);
}
}
if(key_pressed(KEY_ESCAPE))
{
t.destroy_sound(prevslot);
resume_pools();
speak("canceled");
return;
}
if(form.is_pressed(cn))
{
t.destroy_sound(prevslot);
resume_pools();
speak("canceled");
return;
}
if(form.is_pressed(ok))
{
if(form.get_text(mx) == "")
{
speak("X is required.");
form.focus(mx);
continue;
}
if(form.get_text(my) == "")
{
speak("Y is required.");
form.focus(my);
continue;
}
if(form.get_text(dm) == "")
{
speak("Maximum attack is required.");
form.focus(dm);
continue;
}
int bx = string_to_number(form.get_text(mx));
int by = string_to_number(form.get_text(my));
int bdmg = string_to_number(form.get_text(dm));
int p = form.get_list_position(mine_list);
string btype = (p > 0) ? mines_list[p-1] : "none";
bool btrig = form.is_checked(auto_cb);
t.destroy_sound(prevslot);
resume_pools();
write_mine(bx, by, bdmg, btype, btrig);
spawn_mine(bx, by, bdmg, btype, btrig);
load_map(mapname, mapowner);
mpool.play_stationary(get_pack_sound("characters/"+chartype+"/map/*update*"), false);
speak("Map updated.");
return;
}
}
}

void read_mine(string[] sd)
{
int x=stn(sd[1]);
int y=stn(sd[2]);
int dmg=stn(sd[3]);
string minetype=sd[4];
bool tg=string_to_bool(sd[5]);
spawn_mine(x, y, dmg, minetype, tg);
}

void write_mine(int x, int y, int damage, string minetype, bool triggered)
{
mapper.open("data/maps/decompiled/"+mapname+"/"+"info.sif","ab");
mapdata=mapper.read();
mapper.write("\r\n"+"mine "+x+" "+y+" "+damage+" "+minetype+" "+triggered);
mapper.close();
}
