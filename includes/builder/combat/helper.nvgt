helpers[i].stepsound=1;
}
if(helpers[i].helpy>bosses[i5].bossy and paused==0)
{
helpers[i].helpy--;
helpers[i].stepsound=1;
}
}
for(uint i6=0; i6<objs.length(); i6++)
{
if(helpers[i].helpx<objs[i6].itx and paused==0)
{
helpers[i].helpx++;
helpers[i].stepsound=1;
