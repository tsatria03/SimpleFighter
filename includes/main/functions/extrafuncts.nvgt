string[] split_lines(string content)
{
string normalized = string_replace(content, "\r\n", "\n", true);
normalized = string_replace(normalized, "\r", "\n", true);
return string_split(normalized, "\n", true);
}
// Strips a leading and trailing double-quote pair from a string. If the string is shorter than 2 chars, or doesn't start AND end with ", the original string is returned unchanged. Used to unwrap quoted values when reading from files that store user-typed text in quotes (e.g. meta.sif description, tts_enemie taunt/hurt/death/voice).
string strip_quotes(string s)
{
	if (s.length() >= 2 && s.substr(0, 1) == "\"" && s.substr(s.length() - 1, 1) == "\"")
		return s.substr(1, s.length() - 2);
	return s;
}
// Wraps a string in double-quotes after stripping any internal quotes. Used when writing user-typed text to files that store values in quoted form. Symmetric with strip_quotes — strip_quotes(quote_value(x)) returns x with any internal quotes removed.
string quote_value(string s)
{
	string cleaned = string_replace(s, "\"", "", true);
	return "\"" + cleaned + "\"";
}
// Parses a comma-separated owners string (the raw form stored in meta.sif's `owner=` line) into a trimmed list of owner names. Empty input or whitespace-only entries are dropped, so an empty `owner=` field yields an empty array.
string[] parse_owner_list(string raw)
{
	string[] result;
	if (raw.length() == 0) return result;
	string[] parts = string_split(raw, ",", true);
	for (uint i = 0; i < parts.length(); i++)
	{
		string p = string_trim_sides(parts[i]);
		if (p.length() > 0) result.insert_last(p);
	}
	return result;
}
string oxford_join(string[]@ parts)
{
uint n = parts.length();
if (n == 0) return "";
if (n == 1) return parts[0];
if (n == 2) return parts[0] + " and " + parts[1];
string result = "";
for (uint i = 0; i < n - 1; i++)
{
result += parts[i] + ", ";
}
result += "and " + parts[n - 1];
return result;
}
// Takes an ISO 8601 timestamp string (e.g. "2026-05-13T14:30:00Z") and returns a human-readable relative-time phrase describing how long ago that moment was: "just now", "5 minutes ago", "3 hours ago", "yesterday", "12 days ago", "2 months ago", "1 year ago". Designed for at-a-glance display in the map menu line and similar surfaces. An unparseable input or a future timestamp returns "just now" defensively.
// The stamp is parsed manually (substr + parse_double) instead of via parse_datetime because POCO's DateTimeParser throws on unexpected input formats and NVGT does not wrap the exception, which crashes the script. Manual parsing on a known fixed format avoids the parser entirely.
string time_ago(string iso8601_stamp)
{
	if (iso8601_stamp.length() < 19) return "just now";
	int year = int(parse_double(iso8601_stamp.substr(0, 4)));
	int month = int(parse_double(iso8601_stamp.substr(5, 2)));
	int day = int(parse_double(iso8601_stamp.substr(8, 2)));
	int hour = int(parse_double(iso8601_stamp.substr(11, 2)));
	int minute = int(parse_double(iso8601_stamp.substr(14, 2)));
	int second = int(parse_double(iso8601_stamp.substr(17, 2)));
	if (year < 1970 || month < 1 || month > 12 || day < 1 || day > 31) return "just now";
	if (hour < 0 || hour > 23 || minute < 0 || minute > 59 || second < 0 || second > 59) return "just now";
	datetime@ then = datetime(year, month, day, hour, minute, second);
	if (@then == null) return "just now";
	timestamp now;
	now.update();
	// POCO utcTime() returns 100-nanosecond intervals (Windows FILETIME units), not microseconds. Divide by 10,000,000 to get seconds.
	int64 diff_ticks = now.UTC_time - then.UTC_time;
	if (diff_ticks < 0) return "just now";
	int64 seconds = diff_ticks / 10000000;
	if (seconds < 60) return "just now";
	if (seconds < 3600)
	{
		int64 mins = seconds / 60;
		return "" + mins + " minute" + (mins == 1 ? "" : "s") + " ago";
	}
	if (seconds < 86400)
	{
		int64 hours = seconds / 3600;
		return "" + hours + " hour" + (hours == 1 ? "" : "s") + " ago";
	}
	int64 days = seconds / 86400;
	if (days == 1) return "yesterday";
	if (days < 30) return "" + days + " days ago";
	if (days < 365)
	{
		int64 months = days / 30;
		return "" + months + " month" + (months == 1 ? "" : "s") + " ago";
	}
	int64 years = days / 365;
	return "" + years + " year" + (years == 1 ? "" : "s") + " ago";
}
bool string_file_encrypt(string input_file, string output_file, string key)
{
bool success;
file f;
success=f.open(input_file, "rb");
if(!success) return false;
string text=f.read();
text=string_encrypt(text, key);
if(text=="") return false;
success=f.open(output_file, "wb");
if(!success) return false;
f.write(text);
success=f.close();
return success;
}
bool string_file_decrypt(const string& input_file, const string& output_file, const string& encryption_key)
{
file input;
if (!input.open(input_file, "rb"))
return false;
string encrypted_content = input.read();
input.close();
string decrypted_content = string_decrypt(encrypted_content, encryption_key);
file output;
if (!output.open(output_file, "wb"))
return false;
output.write(decrypted_content);
output.close();
return true;
}

double percent(double n1, double n2)
{
return (n1/n2)*100;
}
double average(double[] vals, int roundval=2)
{
double res=0;
for(uint i=0; i<vals.length(); i++)
{
res=res+vals[i];
}
res=res/vals.length();
res=round(res,roundval);
return res;
}

double clamp(double value, double min, double max)
{
value=value<min? min:value;
value=value>max? max:value;
return value;
}

int detect_newline(string text)
{
	if(string_find(text, "\r\n") != -1)
		return 2;
	if(string_find(text, "\n") != -1)
		return 1;
	if(string_find(text, "\r") != -1)
		return 3;
	return 0;
}
string normalize_newlines(string text)
{
	text = string_replace(text, "\r\n", "\n", true);
	text = string_replace(text, "\r", "\n", true);
	return text;
}

double distance(int x1, int y1, int x2, int y2)
{
	double dx = double(x2 - x1);
	double dy = double(y2 - y1);
	return sqrt(dx * dx + dy * dy);
}

double min(double a, double b)
{
return (a < b) ? a : b;
}
double max(double a, double b)
{
return (a > b) ? a : b;
}
double buy_item(double item, double base_cost, double cost_multiplier)
{
return 1+(item*0.1)*base_cost*cost_multiplier;
}

double convert_to_pan(double length, double index, double range1, double range2)
{
try
{
double range = range2 - range1;
double percent = index / (length - 1);
double value = range1 + range * percent;
return value;
}
catch
{
return 0;
}
}
double convert_to_volume(double length,double index,double min_volume=-100,double max_volume=0)
{
try
{
double range=max_volume-min_volume;
double percent=index/(length-1);
double value=min_volume+range*percent;
return value;
}
catch
{
return 0;
}
}
double convert_to_pitch(double length,double index,double min_pitch=0,double max_pitch=200)
{
try
{
double range=max_pitch-min_pitch;
double percent=index/(length-1);
double value=min_pitch+range*percent;
return value;
}
catch
{
return 100;
}
}

double string_to_double(string str)
{
	double result = 0.0;
	double fraction = 0.0;
	double divisor = 10.0;
	bool isNegative = false;
	bool inFraction = false;
	if (str.length() == 0) return 0.0;
	if (str.substr(0, 1) == "-")
	{
		isNegative = true;
		str = str.substr(1);
	}
	for (uint i = 0; i < str.length(); i++)
	{
		string c = str.substr(i, 1);
		if (c == ".")
		{
			if (inFraction) break;
			inFraction = true;
			continue;
		}
		int digit = 0;
		if (c == "0") digit = 0;
		else if (c == "1") digit = 1;
		else if (c == "2") digit = 2;
		else if (c == "3") digit = 3;
		else if (c == "4") digit = 4;
		else if (c == "5") digit = 5;
		else if (c == "6") digit = 6;
		else if (c == "7") digit = 7;
		else if (c == "8") digit = 8;
		else if (c == "9") digit = 9;
		else break;
		if (!inFraction)
		{
			result = result * 10.0 + digit;
		}
		else
		{
			fraction += digit / divisor;
			divisor *= 10.0;
		}
	}
	result += fraction;
	return isNegative ? -result : result;
}

float random_float(float min, float max)
{
	int steps = 1000;
	int scaled_min = int(min * steps);
	int scaled_max = int(max * steps);
	if (scaled_max <= scaled_min)
		return min;
	int rnd = random(scaled_min, scaled_max);
	return float(rnd) / steps;
}

