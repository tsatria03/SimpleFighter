bool hidedocks=false, hidegames=false, hidemaps=false, hidemisc=false;   // main-menu items hidden via the preferences show/hide screen
void mainmenu_callback(form_menu@ menu, string data)
{
if(is_recording && controls.action_pressed("recording_menu")) speak("Recording is still running. Open a map to manage it.");
}
void mainmenu()
{
setupmenu(true);
@m.background_callback=@mainmenu_callback;
if(hidedocks==false) m.add_item("documentation menu", "help");
if(hidegames==false) m.add_item("game menu", "game");
if(hidemaps==false) m.add_item("map menu", "map");
if(hidemisc==false) m.add_item("miscellaneous menu", "misc");
m.add_item("preferences menu", "settings");
m.add_item("Change game version. Currently set to "+version, "cgv");
m.add_item("check for updates", "chup");
m.add_item("redownload all sounds", "rdl");
m.add_item("test speakers", "st");
m.add_item("restart game", "rx");
m.add_item("exit game", "ex");
m.intro_text="Main menu. Please choose an option with your arrow keys, then press enter to activate one.";
int mres=m.run();
string main=mres<0?"":m.selected_item_id;
if(mres<0)
{
speak("exiting");
m.fade_music();
exit();
}
if(main=="map")
{
mapmenu();
}
if(main=="game")
{
gamemenu();
}
if(main=="misc")
{
miscmenu();
}
if(main=="help")
{
docksmenu();
}
if(main=="rdl")
{
m.fade_music();
setupmenu();
m.add_item("yes");
m.add_item("no");
m.intro_text="Are you sure you want to redownload all sounds? This action cannot be undone.";
int mres=m.run();
if(mres<0)
{
speak("canceled");
mainmenu();
}
if(mres==0)
{
if(directory_exists("sounds")) directory_delete("sounds");
downloadsounds();
}
if(mres==1)
{
mainmenu();
}
}
if(main=="st")
{
m.fade_music();
dlgplay(get_pack_sound("main/menus/"+menutype+"/*speaker*"), true, true, 30);
mainmenu();
}
if(main=="ex")
{
speak("exiting");
m.fade_music();
exit();
}
if (main == "cgv")
{
m.fade_music();
string newver = vd.input_box("Game version", "Enter a version number to override what the game reports to the updater. Use this to force a re-download of the latest update or to test against a specific version.", version);
if(newver != "" and newver != version)
{
version = newver;
dlg("Version updated to "+version+". Press enter to continue.");
}
else if(newver == version)
{
dlg("Version already set to "+version+". Press enter to continue.");
}
mainmenu();
}
if (main == "chup")
{
m.fade_music();
check_for_updates(version, "SimpleFighter", true);
mainmenu();
}
if(main=="rx")
{
speak("restarting");
m.fade_music();
restart("sf.exe");
}
if(main=="settings")
{
m.fade_music();
settingsmenu();
}
}
