void mainmenu()
{
setupmenu(true);
m.add_item("documentation menu", "help");
m.add_item("map menu", "map");
m.add_item("miscellaneous menu", "misc");
m.add_item("settings menu", "settings");
m.add_item("Change game version. Currently set to "+version, "cgv");
m.add_item("check for updates", "chup");
m.add_item("redownload all sounds", "rdl");
m.add_item("test speakers", "st");
m.add_item("restart game", "rx");
m.add_item("exit game", "ex");
m.intro_text="Main menu. Please choose an option with your arrow keys, then press enter to activate one.";
int mres=m.run();
string main=mres<0?"":m.selected_item_id;
if(mres<0)
{
speak("exiting");
m.fade_music();
exit();
}
if(main=="map")
{
mapmenu();
}
if(main=="misc")
{
miscmenu();
}
if(main=="help")
{
docksmenu();
}
if(main=="rdl")
{
m.fade_music();
setupmenu();
m.add_item("yes");
m.add_item("no");
m.intro_text="Are you sure you want to redownload all sounds? This action cannot be undone.";
int mres=m.run();
if(mres<0)
{
speak("canceled");
mainmenu();
}
if(mres==0)
{
if(directory_exists("sounds")) directory_delete("sounds");
downloadsounds();
}
if(mres==1)
{
mainmenu();
}
}
if(main=="st")
{
m.fade_music();
dlgplay(get_pack_sound("main/menus/"+menutype+"/*speaker*"), true, true, 30);
mainmenu();
}
if(main=="ex")
{
speak("exiting");
m.fade_music();
exit();
}
if (main == "cgv")
{
m.fade_music();
string newver = vd.input_box("Game version", "Enter a version number to override what the game reports to the updater. Use this to force a re-download of the latest update or to test against a specific version.", version);
if(newver != "" and newver != version)
{
version = newver;
dlg("Version updated to "+version+". Press enter to continue.");
}
else if(newver == version)
{
dlg("Version already set to "+version+". Press enter to continue.");
}
mainmenu();
}
if (main == "chup")
{
m.fade_music();
check_for_updates(version, "SimpleFighter", true);
mainmenu();
}
if(main=="rx")
{
speak("restarting");
m.fade_music();
restart("sf.exe");
}
if(main=="settings")
{
m.fade_music();
settingsmenu();
}
}
void docksmenu()
{
while(true)
{
setupmenu(true);
m.add_item("changelog", "changelog");
m.add_item("credits", "credits");
m.add_item("readme", "readme");
m.add_item("todo_list", "todo_list");
m.add_item("back", "back");
m.intro_text="Documentation menu";
int mres=m.run();
if(mres<0) return;
string dnm=m.selected_item_id;
if(dnm=="back") return;
if(dnm=="changelog") { m.fade_music(); dockread("docks/main/changelog.txt"); }
else if(dnm=="credits") { m.fade_music(); dockread("docks/main/credits.txt"); }
else if(dnm=="readme") { m.fade_music(); dockread("docks/main/readme.txt"); }
else if(dnm=="todo_list") { m.fade_music(); dockread("docks/main/todo_list.txt"); }
}
}
void miscmenu()
{
	setupmenu(true);
	m.add_item("data manager menu", "datamanager");
	m.add_item("map tools menu", "maptools");
	m.add_item("pack tools menu", "packtools");
	m.add_item("back", "back");
	m.intro_text="Miscellaneous menu";
	int mres = m.run();
	if(mres < 0)
	{
		mainmenu();
	}
	string sel = m.selected_item_id;
	if(sel == "maptools")
	{
		maptoolsmenu();
	}
	if(sel == "packtools")
	{
		packtoolsmenu();
	}
	if(sel == "datamanager")
	{
		datamanagermenu();
	}
	if(sel == "back")
	{
		mainmenu();
	}
}
void datamanagermenu()
{
	setupmenu(true);
	m.add_item("character", "character");
	m.add_item("npc", "npc");
	m.add_item("shield", "shield");
	m.add_item("weapon", "weapon");
	m.add_item("back", "back");
	m.intro_text="Data manager menu";
	int mres = m.run();
	if(mres < 0)
	{
		miscmenu();
	}
	string sel = m.selected_item_id;
	if(sel == "character")
	{
		character_chooser();
		datamanagermenu();
	}
	if(sel == "npc")
	{
		npc_chooser();
		datamanagermenu();
	}
	if(sel == "shield")
	{
		shield_chooser();
		datamanagermenu();
	}
	if(sel == "weapon")
	{
		weapon_chooser();
		datamanagermenu();
	}
	if(sel == "back")
	{
		miscmenu();
	}
}
void maptoolsmenu()
{
	setupmenu(true);
	m.add_item("compile map", "cpm");
	m.add_item("decompile map", "dpm");
