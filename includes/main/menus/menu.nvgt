speak("Perchis completed.");
wepchar.range+=tempstat;
points-=tempstat;
wepchar.update_x_range(wepchar.range);
}
}
if(ptmem=="umra2")
{
if(points<=0)
{
dlg("Error, you don't have enough points to complete this action. Press enter to continue.");
resume_pools();
return;
}
else if(points>=1)
{
vd.set_disallowed_chars("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ !@#$%^&*()[]{};:'\"\\|,.<>?/+=`~", false, "This character is not allowed.");
string rg2=vd.input_box("","How much y weapon range would you like to buy?");
if(rg2=="")
{
speak("canceled");
pointsmenu();
return;
}
double tempstat=string_to_number(rg2);
p.play_stationary(get_pack_sound("characters/"+chartype+"/general/*buy*"),false);
resume_pools();
speak("Perchis completed.");
wepchar.range2+=tempstat;
points-=tempstat;
wepchar.update_y_range(wepchar.range2);
}
}
if(ptmem=="umra3")
{
if(points<=0)
{
dlg("Error, you don't have enough points to complete this action. Press enter to continue.");
resume_pools();
return;
}
else if(points>=1)
{
vd.set_disallowed_chars("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ !@#$%^&*()[]{};:'\"\\|,.<>?/+=`~", false, "This character is not allowed.");
string rg3=vd.input_box("","How much z weapon range would you like to buy?");
if(rg3=="")
{
speak("canceled");
pointsmenu();
return;
}
double tempstat=string_to_number(rg3);
p.play_stationary(get_pack_sound("characters/"+chartype+"/general/*buy*"),false);
resume_pools();
speak("Perchis completed.");
wepchar.range3+=tempstat;
points-=tempstat;
wepchar.update_z_range(wepchar.range3);
}
}
if(ptmem=="back")
{
resume_pools();
return;
}
}
void weaponsmenu()
{
    string[] cats = get_pack_sound_folders("equipments/weapons/*");
    if(cats.length() == 0)
    {
        dlg("Error. There are no weapon categories available to view. Press enter to continue.");
        resume_pools();
        return;
    }
    // Build tab list with "all" at index 0 followed by each real category.
    string[] tab_cats;
    tab_cats.insert_last("all");
    for(uint i = 0; i < cats.length(); i++) tab_cats.insert_last(cats[i]);
    // Per-tab parallel arrays of weapon labels, ids, unlock state, and source category
    // (source category matters because the "all" tab aggregates from multiple categories).
    string[][] weapon_labels(tab_cats.length());
    string[][] weapon_ids(tab_cats.length());
    bool[][] weapon_unlocked(tab_cats.length());
    string[][] weapon_source_cat(tab_cats.length());
    for(uint i = 0; i < cats.length(); i++)
    {
        string[] weps = get_pack_sound_folders("equipments/weapons/" + cats[i] + "/*");
        for(uint j = 0; j < weps.length(); j++)
        {
            weapon temp;
            temp.parse(cats[i], weps[j]);
            double unlock_level = temp.level;
            bool is_unlocked = level >= unlock_level;
            string label = weps[j];
            if(!is_unlocked) label += " (Unlocked at level " + int_to_string(int(unlock_level)) + ")";
            // Per-category tab (i+1 because "all" is index 0)
            weapon_labels[i+1].insert_last(label);
            weapon_ids[i+1].insert_last(weps[j]);
            weapon_unlocked[i+1].insert_last(is_unlocked);
            weapon_source_cat[i+1].insert_last(cats[i]);
            // "All" tab — aggregate everything
            weapon_labels[0].insert_last(label);
            weapon_ids[0].insert_last(weps[j]);
            weapon_unlocked[0].insert_last(is_unlocked);
            weapon_source_cat[0].insert_last(cats[i]);
        }
    }
    // Sort the "all" tab alphabetically by label, keeping the parallel arrays in sync.
    int[] order(weapon_labels[0].length());
    for(uint i = 0; i < order.length(); i++) order[i] = int(i);
    for(uint i = 1; i < order.length(); i++)
    {
        int key = order[i];
        int j = int(i) - 1;
        while(j >= 0 && weapon_labels[0][order[j]] > weapon_labels[0][key])
        {
            order[j+1] = order[j];
            j--;
        }
        order[j+1] = key;
    }
    string[] sorted_labels(order.length());
    string[] sorted_ids(order.length());
    bool[] sorted_unlocked(order.length());
    string[] sorted_sources(order.length());
    for(uint i = 0; i < order.length(); i++)
    {
        sorted_labels[i] = weapon_labels[0][order[i]];
        sorted_ids[i] = weapon_ids[0][order[i]];
        sorted_unlocked[i] = weapon_unlocked[0][order[i]];
        sorted_sources[i] = weapon_source_cat[0][order[i]];
    }
    weapon_labels[0] = sorted_labels;
    weapon_ids[0] = sorted_ids;
    weapon_unlocked[0] = sorted_unlocked;
    weapon_source_cat[0] = sorted_sources;
    form.reset();
    form.create_window("Weapons menu", false);
    int cat_tab = form.create_tab_panel("category");
    for(uint i = 0; i < tab_cats.length(); i++)
        form.add_list_item(cat_tab, tab_cats[i], tab_cats[i]);
    form.set_list_position(cat_tab, 0, false);
    int[] wep_lists(tab_cats.length());
    for(uint i = 0; i < tab_cats.length(); i++)
    {
        wep_lists[i] = form.create_list(tab_cats[i]);
        for(uint j = 0; j < weapon_labels[i].length(); j++)
            form.add_list_item(wep_lists[i], weapon_labels[i][j], weapon_ids[i][j]);
        if(weapon_labels[i].length() > 0) form.set_list_position(wep_lists[i], 0, false);
        form.assign_to_tab(wep_lists[i], cat_tab, i);
    }
    int ok = form.create_button("&okay", true);
    int cn = form.create_button("&cancel", false, true);
    form.focus(wep_lists[0]);
    while(true)
    {
        wait(5);
        form.monitor();
        int cur_focus = form.get_current_focus();
        int tab_pos = form.get_list_position(cat_tab);
        int active_list = wep_lists[tab_pos];
        // Sound previews — only when a weapon list is focused
        if(cur_focus == active_list)
        {
            int sel = form.get_list_position(active_list);
            if(sel >= 0 && sel < int(weapon_ids[tab_pos].length()))
            {
                string source_cat = weapon_source_cat[tab_pos][sel];
                string folder = "equipments/weapons/" + source_cat + "/" + weapon_ids[tab_pos][sel] + "/";
                if(key_down(KEY_SPACE) && keytimer.elapsed >= keytime)
                {
                    t.destroy_sound(prevslot);
                    prevslot = t.play_stationary(get_pack_sound(folder + "*fire*"), false);
                    keytimer.restart();
                }
                if(control_is_down() && key_repeating(KEY_L))
                {
                    t.destroy_sound(prevslot);
                    prevslot = t.play_stationary(get_pack_sound(folder + "*draw*"), false);
                }
                if(control_is_down() && key_repeating(KEY_H))
                {
                    t.destroy_sound(prevslot);
                    prevslot = t.play_stationary(get_pack_sound(folder + "*hit*"), false);
                }
                if(control_is_down() && key_repeating(KEY_E))
                {
                    t.destroy_sound(prevslot);
                    prevslot = t.play_stationary(get_pack_sound(folder + "*empty*"), false);
                }
                if(control_is_down() && key_repeating(KEY_R))
                {
                    t.destroy_sound(prevslot);
                    prevslot = t.play_stationary(get_pack_sound(folder + "*reload*"), false);
                }
            }
        }
        if(key_pressed(KEY_ESCAPE) || form.is_pressed(cn))
        {
            t.destroy_sound(prevslot);
            resume_pools();
            speak("canceled");
            return;
        }
        if(form.is_pressed(ok))
        {
            int sel = form.get_list_position(active_list);
            if(sel < 0 || sel >= int(weapon_ids[tab_pos].length())) continue;
            if(!weapon_unlocked[tab_pos][sel])
            {
                speak(weapon_labels[tab_pos][sel]);
                continue;
            }
            string source_cat = weapon_source_cat[tab_pos][sel];
            string id = weapon_ids[tab_pos][sel];
            t.destroy_sound(prevslot);
            resume_pools();
            p.destroy_sound(refslot);
            wepdef = 0;
            wepchar.cad = source_cat;
            wepchar.sub = id;
            wepchar.parse(source_cat, id);
            wepchar.play_draw(int(me.x), int(me.y), int(me.z));
            speak(id + " equipped");
            return;
        }
    }
}
void pausemenu()
{
setupmenu();
m.add_item_tts("resume game", "rmg");
m.add_item_tts("view statistics", "vs");
int mres=m.run("Pause menu. ",true);
string psmem=m.get_item_name(mres);
if(mres==0)
{
p.play_stationary(get_pack_sound("characters/"+chartype+"/general/*resume*"),false);
resume_game();
return;
}
if(psmem=="rmg")
{
p.play_stationary(get_pack_sound("characters/"+chartype+"/general/*resume*"),false);
resume_game();
return;
}
if(psmem=="vs")
{
statsmenu();
}
}
