// Per-shield/weapon unlock levels, populated by shieldsmenu/weaponsmenu so the disabled_callback can speak the requirement when the player tries to equip a locked item.
dictionary shield_unlock_levels;
dictionary weapon_unlock_levels;
// weaponsmenu also tracks each item's source category per-tab so the "all" tab can equip from the right folder. Indexed [tab][item].
string[][] weapon_source_cat;
void shield_locked_callback(form_menu@ m, string id)
{
double req = 0;
shield_unlock_levels.get(id, req);
speak(id + " is locked. Reach level " + int_to_string(int(req)) + " to unlock.");
}
void weapon_locked_callback(form_menu@ m, string id)
{
double req = 0;
weapon_unlock_levels.get(id, req);
speak(id + " is locked. Reach level " + int_to_string(int(req)) + " to unlock.");
}

string charsmenu(bool ingame=false)
{
string[] chars=get_pack_sound_folders("main/characters/*");
setupmenu();
@m.background_callback=@chars_callback;
m.intro_text="Character themes menu";
for (uint i=0; i<chars.length(); i++)
{
m.add_item(chars[i],chars[i]);
}
int mres=m.run();
if(mres<0)
{
speak("canceled");
if(ingame==false) settingsmenu();
if(ingame==true) resume_pools();
return "";
}
if(mres>=0 and mres<int(chars.length()))
{
chartype=chars[mres];
charparse();
if(ingame==false)
{
dlg("Character theme set. Press enter to continue.");
settingsmenu();
}
else if(ingame==true)
{
resume_pools();
speak("Character theme set to "+chartype+".");
writepreffs();
}
}
return m.get_item_id(mres);
}
void chars_callback(form_menu@ m, string data)
{
int pos=m.focused_item;
if(pos<0) return;
string chars=m.get_item_id(pos);
if(key_down(KEY_SPACE) and keytimer.elapsed>=keytime)
{
t.destroy_sound(prevslot);
prevslot=t.play_stationary(get_pack_sound("main/characters/"+chars+"/general/*hurt*"), false);
keytimer.restart();
}
if((key_down(KEY_LCONTROL) or key_down(KEY_RCONTROL)) and key_repeating(KEY_D))
{
t.destroy_sound(prevslot);
prevslot=t.play_stationary(get_pack_sound("main/characters/"+chars+"/general/*death*"), false);
}
if((key_down(KEY_LCONTROL) or key_down(KEY_RCONTROL)) and key_repeating(KEY_J))
{
t.destroy_sound(prevslot);
prevslot=t.play_stationary(get_pack_sound("main/characters/"+chars+"/general/*jump*"), false);
}
if((key_down(KEY_LCONTROL) or key_down(KEY_RCONTROL)) and key_repeating(KEY_U))
{
t.destroy_sound(prevslot);
prevslot=t.play_stationary(get_pack_sound("main/characters/"+chars+"/general/*turn*"), false);
}
}
