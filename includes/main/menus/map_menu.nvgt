int buildmenu_last_tab = 0;

bool new_map_form()
{
string disallowed_name = "";
string disallowed_nums = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ `!@#$%^&*()[]{};:'\"\\|,<>?_/.+=~";
string saved_name = "";
string saved_owner = defowner;
string saved_description = "none";
string saved_minx = "";
string saved_maxx = "";
string saved_miny = "";
string saved_maxy = "";
string saved_minz = "";
string saved_maxz = "";
int saved_mode_pos = 0;
int last_mode_pos = -2;
bool do_build = true;
int nm_name, nm_owner, nm_description, nm_mode, nm_minx, nm_maxx, nm_miny, nm_maxy, nm_minz, nm_maxz, nm_ok, nm_cn;
while(true)
{
if(do_build)
{
do_build = false;
if(last_mode_pos != -2)
{
saved_name = form.get_text(nm_name);
saved_owner = form.get_text(nm_owner);
saved_description = form.get_text(nm_description);
saved_minx = form.get_text(nm_minx);
saved_maxx = form.get_text(nm_maxx);
saved_miny = form.get_text(nm_miny);
saved_maxy = form.get_text(nm_maxy);
if(last_mode_pos == 2)
{
saved_minz = form.get_text(nm_minz);
saved_maxz = form.get_text(nm_maxz);
}
}
form.reset();
form.create_window("new map", false, true, last_mode_pos != -2);
nm_mode = form.create_list("map mode");
form.add_list_item(nm_mode, "2d - side-view platformer with jumping and falling", "2d");
form.add_list_item(nm_mode, "topdown - bird's-eye view with free movement on a flat plane and body rotation", "topdown");
form.add_list_item(nm_mode, "3d - full volumetric world with jumping, body rotation, and falling", "3d");
form.set_list_position(nm_mode, saved_mode_pos, false);
nm_name = form.create_input_box("name", saved_name);
form.set_disallowed_chars(nm_name, disallowed_name, false, "This character is not allowed.");
nm_minx = form.create_input_box("minimum length (use a leading dash for negative)", saved_minx);
nm_maxx = form.create_input_box("maximum length (use a leading dash for negative)", saved_maxx);
form.set_disallowed_chars(nm_minx, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(nm_maxx, disallowed_nums, false, "This character is not allowed.");
if(saved_mode_pos == 0)
{
nm_miny = form.create_input_box("minimum height (use a leading dash for negative)", saved_miny);
nm_maxy = form.create_input_box("maximum height (use a leading dash for negative)", saved_maxy);
}
else if(saved_mode_pos == 1)
{
nm_miny = form.create_input_box("minimum width (use a leading dash for negative)", saved_miny);
nm_maxy = form.create_input_box("maximum width (use a leading dash for negative)", saved_maxy);
}
else if(saved_mode_pos == 2)
{
nm_miny = form.create_input_box("minimum width (use a leading dash for negative)", saved_miny);
nm_maxy = form.create_input_box("maximum width (use a leading dash for negative)", saved_maxy);
nm_minz = form.create_input_box("minimum height (use a leading dash for negative)", saved_minz);
nm_maxz = form.create_input_box("maximum height (use a leading dash for negative)", saved_maxz);
form.set_disallowed_chars(nm_minz, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(nm_maxz, disallowed_nums, false, "This character is not allowed.");
}
if(saved_mode_pos != -1)
{
form.set_disallowed_chars(nm_miny, disallowed_nums, false, "This character is not allowed.");
form.set_disallowed_chars(nm_maxy, disallowed_nums, false, "This character is not allowed.");
}
nm_owner = form.create_input_box("owner", saved_owner);
nm_description = form.create_input_box("description", saved_description);
nm_ok = form.create_button("&okay", true);
nm_cn = form.create_button("&cancel");
if(last_mode_pos == -2)
form.focus(nm_mode);
else
form.focus_silently(nm_mode);
last_mode_pos = saved_mode_pos;
}
wait(5);
form.monitor();
int cur_mode_pos = form.get_list_position(nm_mode);
if(cur_mode_pos != last_mode_pos)
{
saved_mode_pos = cur_mode_pos;
do_build = true;
continue;
}
if(key_pressed(KEY_ESCAPE))
{
speak("canceled");
return false;
}
if(form.is_pressed(nm_cn))
{
speak("canceled");
return false;
}
if(form.is_pressed(nm_ok))
{
if(saved_mode_pos == -1)
{
speak("Map mode is required.");
form.focus(nm_mode);
continue;
}
if(form.get_text(nm_name) == "")
{
speak("Name is required.");
form.focus(nm_name);
continue;
}
if(form.get_text(nm_owner) == "")
{
speak("Owner is required.");
form.focus(nm_owner);
continue;
}
if(form.get_text(nm_minx) == "")
{
speak("Minimum length is required.");
form.focus(nm_minx);
continue;
}
if(form.get_text(nm_maxx) == "")
{
speak("Maximum length is required.");
form.focus(nm_maxx);
continue;
}
if(form.get_text(nm_miny) == "")
{
speak((saved_mode_pos == 0) ? "Minimum height is required." : "Minimum width is required.");
form.focus(nm_miny);
continue;
}
if(form.get_text(nm_maxy) == "")
{
speak((saved_mode_pos == 0) ? "Maximum height is required." : "Maximum width is required.");
form.focus(nm_maxy);
continue;
}
if(saved_mode_pos == 2)
{
if(form.get_text(nm_minz) == "")
{
speak("Minimum height is required.");
form.focus(nm_minz);
continue;
}
if(form.get_text(nm_maxz) == "")
{
speak("Maximum height is required.");
form.focus(nm_maxz);
continue;
}
}
string new_name = form.get_text(nm_name);
string new_owner = form.get_text(nm_owner);
string new_description = string_trim_sides(form.get_text(nm_description));
if(new_description == "none") new_description = "";
string new_mode = (saved_mode_pos == 0) ? "2d" : (saved_mode_pos == 1 ? "topdown" : "3d");
double new_minx = string_to_number(form.get_text(nm_minx));
double new_maxx = string_to_number(form.get_text(nm_maxx));
double new_miny = string_to_number(form.get_text(nm_miny));
double new_maxy = string_to_number(form.get_text(nm_maxy));
double new_minz = 0;
double new_maxz = 0;
if(saved_mode_pos == 2)
{
new_minz = string_to_number(form.get_text(nm_minz));
new_maxz = string_to_number(form.get_text(nm_maxz));
}
if(directory_exists("data/builder/maps/decompiled/"+new_name))
{
dlg("Error. A map with this name already exists. Press enter to continue.");
form.focus(nm_name);
continue;
}
create_map(new_name, new_owner, new_mode, new_minx, new_maxx, new_miny, new_maxy, new_minz, new_maxz, new_description);
load_map(new_name, new_owner);
return true;
}
}
return false;
}

