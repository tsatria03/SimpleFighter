void play_player_pain(int dmg)
{
string painfile;
int damage_percent = round((float(dmg) / float(maxhealth)) * 100, 0);
if(damage_percent <= 1)
painfile = get_pack_sound("main/characters/" + chartype + "/general/*hurt*");
else if(damage_percent >= 10)
painfile = get_pack_sound("main/characters/" + chartype + "/general/*crit*");
else
painfile = get_pack_sound("main/characters/" + chartype + "/general/*hurt*");
painslot = p.play_stationary_extended(painfile, false, 0, 0, 0, 100, false);
}

void auto_fire(int x, int y, string facing, int extra_damage, int z=0)
{
if(sub == "" || fire_mode != 1) return;
if(firetimer.elapsed < firetime) return;
firetimer.restart();
fire(x, y, facing, extra_damage, -1, z);
}

void manual_fire(int x, int y, string facing, int extra_damage, int z=0)
{
if(sub == "" || fire_mode != 0) return;
if(is_swinging) return;
if(firetimer2.elapsed < firetime2) return;
firetimer2.restart();
if(is_melee())
p.play_stationary(get_pack_sound("main/characters/"+chartype+"/general/*swing*"), false);
if(is_melee() && swing_speed > 0)
{
sound_slot = p.play_extended_3d(get_pack_sound("main/equipments/weapons/"+cad+"/"+sub+"/general/*fire*"), me.x, me.y, me.z, x, y, z, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
is_swinging = true;
swing_timer.restart();
pending_dmg = damage + extra_damage + int(type_bonus());
return;
}
fire(x, y, facing, extra_damage, -1, z);
}

void check_swing(int fx, int fy, int fz, string facing, int firer_npc = -1)
{
if(!is_swinging) return;
if(swing_timer.elapsed < swing_speed) return;
is_swinging = false;
melee_strike(fx, fy, fz, pending_dmg, firer_npc, facing);
}

void update_max_ammo(double new_max)
{
string path = "sounds/decompiled/main/equipments/weapons/" + cad + "/" + sub + "/data/info.sif";
if(!info.open(path, "r")) { speak("Failed to open file for reading."); return; }
string content = info.read();
info.close();
int pos = string_contains(content, "max ammo=", 1);
if(pos == -1) { speak("Max ammo stat not found in file."); return; }
int value_start = pos + 9;
int value_end = string_contains(content.substr(value_start), "\r\n", 1);
if(value_end == -1) value_end = content.length() - value_start;
string current = string_trim_sides(content.substr(value_start, value_end));
content = string_replace(content, "max ammo=" + current, "max ammo=" + string(new_max), true);
if(!info.open(path, "w")) { speak("Failed to open file for writing."); return; }
uint bytes_written = info.write(content);
info.close();
if(bytes_written == content.length()) speak("Max ammo updated successfully.");
else speak("Failed to write updated max ammo to file.");
}

void update_range_axis(string axis, int new_range)
{
string key = axis + " range";
string path = "sounds/decompiled/main/equipments/weapons/" + cad + "/" + sub + "/data/info.sif";
if(!info.open(path, "r")) { speak("Failed to open file for reading."); return; }
string content = info.read();
info.close();
int range_pos = string_contains(content, key+"=", 1);
if(range_pos == -1) { speak(key + " stat not found in file."); return; }
int value_start = range_pos + key.length() + 1;
int value_end = string_contains(content.substr(value_start), "\r\n", 1);
if(value_end == -1) value_end = content.length() - value_start;
string current = string_trim_sides(content.substr(value_start, value_end));
content = string_replace(content, key+"=" + current, key+"=" + string(new_range), true);
if(!info.open(path, "w")) { speak("Failed to open file for writing."); return; }
uint bytes_written = info.write(content);
info.close();
if(bytes_written == content.length()) speak(key + " stat updated successfully.");
else speak("Failed to write updated " + key + " stat to file.");
}

void update_x_range(int new_range) { update_range_axis("x", new_range); }
void update_y_range(int new_range) { update_range_axis("y", new_range); }
void update_z_range(int new_range) { update_range_axis("z", new_range); }
}

bool tile_blocked(int x, int y, int z, bool is_3d)
{
if(x < int(minx) or x > int(maxx)) return true;
if(y < int(miny) or y > int(maxy)) return true;
if(is_3d and (z < int(minz) or z > int(maxz))) return true;
for(uint i = 0; i < walls.length(); i++)
{
if(@walls[i] == null) continue;
if(x < int(walls[i].minx) or x > int(walls[i].maxx)) continue;
if(y < int(walls[i].miny) or y > int(walls[i].maxy)) continue;
if(is_3d)
{
if(z < int(walls[i].minz) or z > int(walls[i].maxz)) continue;
}
return true;
}
return false;
}

int apply_push(int &inout tx, int &inout ty, int &inout tz, int ax, int ay, int az, int px, int py, int pz, bool is_3d, string bdir = "")
{
int impact = 0;
if(px != 0)
{
int sign = 0;
if(bdir == "right") sign = 1;
else if(bdir == "left") sign = -1;
if(sign == 0)
{
int d = tx - ax;
if(d > 0) sign = 1;
else if(d < 0) sign = -1;
}
if(px < 0) sign = -sign;
if(sign != 0)
{
int mag = absolute(px);
int walked = 0;
for(int s = 0; s < mag; s++)
{
int nx = tx + sign;
if(tile_blocked(nx, ty, tz, is_3d)) break;
tx = nx;
walked++;
}
int leftover = mag - walked;
if(leftover > 0) impact += leftover * absolute(px);
}
}
if(py != 0)
{
int sign = 0;
if(bdir == "forward") sign = 1;
else if(bdir == "backward") sign = -1;
else if(!is_3d and bdir == "up") sign = 1;
else if(!is_3d and bdir == "down") sign = -1;
if(sign == 0)
{
int d = ty - ay;
if(d > 0) sign = 1;
else if(d < 0) sign = -1;
}
if(py < 0) sign = -sign;
if(sign != 0)
{
int mag = absolute(py);
int walked = 0;
for(int s = 0; s < mag; s++)
{
int ny = ty + sign;
if(tile_blocked(tx, ny, tz, is_3d)) break;
ty = ny;
walked++;
}
int leftover = mag - walked;
if(leftover > 0) impact += leftover * absolute(py);
}
}
if(is_3d and pz != 0)
{
int sign = 0;
if(bdir == "up") sign = 1;
else if(bdir == "down") sign = -1;
if(sign == 0)
{
int d = tz - az;
if(d > 0) sign = 1;
else if(d < 0) sign = -1;
}
if(pz < 0) sign = -sign;
if(sign != 0)
{
int mag = absolute(pz);
int walked = 0;
for(int s = 0; s < mag; s++)
{
int nz = tz + sign;
if(tile_blocked(tx, ty, nz, is_3d)) break;
tz = nz;
walked++;
}
int leftover = mag - walked;
if(leftover > 0) impact += leftover * absolute(pz);
}
}
return impact;
}

