bool cloner_has_last = false;

double damage_melee=0;

int refslot;

int cloner_last_x = 0, cloner_last_y = 0, cloner_last_z = 0;
int wepdef=0;

dictionary damage_by_type;
dictionary ammo_reserves;
dictionary ammo_types_bought;

sound_pool specialpool;
weapon wepchar;

class weapon
{
string cad;
string sub;

int damage;
int range;
int range2;
int range3;
int speed;
int firetime;
int firetime2;
int fire_mode;
int weight;
int stun;
string launch_type;
string launch_subtype;
string ammo_type;
bool is_player_weapon;

double ammo;
double max_ammo;
double loaded_ammo;
double level;

bool melee;
bool reflection;
int refchance;
bool refcushion;

int scadder_radius;
int scadder_count;
int swing_speed;

int push_x;
int push_y;
int push_z;

int health_drain;

int life_drain;

int stamina_drain;

bool is_reloading;
double pending_ammo;
int reload_duration;
timer reload_timer;

timer firetimer;
timer firetimer2;

bool is_swinging;
timer swing_timer;
int pending_dmg;

int sound_slot;

weapon()
{
cad = "melee";
sub = "fist";
damage = 1;
range = 1;
range2 = 1;
range3 = 1;
speed = 30;
firetime = 100;
firetime2 = 100;
fire_mode = 0;
weight = 1;
stun = 0;
ammo = 100;
max_ammo = 100;
loaded_ammo = 100;
level = 1;
launch_type = "bullet";
launch_subtype = "";
ammo_type = "normal";
melee = true;
reflection = true;
refchance = 80;
refcushion = false;
scadder_radius = 0;
scadder_count = 0;
swing_speed = 0;
push_x = 0;
push_y = 0;
push_z = 0;
health_drain = 0;
life_drain = 0;
stamina_drain = 0;
is_swinging = false;
pending_dmg = 0;
is_reloading = false;
pending_ammo = 0;
reload_duration = 0;
sound_slot = 0;
}

bool is_melee()
{
return melee;
}

bool is_glider()
{
return sub.length() >= 6 && sub.substr(0, 6) == "glider";
}

void parse(string c, string s)
{
if(is_glider()) glider_engine_stop();
cad = c;
sub = s;
melee = (cad == "melee");
reflection = (cad == "melee");
refchance = 80;
refcushion = false;
scadder_radius = 0;
scadder_count = 0;
swing_speed = 0;
push_x = 0;
push_y = 0;
push_z = 0;
health_drain = 0;
life_drain = 0;
stamina_drain = 0;
is_swinging = false;
pending_dmg = 0;
string content = read_datafile("main/equipments/weapons/" + cad + "/" + sub + "/data/info.sif");
if(content == "") return;
launch_type = "bullet";
launch_subtype = "";
ammo_type = (cad == "melee") ? "none" : "normal";
stun = 0;
damage = 1;
range = 1;
range2 = 1;
range3 = 1;
speed = 30;
firetime = 100;
firetime2 = 100;
fire_mode = 0;
weight = 1;
ammo = 100;
max_ammo = 100;
loaded_ammo = 100;
level = 1;
string[] lines = split_lines(content);
for(uint i = 0; i < lines.length(); i++)
{
string[] data = string_split(lines[i], "=", true);
if(data.length() < 2) continue;
if(data[0] == "damage") damage = parse_int(data[1]);
else if(data[0] == "fire mode") fire_mode = parse_int(data[1]);
else if(data[0] == "x range") range = span_int(data[1]);
else if(data[0] == "y range") range2 = span_int(data[1]);
else if(data[0] == "z range") range3 = span_int(data[1]);
else if(data[0] == "bullet speed") speed = parse_int(data[1]);
else if(data[0] == "repeat time") firetime = parse_int(data[1]);
else if(data[0] == "spam time") firetime2 = parse_int(data[1]);
else if(data[0] == "weight") weight = parse_int(data[1]);
else if(data[0] == "ammo") ammo = parse_double(data[1]);
else if(data[0] == "loaded ammo") loaded_ammo = parse_double(data[1]);
else if(data[0] == "max ammo") max_ammo = parse_double(data[1]);
else if(data[0] == "unlock level") level = parse_double(data[1]);
else if(data[0] == "launch type")
{
string val = data[1];
int colon = string_contains(val, ":", 1);
if(colon >= 0)
{
launch_type = string_left(val, colon);
launch_subtype = string_mid(val, colon+2, val.length()-colon-1);
}
else
{
launch_type = val;
launch_subtype = "";
}
}
else if(data[0] == "stun mode")
{
string[] toks = string_split(data[1], ":", true);
int enabled = (toks.length() >= 1 && toks[0] != "") ? parse_int(toks[0]) : 0;
int dur = (toks.length() >= 2 && toks[1] != "") ? parse_int(toks[1]) : 0;
stun = (enabled == 1 && dur > 0) ? dur : 0;
}
else if(data[0] == "ammo type")
{
string[] allowed_types = {"normal", "gas", "air", "battery", "powder", "arrow", "rocket", "water", "knife", "needle", "dart", "ball", "mana", "fuel", "rock", "grenade"};
bool valid = false;
for(uint k = 0; k < allowed_types.length(); k++) if(allowed_types[k] == data[1]) { valid = true; break; }
if(valid) ammo_type = data[1];
else ammo_type = (cad == "melee") ? "none" : "normal";
}
else if(data[0] == "melee") melee = (data[1] == "true");
else if(data[0] == "reflection") reflection = (data[1] == "true");
else if(data[0] == "scadder")
{
string[] sc_parts = string_split(data[1], ":", true);
int sr = (sc_parts.length() >= 1 && sc_parts[0] != "") ? parse_int(sc_parts[0]) : 0;
int sc = (sc_parts.length() >= 2 && sc_parts[1] != "") ? parse_int(sc_parts[1]) : 0;
if(sr < 0) sr = 0;
if(sc < 0) sc = 0;
scadder_radius = sr;
scadder_count = sc;
}
else if(data[0] == "swing speed")
{
int v = parse_int(data[1]);
if(v < 0) v = 0;
swing_speed = v;
}
else if(data[0] == "push x") push_x = span_int(data[1]);
else if(data[0] == "push y") push_y = span_int(data[1]);
else if(data[0] == "push z") push_z = span_int(data[1]);
else if(data[0] == "health drain")
{
int v = parse_int(data[1]);
health_drain = (v < 0) ? 0 : v;
}
else if(data[0] == "life drain")
{
int v = parse_int(data[1]);
life_drain = (v < 0) ? 0 : v;
}
else if(data[0] == "stamina drain")
{
int v = parse_int(data[1]);
stamina_drain = (v < 0) ? 0 : v;
}
else if(data[0] == "refchance")
{
string[] rc_parts = string_split(data[1], ":", true);
int v = (rc_parts.length() >= 1 && rc_parts[0] != "") ? parse_int(rc_parts[0]) : 80;
if(v < 0) v = 0;
if(v > 100) v = 100;
refchance = v;
if(rc_parts.length() >= 2) refcushion = (rc_parts[1] == "true");
}
}
if(is_glider())
{
fire_mode = 1;
melee = true;
swing_speed = 0;
scadder_radius = 0;
scadder_count = 0;
launch_type = "bullet";
launch_subtype = "";
ammo_type = "none";
weight = 1;
reflection = false;
refchance = 80;
refcushion = false;
life_drain = 0;
}
}

void play_draw(int x, int y, int z=0)
{
is_reloading = false;
pending_ammo = 0;
reload_duration = 0;
sound_slot = p.play_extended_3d(get_pack_sound("main/equipments/weapons/"+cad+"/"+sub+"/general/*draw*"), me.x, me.y, me.z, x, y, z, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
}

double type_bonus()
{
if(!is_player_weapon) return 0;
if(is_melee()) return damage_melee;
double b = 0;
damage_by_type.get(ammo_type, b);
return b;
}
double current_reserve()
{
if(!is_player_weapon) return ammo;
double r = 0;
ammo_reserves.get(ammo_type, r);
return r;
}
void deduct_reserve(double amount)
{
if(!is_player_weapon) { ammo -= amount; return; }
double r = current_reserve();
update_char_ammo_reserve(ammo_type, r - amount);
}

void check_reload(int x, int y, int z=0)
{
if(is_reloading && reload_timer.elapsed >= reload_duration)
{
loaded_ammo += pending_ammo;
deduct_reserve(pending_ammo);
pending_ammo = 0;
is_reloading = false;
sound_slot = p.play_extended_3d(get_pack_sound("main/equipments/weapons/"+cad+"/"+sub+"/general/*ping*"), me.x, me.y, me.z, x, y, z, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
}
}

bool start_reload(int x, int y, int z=0)
{
if(is_reloading) return false;
double reserve = current_reserve();
if(reserve <= 0)
{
sound_slot = p.play_extended_3d(get_pack_sound("main/equipments/weapons/"+cad+"/"+sub+"/general/*empty*"), me.x, me.y, me.z, x, y, z, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
return false;
}
double am;
if(reserve < max_ammo) am = reserve;
else
{
am = max_ammo;
if(loaded_ammo < max_ammo && loaded_ammo > 0)
am = max_ammo - loaded_ammo;
}
sound_slot = p.play_extended_3d(get_pack_sound("main/equipments/weapons/"+cad+"/"+sub+"/general/*reload*"), me.x, me.y, me.z, x, y, z, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
reload_duration = p.get_sound_length(sound_slot);
is_reloading = true;
reload_timer.restart();
pending_ammo = am;
return true;
}

void fire(int x, int y, string facing, int extra_damage, int firer_npc = -1, int z = 0)
{
if(loaded_ammo == 0 && !is_melee())
{
sound_slot = p.play_extended_3d(get_pack_sound("main/equipments/weapons/"+cad+"/"+sub+"/general/*empty*"), me.x, me.y, me.z, x, y, z, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
return;
}
if(is_player_weapon && stamina_drain > 0)
{
stamina -= stamina_drain;
if(stamina < 0) stamina = 0;
}
if(health_drain > 0)
{
if(firer_npc == -1)
{
health -= health_drain;
if(health < 0) health = 0;
}
else if(firer_npc >= 0 && uint(firer_npc) < npcs.length())
{
npcs[firer_npc].health -= health_drain;
if(npcs[firer_npc].health < 0) npcs[firer_npc].health = 0;
}
}
if(life_drain > 0)
{
if(firer_npc == -1)
{
for(int k = 0; k < life_drain; k++)
{
if(lifecard >= 2)
{
p.play_stationary(get_pack_sound("main/characters/"+chartype+"/general/*life*"), false);
lifecard -= 1;
health = maxhealth;
bonehealth = 0;
broken_bones.delete_all();
}
else
{
if(lifecard > 0) lifecard -= 1;
health = 0;
break;
}
}
}
else if(firer_npc >= 0 && uint(firer_npc) < npcs.length())
{
for(int k = 0; k < life_drain; k++)
{
if(npcs[firer_npc].currentlives >= 2)
{
npcs[firer_npc].currentlives -= 1;
npcs[firer_npc].health = npcs[firer_npc].maxhealth;
}
else
{
if(npcs[firer_npc].currentlives > 0) npcs[firer_npc].currentlives -= 1;
npcs[firer_npc].health = 0;
break;
}
}
}
}
bool player_reflecting = (wepchar.reflection && wepdef == 1);
if(!(firer_npc != -1 && ((shieldon == 1 && !shieldpassthrough) || player_reflecting)))
sound_slot = p.play_extended_3d(get_pack_sound("main/equipments/weapons/"+cad+"/"+sub+"/general/*fire*"), me.x, me.y, me.z, x, y, z, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
int dmg = damage + extra_damage + int(type_bonus());
if(is_melee())
{
melee_strike(x, y, z, dmg, firer_npc, facing);
}
else if(launch_type == "projectile" && launch_subtype != "")
{
int pmnx = x, pmxx = x, pmny = y, pmxy = y, pmnz = z, pmxz = z;
int pdir = 0;
if(facing == "right") { pmxx = x + range; pdir = 0; }
else if(facing == "left") { pmnx = x - range; pdir = 4; }
else if(facing == "forward") { pmxy = y + range2; pdir = 1; }
else if(facing == "backward") { pmny = y - range2; pdir = 5; }
else if(facing == "up")
{
if(mapmode == "3d") { pmxz = z + range3; pdir = 8; }
else { pmxy = y + range2; pdir = 1; }
}
else if(facing == "down")
{
if(mapmode == "3d") { pmnz = z - range3; pdir = 9; }
else { pmny = y - range2; pdir = 5; }
}
spawn_projectile(x, y, pmnx, pmxx, pmny, pmxy, pdir, 1, dmg, speed, launch_subtype, false, false, true, true, stun, z, pmnz, pmxz);
}
else if(launch_type == "bomb" && launch_subtype != "")
{
int bx = x, by = y, bz = z;
if(facing == "right") bx = x + range;
else if(facing == "left") bx = x - range;
else if(facing == "forward") by = y + range2;
else if(facing == "backward") by = y - range2;
else if(facing == "up")
{
if(mapmode == "3d") bz = z + range3;
else by = y + range2;
}
else if(facing == "down")
{
if(mapmode == "3d") bz = z - range3;
else by = y - range2;
}
spawn_bomb(bx, by, dmg, speed, launch_subtype, bz);
}
else
{
bool cloner = (sub.length() >= 5 && sub.substr(0, 5) == "clone");
spawn_bullet(x, y, range, range2, dmg, speed, facing, cad, sub, stun, firer_npc, z, range3, scadder_radius, scadder_count, push_x, push_y, push_z, cloner);
}
if(!is_melee()) loaded_ammo -= 1;
}

void melee_strike(int fx, int fy, int fz, int dmg, int firer_npc, string facing)
{
if(firer_npc != -1)
{
bool player_in_range = npc_targets(npcs[firer_npc], "player")
&& absolute(int(me.x) - fx) <= range
&& absolute(int(me.y) - fy) <= range2
&& (mapmode != "3d" or absolute(int(me.z) - fz) <= range3)
&& inplain == false and invehicle == false and onbike == false and !glider_engine_on;
if(player_in_range)
{
if(wepchar.reflection and wepdef == 1)
{
int roll = random(0, 100);
if(roll < wepchar.refchance)
{
wepchar.sound_slot = p.play_stationary_extended(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*block*"), false, 0, 0, 0, 100, false);
return;
}
if(shieldon == 1 and shield_blocks())
{
int sdm = max(1, (wepchar.refcushion ? int(dmg * 0.5) : dmg) - shielddefence * 3);
shieldstrength -= sdm;
kombatlog.insert_last(sub + "'s attack took " + shieldtype + " " + sdm + " damage.");
shieldslot = p.play_stationary_extended(get_pack_sound("main/equipments/shields/"+shieldtype+"/general/*hit*"), false, 0, 0, 0, 100, false);
try_shield_launch(fx, fy, fz, dmg);
return;
}
p.play_stationary(get_pack_sound("main/equipments/weapons/"+cad+"/"+sub+"/general/*hit*"), false);
p.play_stationary(get_pack_sound("main/equipments/weapons/"+cad+"/"+sub+"/general/*shell*"), false);
int hit_dmg = max(1, (wepchar.refcushion ? int(dmg * 0.5) : dmg) - defence * 3);
int tx = int(me.x), ty = int(me.y), tz = int(me.z);
int impact = apply_push(tx, ty, tz, int(npcs[firer_npc].x), int(npcs[firer_npc].y), int(npcs[firer_npc].z), push_x, push_y, push_z, mapmode == "3d", facing);
me.x = tx; me.y = ty; me.z = tz;
health -= hit_dmg + impact;
kombatlog.insert_last(sub + "'s attack took you " + hit_dmg + " damage.");
if(impact > 0) kombatlog.insert_last("You were slammed into a wall for " + impact + " damage.");
play_player_pain(hit_dmg + impact);
if(stun > 0) stun_target("me", "", stun);
return;
}
if(shieldon == 1 and shield_blocks())
{
int sdm = max(1, (shieldcushion ? int(dmg * 0.5) : dmg) - shielddefence * 3);
shieldstrength -= sdm;
kombatlog.insert_last(sub + "'s attack took " + shieldtype + " " + sdm + " damage.");
shieldslot = p.play_stationary_extended(get_pack_sound("main/equipments/shields/"+shieldtype+"/general/*hit*"), false, 0, 0, 0, 100, false);
try_shield_launch(fx, fy, fz, dmg);
return;
}
p.play_stationary(get_pack_sound("main/equipments/weapons/"+cad+"/"+sub+"/general/*hit*"), false);
p.play_stationary(get_pack_sound("main/equipments/weapons/"+cad+"/"+sub+"/general/*shell*"), false);
int hit_dmg = max(1, dmg - defence * 3);
int tx = int(me.x), ty = int(me.y), tz = int(me.z);
int impact = apply_push(tx, ty, tz, int(npcs[firer_npc].x), int(npcs[firer_npc].y), int(npcs[firer_npc].z), push_x, push_y, push_z, mapmode == "3d", facing);
me.x = tx; me.y = ty; me.z = tz;
health -= hit_dmg + impact;
kombatlog.insert_last(sub + "'s attack took you " + hit_dmg + " damage.");
if(impact > 0) kombatlog.insert_last("You were slammed into a wall for " + impact + " damage.");
play_player_pain(hit_dmg + impact);
if(stun > 0) stun_target("me", "", stun);
return;
}
bool npc_is_3d = (mapmode == "3d");
int best_npc_idx = -1;
int best_npc_dist = -1;
for(uint j = 0; j < npcs.length(); j++)
{
if(@npcs[j] == null) continue;
if(int(j) == firer_npc) continue;
if(npcs[j].targets.length() == 0) continue;
if(!npc_targets(npcs[firer_npc], npcs[j].category)) continue;
if(!target_in_facing(npcs[j].x, npcs[j].x, npcs[j].y, npcs[j].y, npcs[j].z, npcs[j].z, fx, fy, fz, facing, npc_is_3d)) continue;
int dx = absolute(int(npcs[j].x) - fx);
int dy = absolute(int(npcs[j].y) - fy);
int dz = absolute(int(npcs[j].z) - fz);
if(dx > range or dy > range2) continue;
if(npc_is_3d and dz > range3) continue;
int d = dx + dy + (npc_is_3d ? dz : 0);
if(best_npc_dist < 0 or d < best_npc_dist) { best_npc_idx = int(j); best_npc_dist = d; }
}
if(best_npc_idx < 0) return;
uint nj = uint(best_npc_idx);
sound_pool@ npool = npc_pool(npcs[nj].category);
npool.play_extended_3d(get_pack_sound("main/equipments/weapons/"+cad+"/"+sub+"/general/*hit*"), me.x, me.y, me.z, npcs[nj].x, npcs[nj].y, npcs[nj].z, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
int n_hit_dmg = max(1, dmg - npcs[nj].defence * 3);
int n_impact = apply_push(npcs[nj].x, npcs[nj].y, npcs[nj].z, int(npcs[firer_npc].x), int(npcs[firer_npc].y), int(npcs[firer_npc].z), push_x, push_y, push_z, npc_is_3d, facing);
npcs[nj].health -= n_hit_dmg + n_impact;
kombatlog.insert_last(npcs[firer_npc].subtype + " attacked " + npcs[nj].subtype + " for " + n_hit_dmg + " damage.");
if(n_impact > 0) kombatlog.insert_last(npcs[nj].subtype + " was slammed into a wall for " + n_impact + " damage.");
if((n_hit_dmg + n_impact) > 0 and npcs[nj].health > 0)
{
npool.destroy_sound(npcs[nj].hurtsound);
npool.pause_sound(npcs[nj].mainsound);
npcs[nj].hurtsound = npool.play_extended_3d(get_map_sound("builder/kombat/npc/"+npcs[nj].category+"/"+npcs[nj].subtype+"/general/*hurt*"), me.x, me.y, me.z, npcs[nj].x, npcs[nj].y, npcs[nj].z, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
npcs[nj].hurtdelay = round(npool.get_sound_length(npcs[nj].hurtsound), 0);
npcs[nj].hurttimer.restart();
npcs[nj].hurting = true;
}
return;
}
bool is_3d = (mapmode == "3d");
if(scadder_radius > 0)
{
melee_strike_all(fx, fy, fz, dmg, facing, is_3d, scadder_radius, scadder_count);
return;
}
int best_type = 0;
int best_idx = -1;
int best_dist = -1;
for(uint j = 0; j < npcs.length(); j++)
{
if(@npcs[j] == null) continue;
if(npcs[j].targets.length() == 0) continue;
if(!target_in_facing(npcs[j].x, npcs[j].x, npcs[j].y, npcs[j].y, npcs[j].z, npcs[j].z, fx, fy, fz, facing, is_3d)) continue;
int dx = absolute(int(npcs[j].x) - fx);
int dy = absolute(int(npcs[j].y) - fy);
int dz = absolute(int(npcs[j].z) - fz);
if(dx > range or dy > range2) continue;
if(is_3d and dz > range3) continue;
int d = dx + dy + (is_3d ? dz : 0);
if(best_dist < 0 or d < best_dist) { best_type = 1; best_idx = int(j); best_dist = d; }
}
for(uint jt = 0; jt < ttsenemies.length(); jt++)
{
if(@ttsenemies[jt] == null) continue;
if(!target_in_facing(ttsenemies[jt].ttsemx, ttsenemies[jt].ttsemx, ttsenemies[jt].ttsemy, ttsenemies[jt].ttsemy, ttsenemies[jt].ttsemz, ttsenemies[jt].ttsemz, fx, fy, fz, facing, is_3d)) continue;
