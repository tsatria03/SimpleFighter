if(!signs[i].destroyable) continue;
if(!target_in_facing(signs[i].signx, signs[i].signx, signs[i].signy, signs[i].signy, signs[i].signz, signs[i].signz, fx, fy, fz, facing, is_3d)) continue;
int dx = absolute(int(signs[i].signx) - fx);
int dy = absolute(int(signs[i].signy) - fy);
int dz = absolute(int(signs[i].signz) - fz);
if(dx > range or dy > range2) continue;
if(is_3d and dz > range3) continue;
if(dx > sr or dy > sr) continue;
if(is_3d and dz > sr) continue;
