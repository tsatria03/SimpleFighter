void character_chooser()
{
	bool do_build = true;
	int b_add, b_edit, b_remove, b_view, b_back;
	while(true)
	{
		wait(5);
		if(do_build)
		{
			do_build = false;
			form.reset();
			form.create_window("character", false, true, false);
			b_add = form.create_button("&add character");
			b_edit = form.create_button("&edit character");
			b_remove = form.create_button("&remove character");
			b_view = form.create_button("&view character");
			b_back = form.create_button("&back", false, true);
			form.focus(b_add);
		}
		form.monitor();
		if(key_pressed(KEY_ESCAPE) || form.is_pressed(b_back))
		{
			return;
		}
		if(form.is_pressed(b_add)) { add_character(); do_build = true; continue; }
		if(form.is_pressed(b_edit)) { edit_character(); do_build = true; continue; }
		if(form.is_pressed(b_remove)) { remove_character(); do_build = true; continue; }
		if(form.is_pressed(b_view)) { view_character(); do_build = true; continue; }
	}
}

string[] character_main_keys()
{
	string[] keys = {"break verbs", "body verbs", "attack", "defence", "points", "fall modifier", "health", "stamina", "kills", "lives", "level", "level modifier", "experience", "experience modifier", "experience required"};
	return keys;
}

string[] character_kombat_keys()
{
	string[] keys = {"damage_normal", "damage_gas", "damage_air", "damage_battery", "damage_powder", "damage_arrow", "damage_rocket", "damage_water", "damage_knife", "damage_needle", "damage_dart", "damage_ball", "damage_mana", "damage_fuel", "damage_rock", "damage_grenade", "damage_melee", "reserve_normal", "reserve_gas", "reserve_air", "reserve_battery", "reserve_powder", "reserve_arrow", "reserve_rocket", "reserve_water", "reserve_knife", "reserve_needle", "reserve_dart", "reserve_ball", "reserve_mana", "reserve_fuel", "reserve_rock", "reserve_grenade"};
	return keys;
}

dictionary read_character_keyvalue_file(string target_path)
{
	dictionary existing;
	file fin;
	if(fin.open(target_path, "rb"))
	{
		string content = fin.read();
		fin.close();
		string[] lines = split_lines(content);
		for(uint i=0; i<lines.length(); i++)
		{
			int eq = string_contains(lines[i], "=", 1);
			if(eq < 0) continue;
			string k = string_left(lines[i], eq);
			string v = string_mid(lines[i], eq+2, lines[i].length()-eq-1);
			existing[k] = v;
		}
	}
	return existing;
}

bool character_main_form(string subtype, bool is_edit)
{
	string target_path = "sounds/decompiled/main/characters/"+subtype+"/data/main.sif";
	string[] keys = character_main_keys();
	dictionary existing;
	if(is_edit) existing = read_character_keyvalue_file(target_path);
	form.reset();
	form.create_window((is_edit ? "edit " : "add ")+subtype+" main", false, true, false);
	int[] inputs;
	for(uint i=0; i<keys.length(); i++)
	{
		string preset = "";
		if(existing.exists(keys[i])) existing.get(keys[i], preset);
		inputs.insert_last(form.create_input_box(keys[i], preset));
	}
	string[] wt_opts;
	string[] wt2_opts;
	build_npc_weapon_lists(wt_opts, wt2_opts);
	int wt_list = form.create_list("weapon type");
	int wt2_list = form.create_list("weapon type2");
	for(uint i=0; i<wt_opts.length(); i++) form.add_list_item(wt_list, wt_opts[i], wt_opts[i]);
	for(uint i=0; i<wt2_opts.length(); i++) form.add_list_item(wt2_list, wt2_opts[i], wt2_opts[i]);
	string wt_pre = "none"; if(existing.exists("weapon type")) existing.get("weapon type", wt_pre);
	string wt2_pre = "none"; if(existing.exists("weapon type2")) existing.get("weapon type2", wt2_pre);
	int wt_idx = 0, wt2_idx = 0;
	for(uint i=0; i<wt_opts.length(); i++) if(wt_opts[i] == wt_pre) wt_idx = i;
	for(uint i=0; i<wt2_opts.length(); i++) if(wt2_opts[i] == wt2_pre) wt2_idx = i;
	form.set_list_position(wt_list, wt_idx, false);
	form.set_list_position(wt2_list, wt2_idx, false);
	string[] shield_opts;
	shield_opts.insert_last("none");
	string[] discovered_shields = get_pack_sound_folders("main/equipments/shields/*");
	discovered_shields.sort_ascending();
	for(uint i=0; i<discovered_shields.length(); i++) shield_opts.insert_last(discovered_shields[i]);
	shield_opts.insert_last("random");
	int shield_list = form.create_list("shield type");
	for(uint i=0; i<shield_opts.length(); i++) form.add_list_item(shield_list, shield_opts[i], shield_opts[i]);
	string shield_pre = "none"; if(existing.exists("shield type")) existing.get("shield type", shield_pre);
	int shield_idx = 0;
	for(uint i=0; i<shield_opts.length(); i++) if(shield_opts[i] == shield_pre) shield_idx = i;
	form.set_list_position(shield_list, shield_idx, false);
	int b_save = form.create_button("&save", true);
	int b_cancel = form.create_button("&cancel", false, true);
	form.focus(inputs[0]);
	while(true)
	{
		wait(5);
		form.monitor();
		if(key_pressed(KEY_ESCAPE) || form.is_pressed(b_cancel))
		{
			speak("canceled");
			return false;
		}
		if(form.is_pressed(b_save))
		{
			bool blank = false;
			for(uint i=0; i<inputs.length(); i++)
			{
				if(form.get_text(inputs[i]) == "")
				{
					speak(keys[i]+" is required.");
					form.focus(inputs[i]);
					blank = true;
					break;
				}
			}
			if(blank) continue;
			if(!is_edit && file_exists(target_path))
			{
				setupmenu();
				m.add_item("yes");
				m.add_item("no");
				m.intro_text = "A main.sif already exists for this character. Overwrite?";
				int mres = m.run();
				if(mres != 0) continue;
			}
			string content = "";
			for(uint i=0; i<inputs.length(); i++)
				content += keys[i]+"="+form.get_text(inputs[i])+"\r\n";
			content += "weapon type="+wt_opts[form.get_list_position(wt_list)]+"\r\n";
			content += "weapon type2="+wt2_opts[form.get_list_position(wt2_list)]+"\r\n";
			content += "shield type="+shield_opts[form.get_list_position(shield_list)]+"\r\n";
			create_subfolders(target_path);
			file fout;
			if(!fout.open(target_path, "w"))
			{
				speak("Failed to open file for writing.");
				continue;
			}
			fout.write(content);
			fout.close();
			speak("Saved.");
			return true;
		}
	}
	return false;
}

