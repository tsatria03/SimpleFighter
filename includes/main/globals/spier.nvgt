if(mapmode == "3d") dims += " x " + (signs[j].maxz - signs[j].minz + 1);
labels.insert_last(dims + " tile sign");
}
else
labels.insert_last("sign");
}
}
for (uint j = 0; j < spikes.length(); j++)
