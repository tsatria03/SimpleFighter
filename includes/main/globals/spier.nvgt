if(mapmode == "3d" && (sz < switchers[j].minz || sz > switchers[j].maxz)) continue;
double closest_x = me.x < switchers[j].minx ? switchers[j].minx : (me.x > switchers[j].maxx ? switchers[j].maxx : me.x);
double closest_y = me.y < switchers[j].miny ? switchers[j].miny : (me.y > switchers[j].maxy ? switchers[j].maxy : me.y);
string base = switchers[j].contact_trigger ? "sensor" : "switch";
if (sx == closest_x && sy == closest_y && !is_obscured(base, "spier"))
{
bool is_ranged = switchers[j].minx != switchers[j].maxx || switchers[j].miny != switchers[j].maxy || (mapmode == "3d" && switchers[j].minz != switchers[j].maxz);
if(is_ranged)
{
int w = switchers[j].maxx - switchers[j].minx + 1;
int h = switchers[j].maxy - switchers[j].miny + 1;
string dims = w + " x " + h;
if(mapmode == "3d") dims += " x " + (switchers[j].maxz - switchers[j].minz + 1);
labels.insert_last(dims + " tile " + base);
}
else
labels.insert_last(base);
}
}
for (uint j = 0; j < fires.length(); j++)
{
