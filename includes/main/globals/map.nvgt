void gop(string entity,string id,double x,double y,double z=0)
{
if(x<minx or x>maxx or y<miny or y>maxy)
{
speak("You can't move yourself or an entity out of map boundries.");
return;
}
if(mapmode == "3d" and (z<minz or z>maxz))
{
speak("You can't move yourself or an entity out of map boundries.");
return;
}
if (entity == "me")
{
me.x=x;
me.y=y;
me.z=z;
fallcounter=0;
jumping=0;
falling=false;
if(fallcounter>=0) p.destroy_sound(fallslot);
mpool.play_stationary(get_pack_sound("main/characters/"+chartype+"/map/*move*"),false);
if(mapmode == "3d") speak("Player moved to "+me.x+", "+me.y+", "+me.z+".");
else speak("Player moved to "+me.x+", "+me.y+".");
}
else if(entity=="animal" || entity=="boss" || entity=="helper" || entity=="human" || entity=="robot" || entity=="special" || entity=="zombie")
{
string target_cat = (entity == "boss") ? "bosses" : (entity + "s");
for(uint i=0; i<npcs.length(); i++)
{
if(npcs[i].category == target_cat && npcs[i].subtype == id)
{
npcs[i].x = int(x);
npcs[i].y = int(y);
if(mapmode == "3d") npcs[i].z = int(z);
sound_pool@ pool = npc_pool(npcs[i].category);
pool.update_sound_3d(npcs[i].mainsound, npcs[i].x, npcs[i].y, npcs[i].z);
npcs[i].movetimer.restart();
mpool.play_stationary(get_pack_sound("main/characters/"+chartype+"/map/*move*"),false);
if(mapmode == "3d") speak(entity+" moved to "+npcs[i].x+", "+npcs[i].y+", "+npcs[i].z+".");
else speak(entity+" moved to "+npcs[i].x+", "+npcs[i].y+".");
return;
}
}
}
else
{
speak("Unknown entity type "+id+".");
return;
}
}

void create_map(string name, string owner, string mode, double mx, double mx2, double my, double my2, double mz=0, double mz2=0, string description="")
{
mapname=name;
mapowner=owner;
mapmode=mode;
minx=mx;
maxx=mx2;
miny=my;
maxy=my2;
minz=mz;
maxz=mz2;

string base = "data/builder/maps/decompiled/" + mapname;
string[] mapdirs ={"/data", "/assets", "/assets/builder", "/assets/builder/audio", "/assets/builder/audio/musics", "/assets/builder/audio/sources", "/assets/builder/construction", "/assets/builder/construction/belts", "/assets/builder/construction/moving platforms", "/assets/builder/construction/platforms", "/assets/builder/construction/vanishing platforms", "/assets/builder/construction/walls", "/assets/builder/interaction", "/assets/builder/interaction/calendars", "/assets/builder/interaction/clocks", "/assets/builder/interaction/dialogs", "/assets/builder/interaction/items", "/assets/builder/interaction/items/health", "/assets/builder/interaction/items/other", "/assets/builder/interaction/items/stamina", "/assets/builder/interaction/signs", "/assets/builder/interaction/switches", "/assets/builder/kombat", "/assets/builder/kombat/npc", "/assets/builder/kombat/npc/animals", "/assets/builder/kombat/npc/bosses", "/assets/builder/kombat/npc/helpers", "/assets/builder/kombat/npc/humans", "/assets/builder/kombat/npc/robots", "/assets/builder/kombat/npc/specials", "/assets/builder/kombat/npc/zombies", "/assets/builder/kombat/projectiles", "/assets/builder/misc", "/assets/builder/misc/checkpoints", "/assets/builder/transitions", "/assets/builder/transitions/doors", "/assets/builder/transitions/doors/close", "/assets/builder/transitions/doors/dest", "/assets/builder/transitions/doors/loop", "/assets/builder/transitions/doors/move", "/assets/builder/transitions/doors/open", "/assets/builder/transitions/elevators", "/assets/builder/transitions/elevators/beep", "/assets/builder/transitions/elevators/close", "/assets/builder/transitions/elevators/loop", "/assets/builder/transitions/elevators/move", "/assets/builder/transitions/elevators/open", "/assets/builder/transitions/lifts", "/assets/builder/transitions/teleporters", "/assets/builder/transportation", "/assets/builder/transportation/aircrafts", "/assets/builder/transportation/bikes", "/assets/builder/transportation/vehicles", "/assets/builder/traps", "/assets/builder/traps/bombs", "/assets/builder/traps/fires", "/assets/builder/traps/floor breakers", "/assets/builder/traps/force fields", "/assets/builder/traps/hazards", "/assets/builder/traps/mines", "/assets/builder/traps/security cameras", "/assets/builder/traps/spikes", "/assets/builder/traps/time bombs", "/assets/builder/zones", "/assets/builder/zones/heal zones", "/assets/builder/zones/safe zones"};
for (uint i = 0; i < mapdirs.length(); i++)
{
	string fullpath = base + mapdirs[i];
	if (!directory_exists(fullpath))
		directory_create(fullpath);
}

mapper.open("data/builder/maps/decompiled/"+mapname+"/"+"data/main.sif","wb");
mapdata=mapper.read();
string header = "mode "+mode+"\r\n"+"minx "+mx+"\r\n"+"maxx "+mx2+"\r\n"+"miny "+my+"\r\n"+"maxy "+my2;
if(mode == "3d") header += "\r\nminz "+mz+"\r\nmaxz "+mz2;
mapper.write(header);
mapper.close();
bump_map_modified();
string ts = utc_iso8601_now();
file mf;
if (mf.open("data/builder/maps/decompiled/"+mapname+"/data/meta.sif", "wb"))
{
	mf.write("owner="+owner+"\r\ndescription="+quote_value(description)+"\r\ncreated date="+ts+"\r\nmodified date="+ts+"\r\n");
	mf.close();
}
me.x=0;
me.y=0;
me.z=0;
dlg("The map template has been created successfully. Press enter to continue.");
}

void cam_left()
{
if(cam.x-1>=minx and camtimer.elapsed>=camtime and cammable==true)
{
camdir="left";
cam.x-=1;
playcam();
camtimer.restart();
}
}
void cam_right()
{
if(cam.x+1<=maxx and camtimer.elapsed>=camtime and cammable==true)
{
camdir="right";
cam.x+=1;
playcam();
camtimer.restart();
}
}
void cam_backward()
{
if(cam.y-1>=miny and camtimer.elapsed>=camtime and cammable==true)
{
camdir="backward";
cam.y-=1;
playcam();
camtimer.restart();
}
}
void cam_forward()
{
if(cam.y+1<=maxy and camtimer.elapsed>=camtime and cammable==true)
{
camdir="forward";
cam.y+=1;
playcam();
camtimer.restart();
}
}
void cam_down()
{
if(cam.z-1>=minz and camtimer.elapsed>=camtime and cammable==true)
{
camdir="down";
cam.z-=1;
playcam();
camtimer.restart();
}
}
void cam_up()
{
if(cam.z+1<=maxz and camtimer.elapsed>=camtime and cammable==true)
{
camdir="up";
cam.z+=1;
playcam();
camtimer.restart();
}
}

