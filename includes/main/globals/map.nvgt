}

void cbounce()
{
if(camdir=="right")
cam.x--;
else if(camdir=="left")
cam.x++;
else if(camdir=="forward")
cam.y--;
else if(camdir=="backward")
cam.y++;
else if(camdir=="up")
{
if(mapmode == "2d") cam.y--;
else cam.z--;
}
else if(camdir=="down")
{
if(mapmode == "2d") cam.y++;
else cam.z++;
}
}
void pbounce(int steps = 1)
{
if (facing == "right")
me.x -= steps;
else if (facing == "left")
me.x += steps;
else if (facing == "forward")
me.y -= steps;
else if (facing == "backward")
me.y += steps;
else if (facing == "up")
{
if(mapmode == "2d") me.y -= steps;
else me.z -= steps;
}
else if (facing == "down")
{
if(mapmode == "2d") me.y += steps;
else me.z += steps;
}
}
void key_step_up()
{
if(mapmode == "2d")
{
if(facing=="up"==false and turnmode==1)
{
facing="up";
bonecheck();
if(spokenturns==1) speak(facing);
p.play_3d(get_pack_sound("main/characters/"+chartype+"/general/*turn*"),me.x,me.y+1,me.z,me.x,me.y+1,me.z,calculate_theta(me_rotation),false);
}
else if ((!gmt(me.x,me.y+1).is_empty() || glider_engine_on) && me.y+1 <= maxy)
{
if(turnmode==0) facing="up";
me.y++;
bonecheck();
playstep();
}
}
else body_step(0);
}
void key_step_down()
{
if(mapmode == "2d")
{
if(facing=="down"==false and turnmode==1)
{
facing="down";
bonecheck();
if(spokenturns==1) speak(facing);
p.play_3d(get_pack_sound("main/characters/"+chartype+"/general/*turn*"),me.x,me.y-1,me.z,me.x,me.y-1,me.z,calculate_theta(me_rotation),false);
}
else if ((!gmt(me.x,me.y-1).is_empty() || glider_engine_on) && me.y-1 >= miny)
{
if(turnmode==0) facing="down";
me.y--;
bonecheck();
playstep();
}
}
else body_step(1);
}
void key_strafe_left()
{
if(mapmode == "2d") step_left();
else body_step(2);
}
void key_strafe_right()
{
if(mapmode == "2d") step_right();
else body_step(3);
}
void key_step_pgup()
{
if(mapmode == "3d") step_up();
}
void key_step_pgdown()
{
if(mapmode == "3d") step_down();
}
void key_cam_up()
{
if(mapmode == "2d")
{
if(cam.y+1<=maxy and camtimer.elapsed>=camtime and cammable==true)
{
camdir="up";
cam.y+=1;
playcam();
camtimer.restart();
}
}
else body_cam_step(0);
}
void key_cam_down()
{
if(mapmode == "2d")
{
if(cam.y-1>=miny and camtimer.elapsed>=camtime and cammable==true)
{
camdir="down";
cam.y-=1;
playcam();
camtimer.restart();
}
}
else body_cam_step(1);
}
void key_cam_strafe_left()
{
if(mapmode == "2d") cam_left();
else body_cam_step(2);
}
void key_cam_strafe_right()
{
if(mapmode == "2d") cam_right();
else body_cam_step(3);
}
void key_cam_pgup()
{
if(mapmode == "3d") cam_up();
}
void key_cam_pgdown()
{
if(mapmode == "3d") cam_down();
}
// Maps a body direction to the closest cardinal world direction string for the spire.
// body_dir: 0=forward, 1=backward, 2=strafe_left, 3=strafe_right.
string body_to_spy_dir(int body_dir)
{
int dx, dy;
body_world_delta(body_dir, dx, dy);
int adx = dx < 0 ? -dx : dx;
int ady = dy < 0 ? -dy : dy;
if(ady >= adx) return dy >= 0 ? "forward" : "backward";
return dx >= 0 ? "right" : "left";
}
// Same idea for the sonar, which uses up/down for the y axis instead of forward/backward.
string body_to_sonar_dir(int body_dir)
{
int dx, dy;
body_world_delta(body_dir, dx, dy);
int adx = dx < 0 ? -dx : dx;
int ady = dy < 0 ? -dy : dy;
if(ady >= adx) return dy >= 0 ? "up" : "down";
return dx >= 0 ? "right" : "left";
}
void key_spy_left()
{
if(mapmode == "2d") spy("left");
else spy(body_to_spy_dir(2));
}
void key_spy_right()
{
if(mapmode == "2d") spy("right");
else spy(body_to_spy_dir(3));
}
void key_spy_up()
{
if(mapmode == "2d") spy("forward");
else spy(body_to_spy_dir(0));
}
void key_spy_down()
{
if(mapmode == "2d") spy("backward");
else spy(body_to_spy_dir(1));
}
void key_spy_pgup()
{
if(mapmode == "3d") spy("up");
}
void key_spy_pgdown()
{
if(mapmode == "3d") spy("down");
}
void fallcheck()
{
if(mapmode == "topdown") return;
if(onhook) return;
if(doormove || elvmove || invehicle || inplain) return;
if(glider_engine_on) return;
if(mapmode == "2d")
{
if(jumping == 0 && falling == false && (gmt(me.x, me.y) == "" || gmt(me.x, me.y) == "air") && me.y > miny)
{
falling=true;
int predicted = 0;
int yy = me.y;
while(yy > miny)
{
yy--;
predicted++;
string tt = gmt(me.x, yy);
if(tt != "" && tt != "air") break;
}
if(predicted >= 8 && !onbike)
{
fallslot = p.play_stationary(get_pack_sound("main/characters/"+chartype+"/general/*fall*"), false);
fallslot = p.play_stationary(get_pack_sound("main/characters/"+chartype+"/general/*plummet*"), false);
}
}
}
else if(mapmode == "3d")
{
if(jumping == 0 && falling == false && me.z > minz && !platform_supports(me.x, me.y, me.z))
{
falling = true;
int predicted = 0;
double zz = me.z;
while(zz > minz)
{
zz--;
predicted++;
if(platform_supports(me.x, me.y, zz)) break;
}
if(predicted >= 8 && !onbike)
{
fallslot = p.play_stationary(get_pack_sound("main/characters/"+chartype+"/general/*fall*"), false);
fallslot = p.play_stationary(get_pack_sound("main/characters/"+chartype+"/general/*plummet*"), false);
}
}
}
if(falling)
{
if(mapmode == "3d")
{
if(falltimer.elapsed >= falltime && me.z > minz)
{
falltimer.restart();
me.z -= 1;
fallcounter++;
}
bool landed = false;
if(me.z <= minz) { me.z = minz; landed = true; }
else if(platform_supports(me.x, me.y, me.z)) landed = true;
if(landed)
{
if(fallcounter >= 0) p.destroy_sound(fallslot);
if(fallcounter >= 8 and shieldon == 1) shieldslot = p.play_stationary_extended(get_pack_sound("main/equipments/shields/"+shieldtype+"/general/*hit*"), false, 0, 0, 0, 100);
if(fallcounter < 8)
{
playland();
}
else
{
playfall();
int impact_dmg = max(1, fallcounter * fallmod);
for(uint i = 0; i < walls.length(); i++)
{
if(!walls[i].destroyable) continue;
bool in_wall = (me.x >= walls[i].minx && me.x <= walls[i].maxx && me.y >= walls[i].miny && me.y <= walls[i].maxy && me.z >= walls[i].minz && me.z <= walls[i].maxz);
if(!in_wall) continue;
walls[i].wallhealth -= impact_dmg;
kombatlog.insert_last(impact_dmg + " damage to " + string_replace(walls[i].wall, "wall", "", true) + " wall, falling down.");
if(impact_dmg > 0) walls[i].hurtsound = p.play_stationary_extended(get_map_sound("builder/construction/walls/" + walls[i].wall + "/*hurt*"), false, 0, 0, tilevolume, tilepitch, false);
for(uint k = 0; k < walls[i].platform_ids.length(); k++)
{
int pid = walls[i].platform_ids[k];
if(pid >= 0 && pid < platforms.length())
{
platforms[pid].plathealth = walls[i].wallhealth;
platforms[pid].platmaxhealth = walls[i].wallmaxhealth;
}
}
break;
}
for(uint i = 0; i < platforms.length(); i++)
{
if(!platforms[i].destroyable) continue;
if(platforms[i].is_backing) continue;
bool in_plat = (me.x >= platforms[i].minx && me.x <= platforms[i].maxx && me.y >= platforms[i].miny && me.y <= platforms[i].maxy && platforms[i].z == me.z);
if(!in_plat) continue;
platforms[i].plathealth -= impact_dmg;
kombatlog.insert_last(impact_dmg + " damage to " + platforms[i].tile + " platform, falling down.");
if(impact_dmg > 0) platforms[i].hurtsound = p.play_stationary_extended(get_map_sound("builder/construction/platforms/" + platforms[i].tile + "/*hurt*"), false, 0, 0, tilevolume, tilepitch, false);
break;
}
if(fallcounter >= 8 and onbike)
{
int bdmg = max(1, fallcounter * fallmod);
for(uint i = 0; i < bikes.length(); i++)
{
if(bikes[i].moveable)
{
bikes[i].bikehealth -= bdmg;
kombatlog.insert_last(bdmg + " damage to " + bikes[i].biketype + ", falling down.");
if(bikes[i].bikehealth <= 0)
{
health -= bdmg;
kombatlog.insert_last(bdmg + " damage to player, falling down.");
int ct = clamp((fallcounter - 8) * 10, 0, 100);
int count = clamp((fallcounter - 8) / 2, 1, 5);
break_charbones(ct, bdmg, 10 * fallcounter, count);
}
break;
}
}
}
int sdm = max(1, (fallcounter * fallmod) - (shielddefence * 3));
if(fallcounter >= 8 and shieldon == 1 and !onbike)
{
shieldstrength -= sdm;
kombatlog.insert_last(sdm + " damage to " + shieldtype + ", falling down.");
stun_target("me", "", 10 * fallcounter);
if(shieldstrength <= 0)
{
health -= sdm;
kombatlog.insert_last(sdm + " damage to player, falling down.");
int ct = clamp((fallcounter - 8) * 10, 0, 100);
int count = clamp((fallcounter - 8) / 2, 1, 5);
break_charbones(ct, sdm, 10 * fallcounter, count);
}
}
int dmg = max(1, (fallcounter * fallmod) - (defence * 3));
if(fallcounter >= 8 and shieldon == 0 and !onbike)
{
health -= dmg;
kombatlog.insert_last(dmg + " damage to player, falling down.");
string painfile;
int damage_percent = round((float(dmg) / float(maxhealth)) * 100, 0);
if(damage_percent <= 1) painfile = get_pack_sound("main/characters/" + chartype + "/general/*hurt*");
else if(damage_percent >= 10) painfile = get_pack_sound("main/characters/" + chartype + "/general/*crit*");
else painfile = get_pack_sound("main/characters/" + chartype + "/general/*hurt*");
painslot = p.play_stationary_extended(painfile, false, 0, 0, 0, 100, false);
int ct = clamp((fallcounter - 8) * 10, 0, 100);
int count = clamp((fallcounter - 8) / 2, 1, 5);
break_charbones(ct, dmg, 10 * fallcounter, count);
}
}
falling = false;
fallcounter = 0;
}
return;
}
for(uint i=0; i<healzones.length(); i++)
{
bool currently_in_zone = player_in_healzone(i);
if (currently_in_zone && !healzones[i].in_zone)
{
if(healzones[i].healmode==1) healzones[i].healsound=healpool.play_stationary(get_map_sound("builder/zones/heal zones/"+healzones[i].healtype+"/*heal*"),false);
if(healzones[i].healmode==0) healzones[i].takesound=healpool.play_stationary(get_map_sound("builder/zones/heal zones/"+healzones[i].healtype+"/*take*"),false);
healzones[i].in_zone = true;
}
else if (!currently_in_zone && healzones[i].in_zone)
{
healzones[i].in_zone = false;
}
}
for(uint i=0; i<safezones.length(); i++)
{
bool currently_in_zone = player_in_safezone(i);
if (currently_in_zone && !safezones[i].player_in_zone)
{
safezones[i].safesound=safepool.play_stationary(get_map_sound("builder/zones/safe zones/"+safezones[i].safetype+"/*in*"),false);
safezones[i].player_in_zone = true;
}
else if (!currently_in_zone && safezones[i].player_in_zone)
{
safezones[i].safesound=safepool.play_stationary(get_map_sound("builder/zones/safe zones/"+safezones[i].safetype+"/*out*"),false);
safezones[i].player_in_zone = false;
}
}
if(falltimer.elapsed>=falltime and me.y>miny)
{
falltimer.restart();
me.y--;
fallcounter++;
}
if(gmt(me.x, me.y)!="" && gmt(me.x, me.y)!="air")
{
if(fallcounter>=0) p.destroy_sound(fallslot);
if(fallcounter>=8 and shieldon==1) shieldslot=p.play_stationary_extended(get_pack_sound("main/equipments/shields/"+shieldtype+"/general/*hit*"),false,0,0,0,100);
if(fallcounter<8)
{
playland();
}
else if(fallcounter>7)
{
playfall();
if (fallcounter >= 8)
{
int impact_dmg = max(1, (fallcounter * fallmod));
	for (uint i = 0; i < walls.length(); i++)
	{
		if (!walls[i].destroyable) continue;
		bool in_wall =(me.x >= walls[i].minx && me.x <= walls[i].maxx && me.y >= walls[i].miny && me.y <= walls[i].maxy);
		if (!in_wall) continue;
		walls[i].wallhealth -= impact_dmg;
kombatlog.insert_last(impact_dmg+ " damage to "+string_replace(walls[i].wall, "wall", "", true)+" wall, falling down.");
if(impact_dmg>0) walls[i].hurtsound=p.play_stationary_extended(get_map_sound("builder/construction/walls/"+walls[i].wall+"/*hurt*"),false,0,0,tilevolume,tilepitch,false);
		for(uint k=0; k<walls[i].platform_ids.length(); k++)
		{
			int pid = walls[i].platform_ids[k];
			if (pid >= 0 && pid < platforms.length())
			{
				platforms[pid].plathealth = walls[i].wallhealth;
				platforms[pid].platmaxhealth = walls[i].wallmaxhealth;
			}
		}
		break;
	}
for (uint i = 0; i < staircases.length(); i++)
{
	if (!staircases[i].destroyable) continue;
	bool in_stairs =(me.x >= staircases[i].minx && me.x <= staircases[i].maxx && me.y >= staircases[i].miny && me.y <= staircases[i].maxy);
	if(mapmode == "3d") in_stairs = in_stairs && me.z >= staircases[i].minz && me.z <= staircases[i].maxz;
	if (!in_stairs) continue;
	staircases[i].stairshealth -= impact_dmg;
kombatlog.insert_last(impact_dmg+ " damage to "+staircases[i].tile+" staircase, falling down.");
	if (impact_dmg > 0) staircases[i].hurtsound =p.play_stationary_extended(get_map_sound("builder/construction/platforms/" + staircases[i].tile + "/*hurt*"), false, 0, 0, tilevolume, tilepitch, false);
	for(uint k=0; k<staircases[i].platform_ids.length(); k++)
	{
		int pid = staircases[i].platform_ids[k];
		if (pid >= 0 && pid < platforms.length())
		{
			platforms[pid].plathealth = staircases[i].stairshealth;
			platforms[pid].platmaxhealth = staircases[i].stairsmaxhealth;
		}
	}
	break;
}
	for (uint i = 0; i < platforms.length(); i++)
	{
		if (!platforms[i].destroyable) continue;
		bool in_plat =(me.x >= platforms[i].minx && me.x <= platforms[i].maxx && me.y >= platforms[i].miny && me.y <= platforms[i].maxy);
		if (!in_plat) continue;
		platforms[i].plathealth -= impact_dmg;
kombatlog.insert_last(impact_dmg+ " damage to "+platforms[i].tile+" platform, falling down.");
if(impact_dmg>0) platforms[i].hurtsound=p.play_stationary_extended(get_map_sound("builder/construction/platforms/"+platforms[i].tile+"/*hurt*"),false,0,0,tilevolume,tilepitch,false);
		break;
	}
}
if(fallcounter>=8 and onbike)
{
int bdmg = max(1, fallcounter * fallmod);
for(uint i=0; i<bikes.length(); i++)
{
if(bikes[i].moveable)
{
bikes[i].bikehealth -= bdmg;
kombatlog.insert_last(bdmg+ " damage to "+bikes[i].biketype+", falling down.");
if(bikes[i].bikehealth <= 0)
{
health -= bdmg;
kombatlog.insert_last(bdmg+ " damage to player, falling down.");
int ct = clamp((fallcounter - 8) * 10, 0, 100);
int count = clamp((fallcounter - 8) / 2, 1, 5);
break_charbones(ct, bdmg, 10 * fallcounter, count);
}
break;
}
}
}
int sdm = max(1, (fallcounter * fallmod) - (shielddefence * 3));
if(fallcounter>=8 and shieldon==1 and !onbike)
{
shieldstrength-=sdm;
kombatlog.insert_last(sdm+ " damage to "+shieldtype+", falling down.");
stun_target("me", "", 10 * fallcounter);
if(shieldstrength<=0)
{
health -= sdm;
kombatlog.insert_last(sdm+ " damage to player, falling down.");
int ct = clamp((fallcounter - 8) * 10, 0, 100);
int count = clamp((fallcounter - 8) / 2, 1, 5);
break_charbones(ct, sdm, 10 * fallcounter, count);
}
}
int dmg = max(1, (fallcounter * fallmod) - (defence * 3));
if(fallcounter>=8 and shieldon==0 and !onbike)
{
health -= dmg;
kombatlog.insert_last(dmg+ " damage to player, falling down.");
if (fallcounter>=8 and shieldon==0)
{
string painfile;
int damage_percent = round((float(dmg) / float(maxhealth)) * 100, 0);
if (damage_percent <= 1)
{
painfile = get_pack_sound("main/characters/" + chartype+"/general/*hurt*");
}
else if (damage_percent >= 10)
{
painfile = get_pack_sound("main/characters/" + chartype+"/general/*crit*");
}
else
{
painfile = get_pack_sound("main/characters/" + chartype+"/general/*hurt*");
}
painslot = p.play_stationary_extended(painfile, false, 0, 0, 0, 100, false);
}
int ct = clamp((fallcounter - 8) * 10, 0, 100);
int count = clamp((fallcounter - 8) / 2, 1, 5);
break_charbones(ct, dmg, 10 * fallcounter, count);
}
}
falling=false;
fallcounter=0;
for(uint i=0; i<checkpoints.length(); i++)
{
bool fall_cp_match = me.x==checkpoints[i].checkx and me.y==checkpoints[i].checky;
if(mapmode == "3d") fall_cp_match = fall_cp_match and me.z==checkpoints[i].checkz;
if(fall_cp_match)
{
checkpoints[i].getsound=checkpool.play_stationary_extended(get_map_sound("builder/misc/checkpoints/"+checkpoints[i].checktype+"/*get*"),false,0,0,0,100,false);
@last_checkpoint=checkpoints[i];
checkpoints.remove_at(i);
return;
}
}
}
}
}
