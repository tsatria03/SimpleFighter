safezones[i].player_in_zone = false;
}
}
{
string wname = (mapmode == "3d") ? gmt(me.x, me.y, me.z) : gmt(me.x, me.y);
if(string_contains(wname,"wall",1)>-1)
{
wallslot=p.play_extended_3d(get_map_sound("builder/construction/walls/"+wname+"/*bump*"),me.x,me.y,me.z,me.x,me.y,me.z,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,wallvolume,wallpitch);
