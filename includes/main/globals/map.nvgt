void clear_camera_markers(bool feedback=true)
{
	if (!sel_left_set && !sel_right_set && !sel_back_set && !sel_front_set && !sel_bottom_set && !sel_top_set)
	{
		if(feedback) speak("No selection points to clear.");
		return;
	}
	sel_left_set = false;
	sel_right_set = false;
	sel_back_set = false;
	sel_front_set = false;
	sel_bottom_set = false;
	sel_top_set = false;
		if(feedback==true) camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camclear*"),false,0,0,0,100,false);
		if(feedback==true) speak("Selection points cleared.");
}
