void rotate_left()
{
if(mapmode == "2d") return;
if(turnable == false) return;
me_rotation = turnleft(me_rotation, 45);
bonecheck();
p.play_3d(get_pack_sound("main/characters/"+chartype+"/general/*rotate*"),me.x-1,me.y,me.z,me.x-1,me.y,me.z,calculate_theta(me_rotation),false);
facing = body_to_spy_dir(0);
if(spokenturns==1) speak(dir_to_string(int(me_rotation), false));
}

void rotate_right()
{
if(mapmode == "2d") return;
if(turnable == false) return;
me_rotation = turnright(me_rotation, 45);
bonecheck();
p.play_3d(get_pack_sound("main/characters/"+chartype+"/general/*rotate*"),me.x+1,me.y,me.z,me.x+1,me.y,me.z,calculate_theta(me_rotation),false);
facing = body_to_spy_dir(0);
if(spokenturns==1) speak(dir_to_string(int(me_rotation), false));
}

void step_left()
{
if(facing=="left"==false and turnmode==1)
{
facing="left";
bonecheck();
if(spokenturns==1) speak(facing);
if(facing=="left") p.play_3d(get_pack_sound("main/characters/"+chartype+"/general/*turn*"),me.x-1,me.y,me.z,me.x-1,me.y,me.z,calculate_theta(me_rotation),false);
}
else if (mapmode != "2d" and me.x-1>=minx and wall_blocks(me.x-1, me.y, me.z))
{
bump_wall_at(me.x-1, me.y, me.z);
}
else if (me.x-1>=minx)
{
if(turnmode==0) facing="left";
me.x--;
bonecheck();
playstep();
}
}
void step_right()
{
if(facing=="right"==false and turnmode==1)
{
facing="right";
bonecheck();
if(spokenturns==1) speak(facing);
if(facing=="right") p.play_3d(get_pack_sound("main/characters/"+chartype+"/general/*turn*"),me.x+1,me.y,me.z,me.x+1,me.y,me.z,calculate_theta(me_rotation),false);
}
else if (mapmode != "2d" and me.x+1<=maxx and wall_blocks(me.x+1, me.y, me.z))
{
bump_wall_at(me.x+1, me.y, me.z);
}
else if (me.x+1<=maxx)
{
if(turnmode==0) facing="right";
me.x++;
bonecheck();
playstep();
}
}
void step_down()
{
if (me.z-1 >= minz and wall_blocks(me.x, me.y, me.z-1))
{
bump_wall_at(me.x, me.y, me.z-1);
}
else if (me.z-1 >= minz)
{
facing="down";
me.z--;
bonecheck();
playstep();
}
}
void step_up()
{
if (me.z+1 <= maxz && wall_blocks(me.x, me.y, me.z+1))
{
bump_wall_at(me.x, me.y, me.z+1);
}
else if (me.z+1 <= maxz && (platform_supports(me.x, me.y, me.z+1) || glider_engine_on))
{
facing="up";
me.z++;
bonecheck();
playstep();
}
}

// Body-frame movement helpers for topdown/3d. body_dir: 0=forward, 1=backward, 2=strafe_left, 3=strafe_right.
int body_world_angle(int body_dir)
{
int dir_deg = 0;
if(body_dir == 1) dir_deg = 180;
else if(body_dir == 2) dir_deg = 270;
else if(body_dir == 3) dir_deg = 90;
int world_deg = (int(me_rotation) + dir_deg) % 360;
if(world_deg < 0) world_deg += 360;
return world_deg;
}
string body_world_facing(int body_dir)
{
int wd = body_world_angle(body_dir);
if(wd == 0 or wd == 45 or wd == 315) return "forward";
if(wd == 90) return "right";
if(wd == 135 or wd == 180 or wd == 225) return "backward";
if(wd == 270) return "left";
return facing;
}
void body_world_delta(int body_dir, int &out dx, int &out dy)
{
int wd = body_world_angle(body_dir);
dx = 0; dy = 0;
if(wd == 0) dy = 1;
else if(wd == 45) { dx = 1; dy = 1; }
else if(wd == 90) dx = 1;
else if(wd == 135) { dx = 1; dy = -1; }
else if(wd == 180) dy = -1;
else if(wd == 225) { dx = -1; dy = -1; }
else if(wd == 270) dx = -1;
else if(wd == 315) { dx = -1; dy = 1; }
}
void body_step(int body_dir)
{
int dx, dy;
body_world_delta(body_dir, dx, dy);
double nx = me.x + dx;
double ny = me.y + dy;
if(nx < minx or nx > maxx or ny < miny or ny > maxy) return;
if(wall_blocks(nx, ny, me.z))
{
bump_wall_at(nx, ny, me.z);
return;
}
facing = body_world_facing(body_dir);
me.x = nx;
me.y = ny;
bonecheck();
playstep();
}

// Body-frame camera move for topdown/3d. body_dir: 0=forward, 1=backward, 2=strafe_left, 3=strafe_right.
void body_cam_step(int body_dir)
{
if(camtimer.elapsed < camtime or cammable == false) return;
int dx, dy;
body_world_delta(body_dir, dx, dy);
double nx = cam.x + dx;
double ny = cam.y + dy;
if(nx < minx or nx > maxx or ny < miny or ny > maxy) return;
camdir = body_world_facing(body_dir);
cam.x = nx;
cam.y = ny;
playcam();
camtimer.restart();
}

void playcam()
{
string camtile = (mapmode == "3d") ? platform_tile_at(cam.x, cam.y, cam.z) : gct(cam.x, cam.y);
bool cam_on_player = (mapmode == "3d") ? (me.x==cam.x and me.y==cam.y and me.z==cam.z) : (me.x==cam.x and me.y==cam.y);
for (uint i = 0; i < hazards.length(); i++)
{
if(cam_in_hazard(i))
{
if(mfc==true) camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camhazard*"),false,0,0,0,100,false);
if(mfc==false) camslot=campool.play_extended_3d(get_pack_sound("main/characters/"+chartype+"/map/*camhazard*"),me.x,me.y,me.z,cam.x,cam.y,cam.z,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
}
}
for (uint i = 0; i < safezones.length(); i++)
{
bool camera_in_zone = cam_in_safezone(i);
if (camera_in_zone && !safezones[i].cam_in_zone)
{
if(mfc==true) safezones[i].safesound=safepool.play_stationary_extended(get_map_sound("builder/zones/safe zones/"+safezones[i].safetype+"/*in*"),false,0,0,0,100,false);
if(mfc==false) safezones[i].safesound=campool.play_extended_3d(get_map_sound("builder/zones/safe zones/"+safezones[i].safetype+"/*in*"),me.x,me.y,me.z,cam.x,cam.y,cam.z,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,200,false);
safezones[i].cam_in_zone=true;
}
else if (!camera_in_zone && safezones[i].cam_in_zone)
{
if(mfc==true) safezones[i].safesound=safepool.play_stationary_extended(get_map_sound("builder/zones/safe zones/"+safezones[i].safetype+"/*out*"),false,0,0,0,100,false);
if(mfc==false) safezones[i].safesound=campool.play_extended_3d(get_map_sound("builder/zones/safe zones/"+safezones[i].safetype+"/*out*"),me.x,me.y,me.z,cam.x,cam.y,cam.z,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,200,false);
safezones[i].cam_in_zone=false;
}
}
{
string camwallname = (mapmode == "3d") ? wall_tile_at(cam.x, cam.y, cam.z) : wall_tile_at(cam.x, cam.y);
if (camwallname != "")
{
	if((mapmode == "3d") ? is_transparent_wall(cam.x, cam.y, cam.z) : is_transparent_wall(cam.x, cam.y))
	{
if(mfc==true) camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camwall*"),false,0,0,0,100,false);
if(mfc==false) camslot=campool.play_extended_3d(get_pack_sound("main/characters/"+chartype+"/map/*camwall*"),me.x,me.y,me.z,cam.x,cam.y,cam.z,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
if(mfc==true) camslot=campool.play_stationary_extended(get_map_sound("builder/construction/walls/"+camwallname+"/*bump*"),false,0,0,0,100);
if(mfc==false) camslot=campool.play_extended_3d(get_map_sound("builder/construction/walls/"+camwallname+"/*bump*"),me.x,me.y,me.z,cam.x,cam.y,cam.z,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,200);
return;
	}
else
{
if(mfc==true) camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camwall*"),false,0,0,0,100,false);
if(mfc==false) camslot=campool.play_extended_3d(get_pack_sound("main/characters/"+chartype+"/map/*camwall*"),me.x,me.y,me.z,cam.x,cam.y,cam.z,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
if(mfc==true) camslot=campool.play_stationary_extended(get_map_sound("builder/construction/walls/"+camwallname+"/*bump*"),false,0,0,0,100);
if(mfc==false) camslot=campool.play_extended_3d(get_map_sound("builder/construction/walls/"+camwallname+"/*bump*"),me.x,me.y,me.z,cam.x,cam.y,cam.z,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,200);
cbounce();
return;
}
}
}
if(cam_on_player)
{
if(mfc==true) camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camplayer*"),false,0,0,0,100,false);
if(mfc==false) camslot=campool.play_extended_3d(get_pack_sound("main/characters/"+chartype+"/map/*camplayer*"),me.x,me.y,me.z,cam.x,cam.y,cam.z,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,200,false);
}
if(camtile=="" || camtile=="air")
{
if(mapmode != "topdown")
{
if(mfc==true) camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camair*"),false,0,0,0,100,false);
if(mfc==false) camslot=campool.play_extended_3d(get_pack_sound("main/characters/"+chartype+"/map/*camair*"),me.x,me.y,me.z,cam.x,cam.y,cam.z,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
}
}
else
{
if(mfc==true) camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camtile*"),false,0,0,0,100,false);
if(mfc==false) camslot=campool.play_extended_3d(get_pack_sound("main/characters/"+chartype+"/map/*camtile*"),me.x,me.y,me.z,cam.x,cam.y,cam.z,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
array<string> tiles;
array<double> vols;
array<double> pits;
get_all_platform_tiles(cam.x, cam.y, tiles, vols, pits, cam.z);
for(uint i=0; i<tiles.length(); i++)
{
if(mfc==true) camslot=campool.play_stationary_extended(get_map_sound("builder/construction/platforms/"+tiles[i]+"/*step*"),false,0,0,0,100);
if(mfc==false) camslot=campool.play_extended_3d(get_map_sound("builder/construction/platforms/"+tiles[i]+"/*step*"),me.x,me.y,me.z,cam.x,cam.y,cam.z,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,200);
}
}
}
void playstep()
{
string current_text;
if(is_in_blockage(current_text))
{
speak(current_text);
pbounce();
return;
}
if (mapmode == "2d" && string_contains(gmt(me.x, me.y), "wall", 1) > -1)
{
if(glider_engine_on)
{
if(wallbump || !wall_hit_once)
{
p.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*rico*"), false);
if(!wallbump) wall_hit_once = true;
}
}
else if (wallbump)
{
wallslot = p.play_extended_3d(get_map_sound("builder/construction/walls/" + gmt(me.x, me.y) + "/*bump*"), me.x, me.y, me.z, me.x, me.y, me.z, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, wallvolume, wallpitch);
}
else
{
if (!wall_hit_once)
{
wallslot = p.play_extended_3d(get_map_sound("builder/construction/walls/" + gmt(me.x, me.y) + "/*bump*"), me.x, me.y, me.z, me.x, me.y, me.z, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, wallvolume, wallpitch);
wall_hit_once = true;
}
}
pbounce();
return;
}
for(uint i=0; i<healzones.length(); i++)
{
bool currently_in_zone = player_in_healzone(i);
if (currently_in_zone && !healzones[i].in_zone)
{
if(healzones[i].healmode==1) healzones[i].healsound=healpool.play_stationary(get_map_sound("builder/zones/heal zones/"+healzones[i].healtype+"/*heal*"),false);
if(healzones[i].healmode==0) healzones[i].takesound=healpool.play_stationary(get_map_sound("builder/zones/heal zones/"+healzones[i].healtype+"/*take*"),false);
healzones[i].in_zone = true;
}
else if (!currently_in_zone && healzones[i].in_zone)
{
healzones[i].in_zone = false;
}
}
for(uint i=0; i<safezones.length(); i++)
{
bool currently_in_zone = player_in_safezone(i);
if (currently_in_zone && !safezones[i].player_in_zone)
{
safezones[i].safesound=safepool.play_stationary(get_map_sound("builder/zones/safe zones/"+safezones[i].safetype+"/*in*"),false);
safezones[i].player_in_zone = true;
}
else if (!currently_in_zone && safezones[i].player_in_zone)
{
safezones[i].safesound=safepool.play_stationary(get_map_sound("builder/zones/safe zones/"+safezones[i].safetype+"/*out*"),false);
safezones[i].player_in_zone = false;
}
}
for(uint i=0; i<signs.length(); i++)
{
if(jumping==0)
{
if(signs[i].looping==false) signs[i].signsound=signpool.play_3d(get_map_sound("builder/interaction/signs/"+signs[i].signtype+"/*step*"),me.x,me.y,me.z,signs[i].signx,signs[i].signy,signs[i].signz,calculate_theta(me_rotation),false);
}
}
if(!glider_engine_on)
{
for(uint i=0; i<forcefields.length(); i++)
{
if(forcefield_hit(i)) return;
}
for(uint i=0; i<hazards.length(); i++)
{
if(player_in_hazard(i) and !inplain)
{
if(lifecard>=2)
{
hazardpool.play_stationary(get_pack_sound("main/characters/"+chartype+"/general/*life*"),false);
lifecard-=1;
health=maxhealth;
pbounce(5);
return;
}
}
}
}
if (son.cyclemode == 1)
	son.sonarcheck();
if(jumping==0 && !glider_engine_on)
{
array<string> tiles;
array<double> vols;
array<double> pits;
get_all_platform_tiles(me.x, me.y, tiles, vols, pits, me.z);
for(uint i=0; i<tiles.length(); i++)
{
tileslot=p.play_stationary_extended(get_map_sound("builder/construction/platforms/"+tiles[i]+"/*step*"), false, 0, 0, vols[i], pits[i]);
}
}
wall_hit_once = false;
}
void playfall()
{
for(uint i=0; i<healzones.length(); i++)
{
bool currently_in_zone = player_in_healzone(i);
if (currently_in_zone && !healzones[i].in_zone)
{
if(healzones[i].healmode==1) healzones[i].healsound=healpool.play_stationary(get_map_sound("builder/zones/heal zones/"+healzones[i].healtype+"/*heal*"),false);
if(healzones[i].healmode==0) healzones[i].takesound=healpool.play_stationary(get_map_sound("builder/zones/heal zones/"+healzones[i].healtype+"/*take*"),false);
healzones[i].in_zone = true;
}
else if (!currently_in_zone && healzones[i].in_zone)
{
healzones[i].in_zone = false;
}
}
for(uint i=0; i<safezones.length(); i++)
{
bool currently_in_zone = player_in_safezone(i);
