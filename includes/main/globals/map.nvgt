array<double> pits;
get_all_platform_tiles(me.x, me.y, tiles, vols, pits, me.z);
if(!onbike)
{
for(uint i=0; i<tiles.length(); i++)
{
tileslot=p.play_stationary_extended(get_map_sound("builder/construction/platforms/"+tiles[i]+"/*fall*"), false, 0, 0, vols[i], pits[i]);
}
}
if(onbike)
{
for(uint i=0; i<bikes.length(); i++)
{
if(bikes[i].moveable)
{
string biketile = identify_biketile(gmt(me.x, me.y));
bikepool.play_stationary_extended(get_map_sound("builder/transportation/bikes/"+bikes[i].biketype+"/platforms/"+biketile+"/*fall*"), false, 0, 0, 0, 100, false);
break;
}
}
}
}
