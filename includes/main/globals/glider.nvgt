}
for(uint j = 0; j < projectiles.length(); j++)
{
if(projectiles[j].prox != hx || projectiles[j].proy != hy) continue;
if(mapmode == "3d" && projectiles[j].proz != hz) continue;
if(!projectiles[j].destroyable) continue;
int actual = max(0, dmg);
projectiles[j].projhealth -= actual;
kombatlog.insert_last(actual + " damage to " + projectiles[j].projtype + " by " + wepchar.sub + "'s weapon attack.");
gliderpool.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*hit*"), false);
if(actual > 0 && projectiles[j].projhealth > 0)
projectiles[j].wepsound = projpool.play_extended_3d(get_map_sound("builder/kombat/projectiles/"+projectiles[j].projtype+"/*hurt*"), me.x, me.y, me.z, projectiles[j].prox, projectiles[j].proy, projectiles[j].proz, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
if(projectiles[j].projhealth <= 0)
{
gliderpool.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*death*"), false);
projpool.play_extended_3d(get_map_sound("builder/kombat/projectiles/"+projectiles[j].projtype+"/*death*"), me.x, me.y, me.z, projectiles[j].prox, projectiles[j].proy, projectiles[j].proz, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
destroy_projectile(j);
}
return;
}
}

void glider_apply_drains()
{
if(wepchar.stamina_drain > 0)
{
stamina -= wepchar.stamina_drain;
if(stamina < 0) stamina = 0;
}
if(wepchar.health_drain > 0)
{
health -= wepchar.health_drain;
if(health < 0) health = 0;
}
}

void glider_loop()
{
if(!glider_engine_on || !wepchar.is_glider()) return;
if(mapmode == "3d" && me.z < 1)
{
me.z = 0;
glider_fuel_out = true;
glider_engine_stop();
tileslot = p.play_stationary_extended(get_map_sound("builder/construction/platforms/"+platform_tile_at(me.x, me.y, me.z)+"/*land*"), false, 0, 0, tilevolume, tilepitch);
return;
}
else if(mapmode == "2d" && me.y < 1)
{
me.y = 0;
glider_fuel_out = true;
glider_engine_stop();
tileslot = p.play_stationary_extended(get_map_sound("builder/construction/platforms/"+gmt(me.x, me.y)+"/*land*"), false, 0, 0, tilevolume, tilepitch);
return;
}
if(glider_strike_timer.elapsed < movetime) return;
glider_strike_timer.restart();
glider_contact_strike();
glider_apply_drains();
if(stamina <= 0 && wepchar.stamina_drain > 0) { glider_fuel_out = true; glider_engine_stop(); }
}
