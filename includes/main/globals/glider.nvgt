bool glider_engine_on = false;
bool glider_fuel_out = false;
int glider_loop_slot = 0;
sound_pool gliderpool;
timer glider_strike_timer;

void glider_engine_start()
{
if(glider_engine_on) return;
if(glider_fuel_out) return;
if(wepchar.stamina_drain > 0 && stamina <= 0) return;
glider_engine_on = true;
if(falling)
{
falling = false;
fallcounter = 0;
if(fallslot != 0) p.destroy_sound(fallslot);
}
if(mapmode == "3d") me.z += 1;
else if(mapmode == "2d") me.y += 1;
gliderpool.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*on*"), false);
if(glider_loop_slot != 0) { gliderpool.destroy_sound(glider_loop_slot); glider_loop_slot = 0; }
glider_loop_slot = gliderpool.play_stationary_extended(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*loop*"), true, 0, 0, 0, 100, false);
}

void glider_engine_stop()
{
if(!glider_engine_on) return;
glider_engine_on = false;
gliderpool.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*off*"), false);
if(glider_loop_slot != 0) { gliderpool.destroy_sound(glider_loop_slot); glider_loop_slot = 0; }
}

void glider_contact_strike()
{
if(!glider_engine_on || !wepchar.is_glider()) return;
int hx = int(me.x), hy = int(me.y), hz = int(me.z);
if(mapmode == "2d") hy -= 1;
else if(mapmode == "3d") hz -= 1;
int dmg = wepchar.damage;
for(uint j = 0; j < npcs.length(); j++)
{
if(@npcs[j] == null) continue;
if(npcs[j].x != hx || npcs[j].y != hy) continue;
if(mapmode == "3d" && npcs[j].z != hz) continue;
int actual = max(0, dmg - int(npcs[j].defence) * 3);
npcs[j].health -= actual;
kombatlog.insert_last(actual + " damage to " + npcs[j].subtype + " by " + wepchar.sub + "'s weapon attack.");
gliderpool.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*hit*"), false);
if(actual > 0 && npcs[j].health > 0)
{
sound_pool@ npool = npc_pool(npcs[j].category);
npool.destroy_sound(npcs[j].hurtsound);
npool.pause_sound(npcs[j].mainsound);
npcs[j].hurtsound = npool.play_extended_3d(get_map_sound("builder/kombat/npc/"+npcs[j].category+"/"+npcs[j].subtype+"/general/*hurt*"), me.x, me.y, me.z, npcs[j].x, npcs[j].y, npcs[j].z, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
npcs[j].hurtdelay = round(npool.get_sound_length(npcs[j].hurtsound), 0);
npcs[j].hurttimer.restart();
npcs[j].hurting = true;
}
if(npcs[j].health <= 0)
gliderpool.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*death*"), false);
return;
}
for(uint j = 0; j < ttsenemies.length(); j++)
{
if(@ttsenemies[j] == null) continue;
if(ttsenemies[j].ttsemx != hx || ttsenemies[j].ttsemy != hy) continue;
if(mapmode == "3d" && ttsenemies[j].ttsemz != hz) continue;
int actual = max(0, dmg - ttsenemies[j].defense * 3);
ttsenemies[j].ttsenehealth -= actual;
kombatlog.insert_last(actual + " damage to tts enemie by " + wepchar.sub + "'s weapon attack.");
gliderpool.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*hit*"), false);
if(actual > 0 && ttsenemies[j].ttsenehealth > 0)
{
ttsempool.destroy_sound(ttsenemies[j].hurtsound);
ttsempool.pause_sound(ttsenemies[j].ttsemsound);
ttsenemies[j].hurtsound = ttsempool.play_extended_3d(ttsenemies[j].hurt_file, me.x, me.y, me.z, ttsenemies[j].ttsemx, ttsenemies[j].ttsemy, ttsenemies[j].ttsemz, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
ttsenemies[j].hurtdelay = round(ttsempool.get_sound_length(ttsenemies[j].hurtsound), 0);
ttsenemies[j].hurttimer.restart();
ttsenemies[j].hurting = true;
}
if(ttsenemies[j].ttsenehealth <= 0)
gliderpool.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*death*"), false);
return;
}
for(uint j = 0; j < calendars.length(); j++)
{
if(@calendars[j] == null) continue;
if(hx < calendars[j].minx || hx > calendars[j].maxx || hy < calendars[j].miny || hy > calendars[j].maxy) continue;
if(mapmode == "3d" && (hz < calendars[j].minz || hz > calendars[j].maxz)) continue;
if(!calendars[j].destroyable) continue;
gliderpool.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*hit*"), false);
gliderpool.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*death*"), false);
calpool.destroy_sound(calendars[j].calendarsound);
int gbreak = calpool.play_extended_3d(get_map_sound("builder/interaction/calendars/"+calendars[j].calendartype+"/*break*"), me.x, me.y, me.z, calendars[j].calendarx, calendars[j].calendary, calendars[j].calendarz, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
calpool.update_sound_range_3d(gbreak, 0, calendars[j].maxx-calendars[j].minx, 0, calendars[j].maxy-calendars[j].miny, 0, (mapmode=="3d")?(calendars[j].maxz-calendars[j].minz):0);
@calendars[j] = null;
return;
}
for(uint j = 0; j < clocks.length(); j++)
{
if(@clocks[j] == null) continue;
if(hx < clocks[j].minx || hx > clocks[j].maxx || hy < clocks[j].miny || hy > clocks[j].maxy) continue;
if(mapmode == "3d" && (hz < clocks[j].minz || hz > clocks[j].maxz)) continue;
if(!clocks[j].destroyable) continue;
gliderpool.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*hit*"), false);
gliderpool.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*death*"), false);
clockpool.destroy_sound(clocks[j].clocksound);
int gbreak = clockpool.play_extended_3d(get_map_sound("builder/interaction/clocks/"+clocks[j].clocktype+"/*break*"), me.x, me.y, me.z, clocks[j].clockx, clocks[j].clocky, clocks[j].clockz, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
clockpool.update_sound_range_3d(gbreak, 0, clocks[j].maxx-clocks[j].minx, 0, clocks[j].maxy-clocks[j].miny, 0, (mapmode=="3d")?(clocks[j].maxz-clocks[j].minz):0);
@clocks[j] = null;
return;
}
for(uint j = 0; j < signs.length(); j++)
{
if(@signs[j] == null) continue;
if(signs[j].signx != hx || signs[j].signy != hy) continue;
if(mapmode == "3d" && signs[j].signz != hz) continue;
if(!signs[j].destroyable) continue;
gliderpool.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*hit*"), false);
gliderpool.play_stationary(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*death*"), false);
signpool.destroy_sound(signs[j].signsound);
signpool.play_extended_3d(get_map_sound("builder/interaction/signs/"+signs[j].signtype+"/*break*"), me.x, me.y, me.z, signs[j].signx, signs[j].signy, signs[j].signz, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
@signs[j] = null;
return;
}
for(uint j = 0; j < objs.length(); j++)
