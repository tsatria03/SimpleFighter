sound_pool bulletpool;
bullet@[]bullets(0);

class bullet
{
int bullsound, wepsound;
int bullx;
int bully;
int bullz;
int spawn_x;
int spawn_y;
int spawn_z;
int range;
int range2;
int range3;
int damage;
int speed;
int stun;
int firer_npc;
int scadder_radius;
int scadder_count;
int push_x;
int push_y;
int push_z;
bool first_tick;
bool is_cloner;
string direction;
string bulltype;
string bulltype2;
timer speedtimer;
bullet(int bx,int by,int br,int br2,int dmg,int sp,string dr,string bt,string bt2,int sn,int fn,int bz=0,int br3=0,int scr=0,int scc=0,int px=0,int py=0,int pz=0,bool cloner=false)
{
bullx=bx;
bully=by;
bullz=bz;
spawn_x=bx;
spawn_y=by;
spawn_z=bz;
range=br;
range2=br2;
range3=br3;
damage=dmg;
speed=sp;
stun=sn;
firer_npc=fn;
scadder_radius=scr;
scadder_count=scc;
push_x=px;
push_y=py;
push_z=pz;
first_tick=true;
is_cloner=cloner;
direction=dr;
bulltype=bt;
bulltype2=bt2;
bullsound=bulletpool.play_extended_3d(get_pack_sound("main/equipments/weapons/"+bulltype+"/"+bulltype2+"/general/*loop*"),me.x,me.y,me.z,bullx,bully,bullz,calculate_theta(me_rotation),0,0,0,0,0,0,true,0,0,0,100,false);
}
void bull_bounce()
{
if(direction=="right")
direction="left";
else if(direction=="left")
direction="right";
else if(direction=="up")
direction="down";
else if(direction=="down")
direction="up";
else if(direction=="forward")
direction="backward";
else if(direction=="backward")
direction="forward";
}
}
void bulletloop()
{
for(uint i=0; i<bullets.length(); i++)
{
if(@bullets[i] == null) continue;
if(bullets[i].speedtimer.elapsed>=bullets[i].speed)
{
bulletpool.update_sound_3d(bullets[i].bullsound,bullets[i].bullx,bullets[i].bully, bullets[i].bullz);
bullets[i].speedtimer.restart();
bool was_first_tick = bullets[i].first_tick;
bullets[i].first_tick = false;
if(!was_first_tick)
{
if(bullets[i].direction=="right")
{
bullets[i].bullx++;
}
if(bullets[i].direction=="left")
{
bullets[i].bullx--;
}
if(bullets[i].direction=="forward")
{
bullets[i].bully++;
}
if(bullets[i].direction=="backward")
{
bullets[i].bully--;
}
if(bullets[i].direction=="up")
{
if(mapmode == "3d") bullets[i].bullz++;
else bullets[i].bully++;
}
if(bullets[i].direction=="down")
{
if(mapmode == "3d") bullets[i].bullz--;
else bullets[i].bully--;
}
bool bull_hit_wall = false;
for(uint w=0; w<walls.length(); w++)
{
if(@walls[w] == null) continue;
if(walls[w].minx<=bullets[i].bullx and walls[w].maxx>=bullets[i].bullx and walls[w].miny<=bullets[i].bully and walls[w].maxy>=bullets[i].bully)
{
if(mapmode == "3d" and (bullets[i].bullz<walls[w].minz or bullets[i].bullz>walls[w].maxz)) continue;
bull_hit_wall = true;
break;
}
}
if(bull_hit_wall)
{
bulletpool.destroy_sound(bullets[i].bullsound);
bullets[i].wepsound=bulletpool.play_extended_3d(get_pack_sound("main/equipments/weapons/"+bullets[i].bulltype+"/"+bullets[i].bulltype2+"/general/*rico*"),me.x,me.y,me.z,bullets[i].bullx,bullets[i].bully,bullets[i].bullz,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
bullets[i].bull_bounce();
}
}
if(!(was_first_tick && bullets[i].firer_npc == -1) && me.x==bullets[i].bullx and me.y==bullets[i].bully and (mapmode != "3d" or me.z==bullets[i].bullz) and inplain==false and invehicle==false and onbike==false and !glider_engine_on)
{
if(wepchar.reflection and wepdef==1)
{
int roll = random(0, 100);
if(roll < wepchar.refchance)
{
bulletpool.destroy_sound(bullets[i].bullsound);
wepchar.sound_slot=p.play_stationary_extended(get_pack_sound("main/equipments/weapons/"+wepchar.cad+"/"+wepchar.sub+"/general/*block*"),false,0,0,0,100,false);
@bullets[i] = null;
return;
}
else
{
if(shieldon==1 and shield_blocks())
{
bulletpool.destroy_sound(bullets[i].bullsound);
int sdm = max(1, (wepchar.refcushion ? int(bullets[i].damage * 0.5) : bullets[i].damage) - shielddefence * 3);
shieldstrength -= sdm;
kombatlog.insert_last(bullets[i].bulltype2 + "'s attack took " + shieldtype + " " + sdm + " damage.");
shieldslot=p.play_stationary_extended(get_pack_sound("main/equipments/shields/"+shieldtype+"/general/*hit*"),false,0,0,0,100,false);
try_bullet_splash(i, "", -1, mapmode == "3d");
if(bullets[i].firer_npc>=0 and uint(bullets[i].firer_npc)<npcs.length()) try_shield_launch(int(npcs[bullets[i].firer_npc].x), int(npcs[bullets[i].firer_npc].y), int(npcs[bullets[i].firer_npc].z), bullets[i].damage);
@bullets[i] = null;
return;
}
else
{
bulletpool.destroy_sound(bullets[i].bullsound);
bullets[i].wepsound=bulletpool.play_extended_3d(get_pack_sound("main/equipments/weapons/"+bullets[i].bulltype+"/"+bullets[i].bulltype2+"/general/*hit*"),me.x,me.y,me.z,bullets[i].bullx,bullets[i].bully,bullets[i].bullz,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
bullets[i].wepsound=bulletpool.play_extended_3d(get_pack_sound("main/equipments/weapons/"+bullets[i].bulltype+"/"+bullets[i].bulltype2+"/general/*shell*"),me.x,me.y,me.z,bullets[i].bullx,bullets[i].bully,bullets[i].bullz,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
int dmg = max(1, (wepchar.refcushion ? int(bullets[i].damage * 0.5) : bullets[i].damage) - defence * 3);
int impact = 0;
if(bullets[i].firer_npc >= 0)
{
int tx = int(me.x), ty = int(me.y), tz = int(me.z);
impact = apply_push(tx, ty, tz, bullets[i].spawn_x, bullets[i].spawn_y, bullets[i].spawn_z, bullets[i].push_x, bullets[i].push_y, bullets[i].push_z, mapmode == "3d", bullets[i].direction);
me.x = tx; me.y = ty; me.z = tz;
}
health -= dmg + impact;
kombatlog.insert_last(bullets[i].bulltype2 + "'s attack took you " + dmg + " damage.");
if(impact > 0) kombatlog.insert_last("You were slammed into a wall for " + impact + " damage.");
{
int total = dmg + impact;
string painfile;
int damage_percent = round((float(total) / float(maxhealth)) * 100, 0);
if (damage_percent <= 1)
{
painfile = get_pack_sound("main/characters/" + chartype+"/general/*hurt*");
}
else if (damage_percent >= 10)
{
painfile = get_pack_sound("main/characters/" + chartype+"/general/*crit*");
}
else
{
painfile = get_pack_sound("main/characters/" + chartype+"/general/*hurt*");
}
painslot = p.play_stationary_extended(painfile, false, 0, 0, 0, 100, false);
}
if(bullets[i].stun > 0) stun_target("me", "", bullets[i].stun);
try_bullet_splash(i, "", -1, mapmode == "3d");
@bullets[i] = null;
return;
}
}
}
else if (shieldon == 1 and shield_blocks())
{
bulletpool.destroy_sound(bullets[i].bullsound);
