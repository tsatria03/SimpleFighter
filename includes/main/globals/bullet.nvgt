void spawn_bullet(int x,int y,int range,int range2,int damage,int speed,string direction,string bulltype,string bulltype2,int stun=0,int firer_npc=-1,int z=0,int range3=0,int scadder_radius=0,int scadder_count=0,int push_x=0,int push_y=0,int push_z=0,bool is_cloner=false)
{
bullet bl1(x,y,range,range2,damage,speed,direction,bulltype,bulltype2,stun,firer_npc,z,range3,scadder_radius,scadder_count,push_x,push_y,push_z,is_cloner);
bullets.insert_last(bl1);
}
void cloner_clone_position(int hx, int hy, int hz, int &out cx, int &out cy, int &out cz)
{
int px = int(me.x);
int py = int(me.y);
int pz = int(me.z);
if(!cloner_has_last)
{
cx = hx; cy = hy; cz = hz;
}
else
{
int bx = cloner_last_x, by = cloner_last_y, bz = cloner_last_z;
int dx = (bx > px) ? -1 : (bx < px ? 1 : 0);
int dy = (by > py) ? -1 : (by < py ? 1 : 0);
int dz = (bz > pz) ? -1 : (bz < pz ? 1 : 0);
cx = bx + dx;
cy = by + dy;
cz = bz + dz;
if((dx > 0 && cx > px) || (dx < 0 && cx < px)) cx = px;
if((dy > 0 && cy > py) || (dy < 0 && cy < py)) cy = py;
if((dz > 0 && cz > pz) || (dz < 0 && cz < pz)) cz = pz;
}
cloner_last_x = cx;
cloner_last_y = cy;
cloner_last_z = cz;
cloner_has_last = true;
}
void destroy_all_bullets()
{
for(uint i=0; i<bullets.length(); i++)
{
if(@bullets[i] == null) continue;
bulletpool.destroy_sound(bullets[i].bullsound);
}
bullets.resize(0);
}
void clean_dead_npc_bullets(int dead_index)
{
for(uint b=0; b<bullets.length(); b++)
{
if(@bullets[b] == null) continue;
if(bullets[b].firer_npc==dead_index)
{
bulletpool.destroy_sound(bullets[b].bullsound);
@bullets[b] = null;
}
}
}
void destroy_npc_bullets()
{
for(uint b=0; b<bullets.length(); b++)
{
if(@bullets[b] == null) continue;
if(bullets[b].firer_npc!=-1)
{
bulletpool.destroy_sound(bullets[b].bullsound);
@bullets[b] = null;
}
}
}

void bullet_scadder_splash(int bx, int by, int bz, int dmg, int sr, int sc, string bulltype, string bulltype2, int firer_npc, int stun, bool is_3d, string skip_kind, int skip_idx)
{
if(sr <= 0) return;
int remaining = sc;
for(uint j = 0; j < npcs.length(); j++)
{
if(@npcs[j] == null) continue;
if(skip_kind == "npc" and int(j) == skip_idx) continue;
if(int(j) == firer_npc) continue;
if(npcs[j].targets.length() == 0) continue;
int dx = absolute(int(npcs[j].x) - bx);
int dy = absolute(int(npcs[j].y) - by);
int dz = absolute(int(npcs[j].z) - bz);
if(dx > sr or dy > sr) continue;
if(is_3d and dz > sr) continue;
sound_pool@ npool = npc_pool(npcs[j].category);
int hit_dmg = 0;
if(npcs[j].category == "humans" and npcs[j].wephum.reflection and npcs[j].refon)
{
int roll = random(0, 100);
if(roll < npcs[j].wephum.refchance)
{
npool.pause_sound(npcs[j].mainsound);
npcs[j].refsound = npool.play_extended_3d(get_pack_sound("main/equipments/weapons/"+npcs[j].wephum.cad+"/"+npcs[j].wephum.sub+"/general/*block*"), me.x, me.y, me.z, npcs[j].x, npcs[j].y, npcs[j].z, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
npcs[j].hurtdelay = round(npool.get_sound_length(npcs[j].refsound), 0);
npcs[j].hurttimer.restart();
npcs[j].hurting = true;
if(sc > 0) { remaining--; if(remaining <= 0) return; }
continue;
}
hit_dmg = max(0, (npcs[j].wephum.refcushion ? int(dmg * 0.5) : dmg) - npcs[j].defence * 3);
}
else
{
hit_dmg = max(0, dmg - npcs[j].defence * 3);
}
npcs[j].health -= hit_dmg;
kombatlog.insert_last(hit_dmg + " damage to " + npcs[j].subtype + " by " + bulltype2 + "'s weapon attack.");
if(hit_dmg > 0 and npcs[j].health > 0)
{
npool.destroy_sound(npcs[j].hurtsound);
npool.pause_sound(npcs[j].mainsound);
npcs[j].hurtsound = npool.play_extended_3d(get_map_sound("builder/kombat/npc/"+npcs[j].category+"/"+npcs[j].subtype+"/general/*hurt*"), me.x, me.y, me.z, npcs[j].x, npcs[j].y, npcs[j].z, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
npcs[j].hurtdelay = round(npool.get_sound_length(npcs[j].hurtsound), 0);
npcs[j].hurttimer.restart();
npcs[j].hurting = true;
}
if(stun > 0) { stuntimer.restart(); stunned = true; stundir = stun; npcs[j].fireable = false; npcs[j].move_x = false; npcs[j].move_y = false; npcs[j].move_z = false; }
if(sc > 0) { remaining--; if(remaining <= 0) return; }
}
for(uint jt = 0; jt < ttsenemies.length(); jt++)
{
if(@ttsenemies[jt] == null) continue;
if(skip_kind == "tts" and int(jt) == skip_idx) continue;
int dx = absolute(int(ttsenemies[jt].ttsemx) - bx);
int dy = absolute(int(ttsenemies[jt].ttsemy) - by);
int dz = is_3d ? absolute(int(ttsenemies[jt].ttsemz) - bz) : 0;
if(dx > sr or dy > sr or dz > sr) continue;
int hit_dmg = max(0, dmg - ttsenemies[jt].defense * 3);
ttsenemies[jt].ttsenehealth -= hit_dmg;
kombatlog.insert_last(hit_dmg + " damage to tts enemie by " + bulltype2 + "'s weapon attack.");
if(hit_dmg > 0 and ttsenemies[jt].ttsenehealth > 0)
{
ttsempool.destroy_sound(ttsenemies[jt].hurtsound);
ttsempool.pause_sound(ttsenemies[jt].ttsemsound);
ttsenemies[jt].hurtsound = ttsempool.play_extended_3d(ttsenemies[jt].hurt_file, me.x, me.y, me.z, ttsenemies[jt].ttsemx, ttsenemies[jt].ttsemy, ttsenemies[jt].ttsemz, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
ttsenemies[jt].hurtdelay = round(ttsempool.get_sound_length(ttsenemies[jt].hurtsound), 0);
ttsenemies[jt].hurttimer.restart();
ttsenemies[jt].hurting = true;
}
if(sc > 0) { remaining--; if(remaining <= 0) return; }
}
for(uint i = 0; i < walls.length(); i++)
{
if(@walls[i] == null) continue;
if(skip_kind == "wall" and int(i) == skip_idx) continue;
if(!walls[i].destroyable) continue;
int dx = max(0, max(int(walls[i].minx) - bx, bx - int(walls[i].maxx)));
int dy = max(0, max(int(walls[i].miny) - by, by - int(walls[i].maxy)));
int dz = is_3d ? max(0, max(int(walls[i].minz) - bz, bz - int(walls[i].maxz))) : 0;
if(dx > sr or dy > sr) continue;
if(is_3d and dz > sr) continue;
int hit_dmg = max(0, dmg);
walls[i].wallhealth -= hit_dmg;
kombatlog.insert_last(hit_dmg + " damage to " + string_replace(walls[i].wall, "wall", "", true) + " wall by " + bulltype2 + "'s weapon attack.");
if(hit_dmg > 0)
{
walls[i].hurtsound = p.play_extended_3d(get_map_sound("builder/construction/walls/"+walls[i].wall+"/*hurt*"), me.x, me.y, me.z, walls[i].minx, walls[i].miny, walls[i].minz, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, wallvolume, wallpitch, false);
p.update_sound_3d(walls[i].hurtsound, walls[i].minx, walls[i].miny, 0);
p.update_sound_range_3d(walls[i].hurtsound, 0, walls[i].maxx-walls[i].minx, 0, walls[i].maxy-walls[i].miny, 0, 0);
}
if(sc > 0) { remaining--; if(remaining <= 0) return; }
}
for(uint i = 0; i < doors.length(); i++)
{
if(@doors[i] == null) continue;
if(skip_kind == "door" and int(i) == skip_idx) continue;
