void spawn_bullet(int x,int y,int range,int range2,int damage,int speed,string direction,string bulltype,string bulltype2,int stun=0,int firer_npc=-1,int z=0,int range3=0)
{
bullet bl1(x,y,range,range2,damage,speed,direction,bulltype,bulltype2,stun,firer_npc,z,range3);
bullets.insert_last(bl1);
}
void destroy_all_bullets()
{
for(uint i=0; i<bullets.length(); i++)
{
bulletpool.destroy_sound(bullets[i].bullsound);
}
bullets.resize(0);
}
void clean_dead_npc_bullets(int dead_index)
{
for(uint b=0; b<bullets.length();)
{
if(bullets[b].firer_npc==dead_index)
{
bulletpool.destroy_sound(bullets[b].bullsound);
bullets.remove_at(b);
}
else
{
if(bullets[b].firer_npc>dead_index) bullets[b].firer_npc-=1;
b++;
}
}
}
void destroy_npc_bullets()
{
for(uint b=0; b<bullets.length();)
{
if(bullets[b].firer_npc!=-1)
{
bulletpool.destroy_sound(bullets[b].bullsound);
bullets.remove_at(b);
}
else b++;
}
}
