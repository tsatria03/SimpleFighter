int dx = max(0, max(int(doors[i].minx) - bx, bx - int(doors[i].maxx)));
int dy = max(0, max(int(doors[i].miny) - by, by - int(doors[i].maxy)));
int dz = is_3d ? max(0, max(int(doors[i].minz) - bz, bz - int(doors[i].maxz))) : 0;
if(dx > sr or dy > sr) continue;
if(is_3d and dz > sr) continue;
int hit_dmg = max(0, dmg);
doors[i].doorhealth -= hit_dmg;
kombatlog.insert_last(hit_dmg + " damage to door by " + bulltype2 + "'s weapon attack.");
