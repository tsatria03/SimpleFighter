class bullet
{
int bullsound, wepsound;
int bullx;
int bully;
int bullz;
int spawn_x;
int spawn_y;
int spawn_z;
int range;
int range2;
int range3;
int damage;
int speed;
int stun;
int firer_npc;
bool first_tick;
string direction;
string bulltype;
string bulltype2;
timer speedtimer;
bullet(int bx,int by,int br,int br2,int dmg,int sp,string dr,string bt,string bt2,int sn,int fn,int bz=0,int br3=0)
{
bullx=bx;
bully=by;
bullz=bz;
spawn_x=bx;
spawn_y=by;
spawn_z=bz;
range=br;
range2=br2;
range3=br3;
damage=dmg;
speed=sp;
stun=sn;
firer_npc=fn;
first_tick=true;
direction=dr;
bulltype=bt;
bulltype2=bt2;
bullsound=bulletpool.play_extended_3d(get_pack_sound("equipments/weapons/"+bulltype+"/"+bulltype2+"/*loop*"),me.x,me.y,me.z,bullx,bully,bullz,calculate_theta(me_rotation),0,0,0,0,0,0,true,0,0,0,100,false);
}
void bull_bounce()
{
if(direction=="right")
direction="left";
else if(direction=="left")
direction="right";
else if(direction=="up")
direction="down";
else if(direction=="down")
direction="up";
else if(direction=="forward")
direction="backward";
else if(direction=="backward")
direction="forward";
}
}
void bulletloop()
{
for(uint i=0; i<bullets.length(); i++)
{
if(bullets[i].speedtimer.elapsed>=bullets[i].speed)
{
bulletpool.update_sound_3d(bullets[i].bullsound,bullets[i].bullx,bullets[i].bully, bullets[i].bullz);
bullets[i].speedtimer.restart();
bool was_first_tick = bullets[i].first_tick;
bullets[i].first_tick = false;
if(!was_first_tick)
{
if(bullets[i].direction=="right")
{
bullets[i].bullx++;
}
if(bullets[i].direction=="left")
{
bullets[i].bullx--;
}
if(bullets[i].direction=="forward")
{
bullets[i].bully++;
}
if(bullets[i].direction=="backward")
{
bullets[i].bully--;
}
if(bullets[i].direction=="up")
{
if(mapmode == "3d") bullets[i].bullz++;
else bullets[i].bully++;
}
if(bullets[i].direction=="down")
{
if(mapmode == "3d") bullets[i].bullz--;
else bullets[i].bully--;
}
bool bull_hit_wall = false;
for(uint w=0; w<walls.length(); w++)
{
if(walls[w].minx<=bullets[i].bullx and walls[w].maxx>=bullets[i].bullx and walls[w].miny<=bullets[i].bully and walls[w].maxy>=bullets[i].bully)
{
if(mapmode == "3d" and (bullets[i].bullz<walls[w].minz or bullets[i].bullz>walls[w].maxz)) continue;
bull_hit_wall = true;
break;
}
}
if(bull_hit_wall)
{
bulletpool.destroy_sound(bullets[i].bullsound);
bullets[i].wepsound=bulletpool.play_extended_3d(get_pack_sound("equipments/weapons/"+bullets[i].bulltype+"/"+bullets[i].bulltype2+"/*rico*"),me.x,me.y,me.z,bullets[i].bullx,bullets[i].bully,bullets[i].bullz,calculate_theta(me_rotation),0,0,0,0,0,0,false,0,0,0,100,false);
bullets[i].bull_bounce();
}
