if(sc > 0) { remaining--; if(remaining <= 0) return; }
}
for(int i = int(calendars.length()) - 1; i >= 0; i--)
{
if(@calendars[i] == null) continue;
if(skip_kind == "calendar" and i == skip_idx) continue;
if(!calendars[i].destroyable) continue;
int ccx = bx < calendars[i].minx ? calendars[i].minx : (bx > calendars[i].maxx ? calendars[i].maxx : bx);
int ccy = by < calendars[i].miny ? calendars[i].miny : (by > calendars[i].maxy ? calendars[i].maxy : by);
int ccz = bz < calendars[i].minz ? calendars[i].minz : (bz > calendars[i].maxz ? calendars[i].maxz : bz);
int dx = absolute(ccx - bx);
int dy = absolute(ccy - by);
int dz = absolute(ccz - bz);
if(dx > sr or dy > sr) continue;
if(is_3d and dz > sr) continue;
calpool.destroy_sound(calendars[i].calendarsound);
calendars[i].hurtsound = calpool.play_extended_3d(get_map_sound("builder/interaction/calendars/"+calendars[i].calendartype+"/*break*"), me.x, me.y, me.z, calendars[i].calendarx, calendars[i].calendary, calendars[i].calendarz, calculate_theta(me_rotation), 0, 0, 0, 0, 0, 0, false, 0, 0, 0, 100, false);
calpool.update_sound_range_3d(calendars[i].hurtsound, 0, calendars[i].maxx-calendars[i].minx, 0, calendars[i].maxy-calendars[i].miny, 0, (mapmode=="3d")?(calendars[i].maxz-calendars[i].minz):0);
@calendars[i] = null;
if(sc > 0) { remaining--; if(remaining <= 0) return; }
}
