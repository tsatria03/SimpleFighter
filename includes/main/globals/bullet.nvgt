void try_bullet_splash(uint i, string skip_kind, int skip_idx, bool is_3d)
{
if(bullets[i].scadder_radius <= 0) return;
int splash_count = (bullets[i].scadder_count == 0) ? 0 : (bullets[i].scadder_count - 1);
if(bullets[i].scadder_count > 0 and splash_count <= 0) return;
bullet_scadder_splash(bullets[i].bullx, bullets[i].bully, bullets[i].bullz, bullets[i].damage, bullets[i].scadder_radius, splash_count, bullets[i].bulltype, bullets[i].bulltype2, bullets[i].firer_npc, bullets[i].stun, is_3d, skip_kind, skip_idx);
}
