movetimer.restart();
}
else
{
key_strafe_right();
movetimer.restart();
}
}
}
if(key_down(KEY_DOWN) and key_up(KEY_G) and camdext == false and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT))
{
if(moveable==true)
{
if(onhook && hookable==true)
{
if(mapmode == "3d")
{
bonecheck();
hk.release_hook();
