void handle_command_keys()
{
if(controls.action_pressed("command_console") and commable==true)
{
if(glider_engine_on) glider_engine_stop();
comparse();
}
}

void handle_macro_keys()
{
uint bank = 0;
if (shift_is_down() && alt_is_down())
bank = 2;
else if (shift_is_down())
bank = 1;
uint offset = bank * ordered_scriptkeys.length();
for (uint i = 0; i < ordered_scriptkeys.length(); i++)
{
if (key_repeating(ordered_scriptkeys[i]) and scriptmode==true and scriptable==true)
{
use_macro(offset + i);
break;
}
}
}

// In the arena the macro row is repurposed to quick-draw weapons (macros are off there for anti-cheat).
// Slot = bank*14 + key index, across the same plain / Shift / Shift+Alt banks as macros, giving 42
// slots that map positionally onto the current weapon category's list, in the same order as the
// weapons menu's category tab. Switch which category the row addresses by drawing a weapon of another
// category from the menu. Slots past the category's count report empty; a locked weapon reports its level.
void handle_arena_weapon_keys()
{
if(!drawable) return;
uint bank = 0;
if (shift_is_down() && alt_is_down())
bank = 2;
else if (shift_is_down())
bank = 1;
uint offset = bank * ordered_scriptkeys.length();
for (uint i = 0; i < ordered_scriptkeys.length(); i++)
{
if (key_pressed(ordered_scriptkeys[i]))
{
arena_quick_draw(offset + i);
break;
}
}
}
void arena_quick_draw(uint slot)
{
string[] weps = get_pack_sound_folders("main/equipments/weapons/" + wepchar.cad + "/*");
if(slot >= weps.length())
{
speak("this slot is empty");
return;
}
string id = weps[slot];
weapon temp;
temp.parse(wepchar.cad, id);
if(level < temp.level)
{
speak(id + " unlocks at level " + int_to_string(int(temp.level)));
return;
}
draw_weapon(wepchar.cad, id);
}

void handle_draw_keys()
{
if(controls.action_pressed("weapons_menu") && !shift_is_down() && drawable==true)
{
pause_pools();
weaponsmenu();
}
if(controls.action_pressed("shields_menu") && !shift_is_down() && drawable==true)
{
string[] armor=get_pack_sound_folders("main/equipments/shields/*");
if(armor.length()==0)
{
speak("there are no shields available to view.");
}
else if(drawnshield==true)
{
speak("You can't switch to a different shield while the current one is in use.");
}
else
{
shieldparse();
pause_pools();
string res=shieldsmenu();
if(res!="")
{
drawnshield=true;
shieldtype=res;
}
}
}
}

void handle_spier_keys()
{
if(controls.action_pressed("spy_left") && !alt_is_down() and spiable==true)
{
key_spy_left();
}
if(controls.action_pressed("spy_right") && !alt_is_down() and spiable==true)
{
key_spy_right();
}
if(controls.action_pressed("spy_down") && !alt_is_down() and spiable==true)
{
key_spy_down();
}
if(controls.action_pressed("spy_up") && !alt_is_down() and spiable==true)
{
key_spy_up();
}
if(controls.action_pressed("spy_pgup") && !alt_is_down() && spiable==true)
{
key_spy_pgup();
}
if(controls.action_pressed("spy_pgdown") && !alt_is_down() && spiable==true)
{
key_spy_pgdown();
}
}

void handle_rotation_keys()
{
if(!alt_is_down() and !shift_is_down() and key_up(KEY_G) and camdext == false and doormove==false and elvmove==false and mapmode != "2d" and controls.action_pressed("rotate_left"))
{
if(moveable==true)
{
rotate_left();
movetimer.restart();
}
}
if(!alt_is_down() and !shift_is_down() and key_up(KEY_G) and camdext == false and doormove==false and elvmove==false and mapmode != "2d" and controls.action_pressed("rotate_right"))
{
if(moveable==true)
{
rotate_right();
movetimer.restart();
}
}
if(movetimer.elapsed>=movetime and doormove==false and elvmove==false and mapmode != "2d")
{
if(controls.action_down("rotate_left") and !alt_is_down() and !shift_is_down() and key_up(KEY_G) and camdext == false)
{
if(moveable==true)
{
rotate_left();
movetimer.restart();
}
}
if(controls.action_down("rotate_right") and !alt_is_down() and !shift_is_down() and key_up(KEY_G) and camdext == false)
{
if(moveable==true)
{
rotate_right();
movetimer.restart();
}
}
}
}

void handle_camera_keys()
{
if((key_down(KEY_G) || camdext) and !shift_is_down())
{
if(controls.action_repeating("camera_dexterity_toggle") and cammable==true)
{
camdext = !camdext;
if(switchsound==1)
{
if(camdext)
p.play_stationary(get_pack_sound("main/misc/toggleon.ogg"), false);
else
p.play_stationary(get_pack_sound("main/misc/toggleoff.ogg"), false);
}
if(camdext)
speak("Dexterity camera enabled.");
else
speak("Dexterity camera disabled.");
}
if ((key_down(KEY_G) || camdext) and controls.action_pressed("camera_mark_left") and cammable==true)
{
if (sel_left_set)
speak("Left marker is already set to " + sel_left);
else
{
sel_left = cam.x;
sel_left_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Left marker set to " + cam.x);
}
}
if ((key_down(KEY_G) || camdext) and controls.action_pressed("camera_mark_right") and cammable==true)
{
if (sel_right_set)
speak("Right marker is already set to " + sel_right);
else
{
sel_right = cam.x;
sel_right_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Right marker set to " + cam.x);
}
}
if ((key_down(KEY_G) || camdext) and !shift_is_down() and controls.action_pressed("camera_mark_back") and cammable==true)
{
if (mapmode != "2d")
{
if (sel_back_set)
speak("Back marker is already set to " + sel_back);
else
{
sel_back = cam.y;
sel_back_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Back marker set to " + cam.y);
}
}
else
{
if (sel_bottom_set)
speak("Bottom marker is already set to " + sel_bottom);
else
{
sel_bottom = cam.y;
sel_bottom_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Bottom marker set to " + cam.y);
}
}
}
if ((key_down(KEY_G) || camdext) and !shift_is_down() and controls.action_pressed("camera_mark_front") and cammable==true)
{
if (mapmode != "2d")
{
if (sel_front_set)
speak("Front marker is already set to " + sel_front);
else
{
sel_front = cam.y;
sel_front_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Front marker set to " + cam.y);
}
}
else
{
if (sel_top_set)
speak("Top marker is already set to " + sel_top);
else
{
sel_top = cam.y;
sel_top_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Top marker set to " + cam.y);
}
}
}
if (controls.action_pressed("camera_view_markers") and cammable==true)
{
if (!sel_left_set && !sel_right_set && !sel_back_set && !sel_front_set && !sel_bottom_set && !sel_top_set)
{
speak("No selection points to view.");
return;
}
string msg = "Selection points:";
if (sel_left_set)
msg += " left: " + sel_left + ",";
if (sel_right_set)
msg += " right: " + sel_right + ",";
if (sel_back_set)
msg += " back: " + sel_back + ",";
if (sel_front_set)
msg += " front: " + sel_front + ",";
if (sel_bottom_set)
msg += " bottom: " + sel_bottom + ",";
if (sel_top_set)
msg += " top: " + sel_top + ",";
if (msg.ends_with(","))
msg = msg.substr(0, msg.length() - 1);
speak(msg);
}
if (controls.action_pressed("camera_clear_markers") and cammable==true)
{
clear_camera_markers();
}
if(controls.action_pressed("camera_describe") and cammable==true)
{
bool is_3d = mapmode == "3d";
bool is_topdown = mapmode == "topdown";
bool y_is_depth = mapmode != "2d";
bool hazard_found = false;
string tile_lookup = platform_tile_at(cam.x, cam.y, cam.z);
bool no_tile = tile_lookup == "";
bool suppress_air = is_topdown && no_tile;
string tiletype = no_tile ? "air" : tile_lookup;
int dx = cam.x - me.x;
int dy = cam.y - me.y;
int dz = int(cam.z - me.z);
string[] pos_parts;
if(dx > 0) pos_parts.insert_last("Right " + dx);
else if(dx < 0) pos_parts.insert_last("Left " + abs(dx));
if(y_is_depth)
{
if(dy > 0) pos_parts.insert_last("In front " + dy);
else if(dy < 0) pos_parts.insert_last("Behind " + abs(dy));
}
else
{
if(dy > 0) pos_parts.insert_last("Above " + dy);
else if(dy < 0) pos_parts.insert_last("Below " + abs(dy));
}
if(is_3d)
{
if(dz > 0) pos_parts.insert_last("Above " + dz);
else if(dz < 0) pos_parts.insert_last("Below " + abs(dz));
}
string pos = oxford_join(@pos_parts);
bool here = is_3d ? (dx == 0 && dy == 0 && dz == 0) : (dx == 0 && dy == 0);
if(here) pos = "Right here";
string coords = is_3d ? (cam.x + ", " + cam.y + ", " + cam.z) : (cam.x + ", " + cam.y);
for(uint i = 0; i < hazards.length(); i++)
{
if(@hazards[i] == null) continue;
if(cam_in_hazard(i))
{
hazard_found = true;
if(suppress_air) speak(hazards[i].hazardtype + " hazard, " + coords + ". " + pos);
else speak(tiletype + " with " + hazards[i].hazardtype + " hazard, " + coords + ". " + pos);
break;
}
}
if(!hazard_found)
{
bool on_player = is_3d ? (me.x == cam.x && me.y == cam.y && me.z == cam.z) : (me.x == cam.x && me.y == cam.y);
if(on_player)
{
if(suppress_air) speak("player, " + coords + ". " + pos);
else speak(tiletype + " with player, " + coords + ". " + pos);
}
else
{
if(suppress_air) speak(coords + ". " + pos);
else speak(tiletype + ", " + coords + ". " + pos);
}
}
}
if(controls.action_repeating("camera_mfc_toggle") and cammable==true)
{
if(mfc==false)
{
mfc=true;
if(switchsound==1) p.play_stationary(get_pack_sound("main/misc/toggleon.ogg"),false);
speak("Mfwc enabled.");
}
else if(mfc==true)
{
mfc=false;
if(switchsound==1) p.play_stationary(get_pack_sound("main/misc/toggleoff.ogg"),false);
speak("Mfwc disabled.");
}
}
if(controls.action_repeating("camera_playback") and cammable==true)
{
playcam();
}
if(cleft.pressing())
{
key_cam_strafe_left();
}
if(cright.pressing())
{
key_cam_strafe_right();
}
if(cdown.pressing())
{
key_cam_down();
}
if(cup.pressing())
{
key_cam_up();
}
if(cpgdown.pressing() || cs.pressing())
{
key_cam_pgdown();
}
if(cpgup.pressing() || cw.pressing())
{
key_cam_pgup();
}
}
if ((key_down(KEY_G) || camdext) and controls.action_pressed("camera_mark_bottom_3d") and cammable==true and mapmode == "3d")
{
if (sel_bottom_set)
speak("Bottom marker is already set to " + sel_bottom);
else
{
sel_bottom = cam.z;
sel_bottom_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Bottom marker set to " + cam.z);
}
}
if ((key_down(KEY_G) || camdext) and controls.action_pressed("camera_mark_top_3d") and cammable==true and mapmode == "3d")
{
if (sel_top_set)
speak("Top marker is already set to " + sel_top);
else
{
sel_top = cam.z;
sel_top_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Top marker set to " + cam.z);
}
}
if(key_up(KEY_G) && !camdext)
{
for(uint i=0; i<safezones.length(); i++)
{
safezones[i].cam_in_zone=safezones[i].player_in_zone;
}
cam.x=me.x;
cam.y=me.y;
cam.z=me.z;
mfc=false;
}
}

