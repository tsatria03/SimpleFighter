void handle_command_keys()
{
if(key_pressed(KEY_SLASH) and commable==true)
{
// Drop the glider engine before opening the command console, the same way the auto-fire path naturally lets go of its trigger when a modal dialog takes focus. The console blocks the game loop while the player types, so leaving the engine engaged would keep the loop clip playing under the dialog and skip the off-clip transition the player expects.
if(glider_engine_on) glider_engine_stop();
comparse();
}
}

void handle_macro_keys()
{
uint bank = 0;
if (shift_is_down() && alt_is_down())
bank = 2;
else if (shift_is_down())
bank = 1;
uint offset = bank * ordered_scriptkeys.length();
for (uint i = 0; i < ordered_scriptkeys.length(); i++)
{
if (key_repeating(ordered_scriptkeys[i]) and scriptmode==true and scriptable==true)
{
use_macro(offset + i);
break;
}
}
}

void handle_weapon_draw_keys()
{
if(alt_is_down() && !shift_is_down() && key_pressed(KEY_W) && drawable==true)
{
pause_pools();
weaponsmenu();
}
if(alt_is_down() && !shift_is_down() && key_repeating(KEY_S) && drawable==true)
{
string[] armor=get_pack_sound_folders("main/equipments/shields/*");
if(armor.length()==0)
{
speak("there are no shields available to view.");
}
else if(drawnshield==true)
{
speak("You can't switch to a different shield while the current one is in use.");
}
else
{
shieldparse();
pause_pools();
string res=shieldsmenu();
if(res!="")
{
drawnshield=true;
shieldtype=res;
}
}
}
}

void handle_spier_keys()
{
if(shift_is_down() && !alt_is_down() && key_repeating(KEY_LEFT) and spiable==true)
{
key_spy_left();
}
if(shift_is_down() && !alt_is_down() && key_repeating(KEY_RIGHT) and spiable==true)
{
key_spy_right();
}
if(shift_is_down() && !alt_is_down() && key_repeating(KEY_DOWN) and spiable==true)
{
key_spy_down();
}
if(shift_is_down() && !alt_is_down() && key_repeating(KEY_UP) and spiable==true)
{
key_spy_up();
}
if(shift_is_down() && !alt_is_down() && (key_repeating(KEY_W) || key_repeating(KEY_PAGEUP)) && spiable==true)
{
key_spy_pgup();
}
if(shift_is_down() && !alt_is_down() && (key_repeating(KEY_S) || key_repeating(KEY_PAGEDOWN)) && spiable==true)
{
key_spy_pgdown();
}
}

void handle_rotation_keys()
{
if(!alt_is_down() and !shift_is_down() and key_up(KEY_G) and camdext == false and doormove==false and elvmove==false and mapmode != "2d" and key_pressed(KEY_Q))
{
if(moveable==true)
{
rotate_left();
movetimer.restart();
}
}
if(!alt_is_down() and !shift_is_down() and key_up(KEY_G) and camdext == false and doormove==false and elvmove==false and mapmode != "2d" and key_pressed(KEY_E))
{
if(moveable==true)
{
rotate_right();
movetimer.restart();
}
}
if(movetimer.elapsed>=movetime and doormove==false and elvmove==false and mapmode != "2d")
{
if(key_down(KEY_Q) and !alt_is_down() and !shift_is_down() and key_up(KEY_G) and camdext == false)
{
if(moveable==true)
{
rotate_left();
movetimer.restart();
}
}
if(key_down(KEY_E) and !alt_is_down() and !shift_is_down() and key_up(KEY_G) and camdext == false)
{
if(moveable==true)
{
rotate_right();
movetimer.restart();
}
}
}
}

void handle_camera_keys()
{
if((key_down(KEY_G) || camdext) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT))
{
if(key_repeating(KEY_Y) and cammable==true)
{
camdext = !camdext;
if(switchsound==1)
{
if(camdext)
p.play_stationary(get_pack_sound("main/misc/toggleon.ogg"), false);
else
p.play_stationary(get_pack_sound("main/misc/toggleoff.ogg"), false);
}
if(camdext)
speak("Dexterity camera enabled.");
else
speak("Dexterity camera disabled.");
}
if ((key_down(KEY_G) || camdext) and key_pressed(KEY_J) and cammable==true)
{
if (sel_left_set)
speak("Left marker is already set to " + sel_left);
else
{
sel_left = cam.x;
sel_left_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Left marker set to " + cam.x);
}
}
if ((key_down(KEY_G) || camdext) and key_pressed(KEY_L) and cammable==true)
{
if (sel_right_set)
speak("Right marker is already set to " + sel_right);
else
{
sel_right = cam.x;
sel_right_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Right marker set to " + cam.x);
}
}
if ((key_down(KEY_G) || camdext) and !shift_is_down() and key_pressed(KEY_K) and cammable==true)
{
if (mapmode != "2d")
{
if (sel_back_set)
speak("Back marker is already set to " + sel_back);
else
{
sel_back = cam.y;
sel_back_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Back marker set to " + cam.y);
}
}
else
{
if (sel_bottom_set)
speak("Bottom marker is already set to " + sel_bottom);
else
{
sel_bottom = cam.y;
sel_bottom_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Bottom marker set to " + cam.y);
}
}
}
if ((key_down(KEY_G) || camdext) and !shift_is_down() and key_pressed(KEY_I) and cammable==true)
{
if (mapmode != "2d")
{
if (sel_front_set)
speak("Front marker is already set to " + sel_front);
else
{
sel_front = cam.y;
sel_front_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Front marker set to " + cam.y);
}
}
else
{
if (sel_top_set)
speak("Top marker is already set to " + sel_top);
else
{
sel_top = cam.y;
sel_top_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Top marker set to " + cam.y);
}
}
}
if (key_pressed(KEY_SEMICOLON) and cammable==true)
{
speak_camera_markers();
}
if (key_pressed(KEY_APOSTROPHE) and cammable==true)
{
clear_camera_markers();
}
if(key_pressed(KEY_R) and cammable==true)
{
bool is_3d = mapmode == "3d";
bool is_topdown = mapmode == "topdown";
bool y_is_depth = mapmode != "2d";
bool hazard_found = false;
string tile_lookup = is_3d ? platform_tile_at(cam.x, cam.y, cam.z) : gct(cam.x, cam.y);
bool no_tile = tile_lookup == "";
bool suppress_air = is_topdown && no_tile;
string tiletype = no_tile ? "air" : tile_lookup;
int dx = cam.x - me.x;
int dy = cam.y - me.y;
int dz = int(cam.z - me.z);
string[] pos_parts;
if(dx > 0) pos_parts.insert_last("Right " + dx);
else if(dx < 0) pos_parts.insert_last("Left " + abs(dx));
if(y_is_depth)
{
if(dy > 0) pos_parts.insert_last("In front " + dy);
else if(dy < 0) pos_parts.insert_last("Behind " + abs(dy));
}
else
{
if(dy > 0) pos_parts.insert_last("Above " + dy);
else if(dy < 0) pos_parts.insert_last("Below " + abs(dy));
}
if(is_3d)
{
if(dz > 0) pos_parts.insert_last("Above " + dz);
else if(dz < 0) pos_parts.insert_last("Below " + abs(dz));
}
string pos = oxford_join(@pos_parts);
bool here = is_3d ? (dx == 0 && dy == 0 && dz == 0) : (dx == 0 && dy == 0);
if(here) pos = "Right here";
string coords = is_3d ? (cam.x + ", " + cam.y + ", " + cam.z) : (cam.x + ", " + cam.y);
for(uint i = 0; i < hazards.length(); i++)
{
if(cam_in_hazard(i))
{
hazard_found = true;
if(suppress_air) speak(hazards[i].hazardtype + " hazard, " + coords + ". " + pos);
else speak(tiletype + " with " + hazards[i].hazardtype + " hazard, " + coords + ". " + pos);
break;
}
}
if(!hazard_found)
{
bool on_player = is_3d ? (me.x == cam.x && me.y == cam.y && me.z == cam.z) : (me.x == cam.x && me.y == cam.y);
if(on_player)
{
if(suppress_air) speak("player, " + coords + ". " + pos);
else speak(tiletype + " with player, " + coords + ". " + pos);
}
else
{
if(suppress_air) speak(coords + ". " + pos);
else speak(tiletype + ", " + coords + ". " + pos);
}
}
}
if(key_repeating(KEY_M) and cammable==true)
{
if(mfc==false)
{
mfc=true;
if(switchsound==1) p.play_stationary(get_pack_sound("main/misc/toggleon.ogg"),false);
speak("Mfwc enabled.");
}
else if(mfc==true)
{
mfc=false;
if(switchsound==1) p.play_stationary(get_pack_sound("main/misc/toggleoff.ogg"),false);
speak("Mfwc disabled.");
}
}
if(key_repeating(KEY_T) and cammable==true)
{
playcam();
}
if(cleft.pressing())
{
key_cam_strafe_left();
}
if(cright.pressing())
{
key_cam_strafe_right();
}
if(cdown.pressing())
{
key_cam_down();
}
if(cup.pressing())
{
key_cam_up();
}
if(cpgdown.pressing() || cs.pressing())
{
key_cam_pgdown();
}
if(cpgup.pressing() || cw.pressing())
{
key_cam_pgup();
}
}
if ((key_down(KEY_G) || camdext) and shift_is_down() and key_pressed(KEY_K) and cammable==true and mapmode == "3d")
{
if (sel_bottom_set)
speak("Bottom marker is already set to " + sel_bottom);
else
{
sel_bottom = cam.z;
sel_bottom_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Bottom marker set to " + cam.z);
}
}
if ((key_down(KEY_G) || camdext) and shift_is_down() and key_pressed(KEY_I) and cammable==true and mapmode == "3d")
{
if (sel_top_set)
speak("Top marker is already set to " + sel_top);
else
{
sel_top = cam.z;
sel_top_set = true;
camslot=campool.play_stationary_extended(get_pack_sound("main/characters/"+chartype+"/map/*camset*"),false,0,0,0,100,false);
speak("Top marker set to " + cam.z);
}
}
if(key_up(KEY_G) && !camdext)
{
for(uint i=0; i<safezones.length(); i++)
{
safezones[i].cam_in_zone=safezones[i].player_in_zone;
}
cam.x=me.x;
cam.y=me.y;
cam.z=me.z;
mfc=false;
}
}

void handle_step_keys()
{
if(key_pressed(KEY_LEFT) and key_up(KEY_G) and camdext == false and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and doormove==false and elvmove==false)
{
if(moveable==true)
{
if(onhook && hookable==true)
{
facing="left";
bonecheck();
hk.release_hook();
key_strafe_left();
movetimer.restart();
}
else
{
key_strafe_left();
movetimer.restart();
}
}
}
if(key_pressed(KEY_RIGHT) and key_up(KEY_G) and camdext == false and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and doormove==false and elvmove==false)
{
if(moveable==true)
{
if(onhook && hookable==true)
{
facing="right";
bonecheck();
hk.release_hook();
key_strafe_right();
movetimer.restart();
}
else
{
key_strafe_right();
movetimer.restart();
}
}
}
if(key_pressed(KEY_DOWN) and key_up(KEY_G) and camdext == false and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and doormove==false and elvmove==false)
{
if(moveable==true)
{
if(onhook && hookable==true)
{
if(mapmode == "3d")
{
bonecheck();
hk.release_hook();
key_step_down();
movetimer.restart();
}
else
{
facing="down";
bonecheck();
hk.move_hook(0,-1);
movetimer.restart();
}
}
else
{
key_step_down();
movetimer.restart();
}
}
}
if(key_pressed(KEY_UP) and key_up(KEY_G) and camdext == false and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and doormove==false and elvmove==false)
{
if(moveable==true)
{
if(onhook && hookable==true)
{
if(mapmode == "3d")
{
bonecheck();
hk.release_hook();
key_step_up();
movetimer.restart();
}
else
{
facing="up";
bonecheck();
hk.move_hook(0,1);
movetimer.restart();
}
}
else
{
key_step_up();
movetimer.restart();
}
}
}
if((key_pressed(KEY_PAGEDOWN) || (key_pressed(KEY_S) && mapmode == "3d" && !alt_is_down())) and key_up(KEY_G) and camdext == false and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and doormove==false and elvmove==false)
{
if(moveable==true)
{
if(onhook && hookable==true && mapmode == "3d")
{
bonecheck();
hk.move_hook(0,0,-1);
movetimer.restart();
}
else
{
key_step_pgdown();
movetimer.restart();
}
}
}
if((key_pressed(KEY_PAGEUP) || (key_pressed(KEY_W) && mapmode == "3d" && !alt_is_down())) and key_up(KEY_G) and camdext == false and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and doormove==false and elvmove==false)
{
if(moveable==true)
{
if(onhook && hookable==true && mapmode == "3d")
{
bonecheck();
hk.move_hook(0,0,1);
movetimer.restart();
}
else
{
key_step_pgup();
movetimer.restart();
}
}
}
if(movetimer.elapsed>=movetime and doormove==false and elvmove==false)
{
if(key_down(KEY_LEFT) and key_up(KEY_G) and camdext == false and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT))
{
if(moveable==true)
{
if(onhook && hookable==true)
{
facing="left";
bonecheck();
hk.release_hook();
