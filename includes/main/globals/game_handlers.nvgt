movetimer.restart();
}
}
}
if(key_down(KEY_UP) and key_up(KEY_G) and camdext == false and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT))
{
if(moveable==true)
{
if(onhook && hookable==true)
{
if(mapmode == "3d")
{
bonecheck();
hk.release_hook();
key_step_up();
movetimer.restart();
}
else
{
facing="up";
bonecheck();
hk.move_hook(0,1);
movetimer.restart();
}
}
else
{
key_step_up();
movetimer.restart();
}
}
}
if((key_down(KEY_PAGEDOWN) || (key_down(KEY_S) && mapmode == "3d" && !alt_is_down())) and key_up(KEY_G) and camdext == false and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT))
{
